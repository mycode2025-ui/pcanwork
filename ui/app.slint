import { Button, ComboBox, LineEdit, CheckBox, TabWidget, ListView, ScrollView, VerticalBox, HorizontalBox, TextEdit } from "std-widgets.slint";

// ======================= Shared data structs (Rust <-> Slint) =======================

export struct ByteCell {
    hex: string,
    hot: bool,
}

// 仿真面板画布上一个控件的显示态
export struct SimRow {
    kind: int,       // 0指示灯 1仪表盘 2进度条 3数值 4标签 5按钮 6滑块 7信号发生器
    name: string,
    info: string,
    status: string,
    x: float,        // 画布坐标(逻辑px)
    y: float,
    w: float,
    h: float,
    on: bool,        // 指示灯点亮
    level: float,    // 0..1: 仪表盘角度 / 进度条 / 滑块位置
    selected: bool,
    primary: bool,   // 主控件(等高/等宽的模板基准)
    align: int,      // 文本对齐: 0左 1中 2右
}

export struct MsgRow {
    no: string,
    time: string,
    delta: string,
    ch: string,
    dir: string,
    id: string,
    name: string,
    kind: string,
    fd: string,
    brs: string,
    dlc: string,
    len: string,
    data-bytes: [ByteCell],
    data-text: string,
    cycle: string,
    count: string,
    comment: string,
    is-tx: bool,
    is-error: bool,
    is-new: bool,
    timeout: bool,
    is-signal: bool,
    can-expand: bool,
    expanded: bool,
    signal-name: string,
    signal-out-of-range: bool,
}

export struct SigRow {
    signal: string,
    raw: string,
    physical: string,
    unit: string,
    min: string,
    max: string,
    enum-txt: string,
    startbit: string,
    length: string,
    byteorder: string,
    signed: string,
    factor: string,
    offset: string,
    status: string,
    out-of-range: bool,
}

export struct TxSigRow {
    signal: string,
    phys: string,
    raw: string,
    unit: string,
    factor: string,
    offset: string,
    startbit: string,
    length: string,
    factor-num: float,
    offset-num: float,
}

export struct TxRow {
    enabled: bool,
    checked: bool,
    name: string,
    ch: string,
    id: string,
    dbcname: string,
    kind: string,
    fd: string,
    brs: string,
    dlc: string,
    data: string,
    mode: string,
    period: string,
    count: string,
    sent: string,
    status: string,
    running: bool,
}

export struct PbFileRow {
    name: string,
    count: string,
}

export struct TreeRow {
    level: int,
    label: string,
    kind: string,
    accent: bool,
    expandable: bool,
    expanded: bool,
}

export struct ChanStat {
    ch: string,
    state: string,
    rx: string,
    tx: string,
    err: string,
    load: string,
    fps: string,
    active-ids: string,
}

export struct IdStat {
    ch: string,
    id: string,
    name: string,
    count: string,
    avg-cycle: string,
    min: string,
    max: string,
    last-time: string,
    timeout: string,
}

export struct ChartSeries {
    name: string,
    commands: string,
    clr: color,
    cur: string,
    unit: string,
    axis-max: string,
    axis-mid: string,
    axis-min: string,
    cursor-value: string,
    cursor-y: float,
    cursor-valid: bool,
    cursor2-value: string,
    cursor2-y: float,
    cursor2-valid: bool,
    visible: bool,
    highlight: bool,
    smin: string,
    smax: string,
}

export struct DbcSignalRow {
    label: string,
}

export struct SignalPickRow {
    level: int,
    name: string,
    desc: string,
    kind: string,
    expandable: bool,
    expanded: bool,
    selectable: bool,
    selected: bool,
}

// ======================= Theme =======================

// 中英切换: en=true 显示英文。各处文案写 I18n.en ? "English" : "中文"。
export global I18n {
    in-out property <bool> en: false;
}

export global Theme {
    in-out property <bool> dark: false;
    in-out property <bool> big: true; // 触摸友好的大布局

    // 学术蓝（Academic Blue）配色：冷蓝灰中性 + 海军/宝蓝主色
    out property <color> bg: dark ? #0d1726 : #eef3f9;
    out property <color> panel: dark ? #132237 : #ffffff;
    out property <color> panel2: dark ? #1a2c44 : #e3ecf6;
    out property <color> border: dark ? #2a3f5c : #cdd9e8;
    out property <color> text: dark ? #e4ecf7 : #16243a;
    out property <color> text-dim: dark ? #93a6c0 : #5a6b85;
    out property <color> header: dark ? #16273d : #e0eaf5;
    out property <color> accent: dark ? #5b9bf0 : #1c5aa6;
    out property <color> accent-soft: dark ? #1e3556 : #dbe7f6;
    out property <color> tx-bg: dark ? #14253f : #e8f1fc;
    out property <color> err-bg: dark ? #3a1f23 : #fdecec;
    out property <color> new-bg: dark ? #16301f : #e8f8ee;
    out property <color> timeout-bg: dark ? #3a2e16 : #fff4e2;
    out property <color> changed-bg: dark ? #4a4420 : #fff3bf;
    out property <color> ok: dark ? #4ade80 : #16a34a;
    out property <color> warn: dark ? #fbbf24 : #d97706;
    out property <color> bad: dark ? #f87171 : #dc2626;
    out property <color> sel: dark ? #21406a : #cfe0f5;
    out property <color> zebra: dark ? #101c2e : #f6f9fd;
    out property <color> sigrow: dark ? #122138 : #eef5fd;

    out property <length> rowh: big ? 32px : 26px;
    out property <length> ctrl-h: big ? 38px : 30px;
    out property <length> fs: big ? 14px : 12px;
    out property <length> fs-sm: big ? 13px : 11px;
    out property <length> radius: 6px;
    out property <string> mono: "Cascadia Mono, Consolas";
}

// 列宽（0px = 隐藏该列）。Rust 端在切换列可见性时改写这些值。
export global ColW {
    in-out property <length> no: 52px;
    in-out property <length> time: 96px;
    in-out property <length> delta: 80px;
    in-out property <length> ch: 56px;
    in-out property <length> dir: 44px;
    in-out property <length> id: 88px;
    in-out property <length> name: 150px;
    in-out property <length> kind: 48px;
    in-out property <length> fd: 40px;
    in-out property <length> brs: 40px;
    in-out property <length> dlc: 44px;
    in-out property <length> len: 44px;
    in-out property <length> data: 230px;
    in-out property <length> cycle: 72px;
    in-out property <length> count: 72px;
    in-out property <length> comment: 140px;
    in-out property <length> total: 1268px;
}

// ======================= Small reusable cells =======================

component Cell inherits Rectangle {
    in property <string> text;
    in property <length> w;
    in property <color> txt-clr: Theme.text;
    in property <bool> mono: false;
    in property <TextHorizontalAlignment> align: left;
    width: w;
    clip: true;
    HorizontalLayout {
        padding-left: 7px;
        padding-right: 7px;
        Text {
            text: text;
            color: txt-clr;
            vertical-alignment: center;
            horizontal-alignment: align;
            font-family: mono ? Theme.mono : "";
            font-size: Theme.fs;
            overflow: elide;
        }
    }
}

component HCell inherits Rectangle {
    in property <string> text;
    in property <length> w;
    width: w;
    background: Theme.header;
    Rectangle { width: 1px; x: parent.width - 1px; background: Theme.border; }
    Text {
        text: text;
        x: 7px;
        color: Theme.text;
        font-weight: 700;
        font-size: Theme.fs;
        vertical-alignment: center;
    }
}

component SortHeader inherits Rectangle {
    in property <string> text;
    in property <length> w;
    in property <int> cidx;
    in property <int> sort-col: -1;
    in property <bool> sort-desc: false;
    callback clicked(int);
    width: w;
    background: ta.has-hover ? Theme.accent-soft : Theme.header;
    Rectangle { width: 1px; x: parent.width - 1px; background: Theme.border; }
    ta := TouchArea { clicked => { root.clicked(cidx); } }
    HorizontalLayout {
        padding-left: 7px; padding-right: 3px;
        Text {
            text: text; color: Theme.text; font-weight: 700; font-size: Theme.fs;
            vertical-alignment: center; horizontal-stretch: 1; overflow: elide;
        }
        Text {
            text: root.sort-col == cidx ? (sort-desc ? "v" : "^") : "";
            color: Theme.accent; font-size: Theme.fs-sm; vertical-alignment: center;
        }
    }
}

component TBtn inherits Rectangle {
    in property <string> text;
    in property <bool> active: false;
    in property <bool> boxed: false;   // always render a button box (border + surface), even when idle
    in property <bool> primary: false; // filled accent (primary action button)
    in property <bool> btn-enabled: true;
    in property <length> h: Theme.ctrl-h;
    callback clicked;
    width: txt.preferred-width + 22px;
    height: h;
    border-radius: Theme.radius;
    background: !root.btn-enabled ? Theme.panel2
        : (root.primary || root.active) ? Theme.accent
        : ta.has-hover ? Theme.panel2
        : root.boxed ? Theme.panel
        : transparent;
    border-width: 1px;
    border-color: (root.primary || root.active) ? Theme.accent
        : (root.boxed || ta.has-hover) ? Theme.border
        : transparent;
    txt := Text {
        text: text;
        width: 100%;
        color: !root.btn-enabled ? Theme.text-dim : ((root.primary || root.active) ? white : Theme.text);
        vertical-alignment: center;
        horizontal-alignment: center;
        font-size: Theme.fs;
    }
    ta := TouchArea { enabled: root.btn-enabled; clicked => { root.clicked(); } }
}


// ======================= 矢量图标 =======================

component Icon inherits Rectangle {
    in property <string> name;
    in property <color> clr: Theme.text;
    property <string> fcmd:
        name == "start" ? "M8 5 L19 12 L8 19 Z" :
        name == "stop" ? "M7 7 H17 V17 H7 Z" :
        name == "record" ? "M12 6 A6 6 0 0 0 12 18 A6 6 0 0 0 12 6 Z" :
        name == "pause" ? "M7 6 H10 V18 H7 Z M14 6 H17 V18 H14 Z" :
        name == "theme" ? "M12 4 A8 8 0 0 0 12 20 Z" : "";
    property <string> scmd:
        name == "demo" ? "M3 14 C6 6 9 6 12 14 C15 22 18 22 21 14" :
        name == "connect" ? "M5 12 H10 M14 12 H19 M10 8 V16 M14 8 V16" :
        name == "disconnect" ? "M5 12 H9 M15 12 H19 M5 5 L19 19" :
        name == "channel" ? "M4 9 H18 M15 6 L18 9 L15 12 M20 15 H6 M9 12 L6 15 L9 18" :
        name == "database" ? "M5 6 A7 2.5 0 0 0 19 6 A7 2.5 0 0 0 5 6 V18 A7 2.5 0 0 0 19 18 V6 M5 12 A7 2.5 0 0 0 19 12" :
        name == "language" ? "M4 17 L7.5 7 L11 17 M5.5 13 H9.5 M14 8 H21 M17.5 8 V18 M14 12 H21 M15 18 H20" :
        name == "send" ? "M3 6 H21 V18 H3 Z M3 6 L12 13 L21 6" :
        name == "curve" ? "M3 18 L9 11 L13 15 L21 5" :
        name == "playback" ? "M8 6 L18 12 L8 18 Z" :
        name == "clear" ? "M6 6 L18 18 M18 6 L6 18" :
        name == "layout" ? "M4 4 H20 V20 H4 Z M4 12 H20 M12 4 V20" :
        name == "modbus" ? "M4 5 H20 V19 H4 Z M9 5 V19 M4 10 H20 M4 14 H20" :
        name == "file" ? "M7 3 H14 L19 8 V21 H7 Z M14 3 V8 H19" :
        name == "folder" ? "M3 7 H9 L11 9 H21 V19 H3 Z" :
        name == "save" ? "M4 4 H16 L20 8 V20 H4 Z M8 4 V9 H15 M8 20 V14 H16 V20" :
        name == "filter" ? "M4 5 H20 L14 12 V19 L10 17 V12 Z" :
        name == "window" ? "M4 5 H20 V19 H4 Z M4 9 H20" : "";
    Path {
        visible: fcmd != "";
        commands: fcmd; fill: clr;
        viewbox-width: 24; viewbox-height: 24; width: 100%; height: 100%;
    }
    Path {
        visible: scmd != "";
        commands: scmd; stroke: clr; stroke-width: 1.7px;
        viewbox-width: 24; viewbox-height: 24; width: 100%; height: 100%;
    }
}

// ======================= Ribbon (ZXDoc 风格功能区) =======================

component RibbonBtn inherits Rectangle {
    in property <string> icon;
    in property <string> label;
    in property <color> icon-clr: Theme.accent;
    in property <bool> active: false;
    callback clicked;
    width: Theme.big ? 62px : 54px;
    border-radius: Theme.radius;
    background: active ? Theme.accent : (ta.has-hover ? Theme.accent-soft : transparent);
    VerticalLayout {
        padding: 4px;
        spacing: 3px;
        Rectangle {
            height: Theme.big ? 36px : 30px;
            tile := Rectangle {
                width: Theme.big ? 36px : 30px; height: self.width;
                x: (parent.width - self.width) / 2; y: (parent.height - self.height) / 2;
                border-radius: Theme.radius;
                background: active ? #ffffff33 : (ta.has-hover ? Theme.panel : Theme.panel2);
                border-width: 1px;
                border-color: active ? #ffffff44 : Theme.border;
                drop-shadow-blur: 2px;
                drop-shadow-color: active ? transparent : #00000018;
                drop-shadow-offset-y: 1px;
                Icon {
                    name: icon; clr: active ? white : icon-clr;
                    width: Theme.big ? 22px : 18px; height: self.width;
                    x: (parent.width - self.width) / 2; y: (parent.height - self.height) / 2;
                }
            }
        }
        Text {
            text: label; font-size: Theme.fs-sm;
            color: active ? white : Theme.text;
            horizontal-alignment: center; vertical-alignment: center;
            wrap: word-wrap;
        }
    }
    ta := TouchArea { clicked => { root.clicked(); } }
}

component RibbonGroup inherits Rectangle {
    in property <string> caption;
    Rectangle { width: 1px; x: parent.width - 1px; background: Theme.border; }
    VerticalLayout {
        padding-left: 5px; padding-right: 6px; padding-top: 4px; padding-bottom: 8px;
        spacing: 2px;
        HorizontalLayout { spacing: 1px; vertical-stretch: 1; @children }
        Text {
            text: caption; font-size: Theme.fs-sm; color: Theme.text-dim;
            horizontal-alignment: center; height: 16px;
        }
    }
}

component RibbonTab inherits Rectangle {
    in property <string> text;
    in property <bool> active: false;
    callback clicked;
    width: txt.preferred-width + 22px;
    height: 28px;
    background: active ? Theme.panel : transparent;
    border-top-left-radius: 4px; border-top-right-radius: 4px;
    txt := Text {
        text: text; color: active ? Theme.accent : Theme.text;
        font-weight: active ? 700 : 400; font-size: Theme.fs;
        horizontal-alignment: center; vertical-alignment: center;
    }
    Rectangle {
        visible: active; height: 2px; width: 100%; y: parent.height - 2px; background: Theme.accent;
    }
    ta := TouchArea { clicked => { root.clicked(); } }
}

export component SignalSelectWindow inherits Window {
    title: I18n.en ? "Select Signal" : "选择信号";
    icon: @image-url("logo.svg");
    preferred-width: 900px;
    preferred-height: 560px;
    background: Theme.bg;

    in property <[SignalPickRow]> signal-pick-rows;
    in property <string> signal-pick-summary;
    in property <string> signal-pick-dbc-name: "(无)";
    in-out property <string> signal-pick-filter;
    // 左侧分类: 0=CAN/DBC, 1=System, 2=User Defined, 3=Expression, 4=Function
    in-out property <int> sig-cat: 0;
    // 表达式编辑器(sig-cat==3 时显示)
    in-out property <string> expr-name;
    in-out property <string> expr-formula;
    in-out property <string> expr-unit;
    in property <string> expr-error;

    callback signal-pick-search(string);
    callback signal-pick-row-clicked(int);
    callback signal-pick-row-double-clicked(int);
    callback signal-pick-ok();
    callback signal-pick-apply();
    callback signal-pick-cancel();
    callback sig-cat-changed(int);
    callback expr-save();   // 添加/更新表达式(用 expr-name/formula/unit)
    callback expr-delete(); // 删除当前选中的表达式

    VerticalLayout {
        padding: 12px;
        spacing: 8px;

        HorizontalLayout {
            spacing: 0px;
            // 左侧导航
            Rectangle {
                width: 220px;
                background: Theme.panel;
                border-width: 1px; border-color: Theme.border;
                VerticalLayout {
                    Rectangle {
                        height: 52px;
                        background: root.sig-cat == 0 ? Theme.accent-soft : (cana.has-hover ? Theme.accent-soft : transparent);
                        cana := TouchArea { clicked => { root.sig-cat = 0; root.sig-cat-changed(0); } }
                        HorizontalLayout {
                            padding-left: 12px; spacing: 8px;
                            Rectangle { width: 14px; Icon { name: "channel"; clr: Theme.accent; width: 14px; height: 14px; y: (parent.height - self.height)/2; } }
                            VerticalLayout {
                                alignment: center;
                                Text { text: "CAN 1"; font-size: Theme.fs; font-weight: 700; color: Theme.text; }
                                Text { text: root.signal-pick-dbc-name; font-size: Theme.fs-sm; color: Theme.text-dim; overflow: elide; }
                            }
                        }
                    }
                    for nav[i] in ["System Variables", "User Defined Variables", "Expression Variables", "Function Signals"]: Rectangle {
                        height: 36px;
                        background: root.sig-cat == i + 1 ? Theme.sel : (nta.has-hover ? Theme.accent-soft : transparent);
                        nta := TouchArea { clicked => { root.sig-cat = i + 1; root.sig-cat-changed(i + 1); } }
                        HorizontalLayout {
                            padding-left: 12px; spacing: 8px;
                            Rectangle { width: 16px; Icon { name: i == 2 ? "curve" : "filter"; clr: Theme.text-dim; width: 13px; height: 13px; y: (parent.height - self.height)/2; } }
                            Text { text: nav; vertical-alignment: center; color: Theme.text; font-size: Theme.fs; }
                        }
                    }
                    Rectangle { vertical-stretch: 1; }
                }
            }

            // 右侧 DBC 树
            Rectangle {
                horizontal-stretch: 1;
                background: Theme.panel;
                border-width: 1px; border-color: Theme.border;
                VerticalLayout {
                    Rectangle {
                        height: 36px; background: Theme.panel2;
                        HorizontalLayout {
                            padding-left: 8px; padding-right: 8px; spacing: 8px;
                            Text { text: I18n.en ? "Search" : "搜索"; vertical-alignment: center; font-size: Theme.fs; color: Theme.text-dim; }
                            search-edit := LineEdit {
                                text: root.signal-pick-filter;
                                placeholder-text: I18n.en ? "filter by name" : "按名称过滤";
                                height: Theme.ctrl-h - 4px;
                                horizontal-stretch: 1;
                                edited(v) => { root.signal-pick-search(v); }
                                accepted(v) => { root.signal-pick-search(v); }
                            }
                            TBtn { text: I18n.en ? "Search" : "搜索"; clicked => { root.signal-pick-search(search-edit.text); } }
                        }
                    }
                    // 表达式编辑器（仅 Expression Variables 分类显示）
                    if root.sig-cat == 3: Rectangle {
                        height: 46px; background: Theme.panel2;
                        HorizontalLayout {
                            padding: 7px; spacing: 6px;
                            LineEdit { width: 120px; height: Theme.ctrl-h - 4px; placeholder-text: I18n.en ? "name" : "名称"; text <=> root.expr-name; }
                            LineEdit { horizontal-stretch: 1; height: Theme.ctrl-h - 4px; placeholder-text: I18n.en ? "formula e.g. Voltage*Current/1000" : "表达式 如 Voltage*Current/1000"; text <=> root.expr-formula; accepted(v) => { root.expr-save(); } }
                            LineEdit { width: 70px; height: Theme.ctrl-h - 4px; placeholder-text: I18n.en ? "unit" : "单位"; text <=> root.expr-unit; }
                            TBtn { text: I18n.en ? "Add/Update" : "添加/更新"; clicked => { root.expr-save(); } }
                            TBtn { text: I18n.en ? "Delete" : "删除"; clicked => { root.expr-delete(); } }
                        }
                    }
                    if root.sig-cat == 3 && root.expr-error != "": Rectangle {
                        height: 22px; background: Theme.panel2;
                        Text { text: root.expr-error; x: 10px; width: parent.width - 16px; color: #e06c6c; font-size: Theme.fs-sm; vertical-alignment: center; overflow: elide; }
                    }
                    Rectangle {
                        height: 24px;
                        HorizontalLayout {
                            HCell { text: I18n.en ? "Name" : "名称"; w: 420px; }
                            HCell { text: I18n.en ? "Desc" : "描述"; w: 220px; }
                        }
                    }
                    ListView {
                        for row[i] in root.signal-pick-rows: Rectangle {
                            height: Theme.big ? 28px : 24px;
                            background: row.selected ? Theme.sel : (ta.has-hover ? Theme.accent-soft : (Math.mod(i, 2) == 0 ? Theme.panel : Theme.zebra));
                            ta := TouchArea {
                                clicked => { root.signal-pick-row-clicked(i); }
                                double-clicked => { root.signal-pick-row-double-clicked(i); }
                            }
                            HorizontalLayout {
                                spacing: 0px;
                                Rectangle {
                                    width: 420px; clip: true;
                                    HorizontalLayout {
                                        padding-left: 8px + row.level * 18px; spacing: 5px;
                                        Text {
                                            text: row.expandable ? (row.expanded ? "v" : ">") : "";
                                            width: 12px; color: Theme.text-dim;
                                            vertical-alignment: center; horizontal-alignment: center; font-size: Theme.fs-sm; font-family: Theme.mono;
                                        }
                                        Rectangle { width: 16px;
                                            Icon {
                                                name: row.kind == "dbc" ? "database" : (row.kind == "folder" ? "folder" : (row.kind == "message" ? "send" : "curve"));
                                                clr: row.kind == "message" ? Theme.accent : Theme.text-dim;
                                                width: 13px; height: 13px; x: (parent.width - self.width)/2; y: (parent.height - self.height)/2;
                                            }
                                        }
                                        Text { text: row.name; color: Theme.text; font-size: Theme.fs; vertical-alignment: center; overflow: elide; }
                                    }
                                }
                                Rectangle { width: 1px; background: Theme.border; }
                                Rectangle {
                                    horizontal-stretch: 1; clip: true;
                                    Text { text: row.desc; x: 8px; width: parent.width - 10px; color: Theme.text-dim; font-size: Theme.fs; vertical-alignment: center; overflow: elide; }
                                }
                            }
                        }
                    }
                }
            }
        }

        Rectangle {
            height: 36px;
            HorizontalLayout {
                spacing: 8px;
                Text { text: root.signal-pick-summary; color: Theme.text-dim; font-size: Theme.fs; vertical-alignment: center; horizontal-stretch: 1; }
                Button { text: I18n.en ? "OK" : "确定"; width: 96px; clicked => { root.signal-pick-ok(); } }
                Button { text: I18n.en ? "Cancel" : "取消"; width: 96px; clicked => { root.signal-pick-cancel(); } }
                Button { text: I18n.en ? "Apply" : "应用"; width: 96px; clicked => { root.signal-pick-apply(); } }
            }
        }
    }
}

export component ChartWindow inherits Window {
    title: I18n.en ? "PcanWork - Chart Window" : "PcanWork - 独立曲线窗口";
    icon: @image-url("logo.svg");
    preferred-width: 1280px;
    preferred-height: 820px;
    min-width: 900px;
    min-height: 560px;
    background: Theme.bg;

    in property <[ChartSeries]> series;
    in property <string> chart-xstart-label;
    in property <string> chart-xend-label;
    in property <[string]> chart-xlabels;
    in property <string> chart-cursor-readout;
    in property <bool> chart-paused: false;
    in property <bool> chart-cursor: false;
    in-out property <float> cursor-frac;
    // 双游标：开启后显示第二条游标线(cursor-frac2)，并在读数里给出两游标的时间差/值差
    in property <bool> chart-dual: false;
    in-out property <float> cursor-frac2: 0.5;
    property <int> drag-target: 1; // 双游标拖动时当前抓住的游标(1/2)
    // 绘图区宽高比：由 Rust 根据上报的 plot 像素宽高算出并写回，Path viewbox 读它(纯值,无布局依赖)。
    in-out property <float> chart-aspect: 4.0;
    // plot 像素宽高，仅由 Rust 读取(Slint 布局不读这两个属性，故在 changed 里写不会引起布局递归)。
    in-out property <float> plot-w: 600;
    in-out property <float> plot-h: 110;
    // 每条曲线行高(px)：由 Rust 算 max(最小高, 区域高/可见数)，信号少则等分填满、多则按最小高并滚动。
    in-out property <float> row-h: 120;

    in property <bool> chart-sig-logging: false;
    callback chart-toggle-pause();
    callback clear-chart();
    callback chart-cursor-toggle();
    callback chart-dual-toggle();
    callback chart-cursor-move();
    callback chart-export-csv();
    callback chart-export-wide-csv();
    callback chart-sig-log-toggle();
    callback open-signal-selector();
    callback chart-toggle-series(int);
    callback chart-remove-series(int);
    callback chart-zoom(float, float);
    callback chart-fit();

    HorizontalLayout {
        Rectangle {
            width: 260px; background: Theme.panel;
            Rectangle { width: 1px; height: 100%; x: parent.width - 1px; background: Theme.border; }
            VerticalLayout {
                // 第一行：选择信号
                Rectangle {
                    height: Theme.ctrl-h + 8px; background: Theme.panel2;
                    Rectangle { width: 100%; height: 1px; y: parent.height - 1px; background: Theme.border; }
                    HorizontalLayout {
                        padding: 4px; spacing: 6px; alignment: start;
                        TBtn { text: I18n.en ? "Select Signal" : "选择信号"; clicked => { root.open-signal-selector(); } }
                        Text { text: I18n.en ? "Add from DBC message tree" : "从 DBC 消息树添加"; vertical-alignment: center; font-size: Theme.fs-sm; color: Theme.text-dim; horizontal-stretch: 1; }
                    }
                }
                // 第二行：曲线信号（列表标题）
                Rectangle {
                    height: 28px; background: Theme.header;
                    Rectangle { width: 100%; height: 1px; y: parent.height - 1px; background: Theme.border; }
                    Text { text: I18n.en ? "Chart Signals" : "曲线信号"; x: 8px; vertical-alignment: center; font-weight: 700; font-size: Theme.fs; color: Theme.text; }
                }
                ListView {
                    for ser[i] in root.series: Rectangle {
                        height: 34px;
                        background: Math.mod(i, 2) == 0 ? Theme.panel : Theme.zebra;
                        HorizontalLayout {
                            padding-left: 6px; padding-right: 4px; spacing: 6px;
                            Rectangle {
                                width: 16px; height: 16px; y: (parent.height - 16px) / 2;
                                border-width: 1px; border-color: Theme.border; border-radius: 3px;
                                background: ser.visible ? Theme.accent : white;
                                Text { text: ser.visible ? "v" : ""; color: white; font-size: 11px; horizontal-alignment: center; vertical-alignment: center; }
                                TouchArea { clicked => { root.chart-toggle-series(i); } }
                            }
                            Rectangle { width: 12px; height: 12px; y: (parent.height - 12px) / 2; background: ser.clr; border-radius: 2px; }
                            VerticalLayout {
                                horizontal-stretch: 1;
                                Text { text: ser.name; font-size: 11px; color: Theme.text; overflow: elide; }
                                Text { text: (I18n.en ? "cur " : "当 ") + ser.cur + (I18n.en ? "  lo " : "  低 ") + ser.smin + (I18n.en ? "  hi " : "  高 ") + ser.smax + " " + ser.unit; font-size: 10px; color: Theme.text-dim; font-family: Theme.mono; overflow: elide; }
                            }
                            Rectangle {
                                width: 18px;
                                Text { text: "X"; color: Theme.bad; font-size: 12px; horizontal-alignment: center; vertical-alignment: center; }
                                TouchArea { clicked => { root.chart-remove-series(i); } }
                            }
                        }
                    }
                }
            }
        }

        VerticalLayout {
            Rectangle {
                height: Theme.ctrl-h + 8px; background: Theme.panel2;
                Rectangle { width: 100%; height: 1px; y: parent.height - 1px; background: Theme.border; }
                HorizontalLayout {
                    padding: 4px; spacing: 3px; alignment: start;
                    TBtn { text: root.chart-paused ? (I18n.en ? "Resume" : "继续") : (I18n.en ? "Pause" : "暂停"); active: root.chart-paused; clicked => { root.chart-toggle-pause(); } }
                    TBtn { text: I18n.en ? "Clear" : "清空"; clicked => { root.clear-chart(); } }
                    TBtn { text: I18n.en ? "Cursor" : "游标"; active: root.chart-cursor; clicked => { root.chart-cursor-toggle(); } }
                    TBtn { text: I18n.en ? "Dual Cursor" : "双游标"; active: root.chart-dual; clicked => { root.chart-dual-toggle(); } }
                    Rectangle { width: 1px; background: Theme.border; }
                    Text { text: I18n.en ? "Time axis:" : "时间轴:"; vertical-alignment: center; font-size: 11px; color: Theme.text-dim; }
                    TBtn { text: I18n.en ? "Zoom+" : "放大"; clicked => { root.chart-zoom(-1, 0.5); } }
                    TBtn { text: I18n.en ? "Zoom-" : "缩小"; clicked => { root.chart-zoom(1, 0.5); } }
                    TBtn { text: I18n.en ? "Fit" : "适应"; clicked => { root.chart-fit(); } }
                    Rectangle { width: 1px; background: Theme.border; }
                    TBtn { text: I18n.en ? "Export CSV" : "导出CSV"; clicked => { root.chart-export-csv(); } }
                    TBtn { text: I18n.en ? "Export Wide" : "导出宽表"; clicked => { root.chart-export-wide-csv(); } }
                    TBtn { text: root.chart-sig-logging ? (I18n.en ? "Stop log" : "停止记录") : (I18n.en ? "Sig log" : "信号记录"); active: root.chart-sig-logging; clicked => { root.chart-sig-log-toggle(); } }
                    Rectangle { horizontal-stretch: 1; }
                    Text { text: I18n.en ? "Independent Y axis · each signal by its own Min/Max" : "独立 Y 轴 · 每信号按自身 Min/Max"; vertical-alignment: center; font-size: 11px; color: Theme.text-dim; }
                }
            }

            // 各信号垂直方向等分填满（VerticalLayout 永远铺满不溢出，无需内部滚动→不抢拖动手势）
            VerticalLayout {
                spacing: 0px;
                // 上报曲线区像素宽高给 Rust（容器尺寸自上而下给定、稳定，读它不触发布局递归）。
                changed width => { root.plot-w = self.width / 1px; }
                changed height => { root.plot-h = self.height / 1px; }
                init => { root.plot-w = self.width / 1px; root.plot-h = self.height / 1px; }
                // 空曲线提示: 必须在 for 外(空时循环不渲染, 原提示写在循环内永远不显示)
                if root.series.length == 0: Rectangle {
                    vertical-stretch: 1;
                    Text {
                        width: 100%; height: 100%;
                        text: I18n.en ? "Add curves from the signal panel or by right-clicking an expanded signal" : "从信号解析或展开信号右键添加曲线";
                        color: Theme.text-dim; font-size: 13px;
                        horizontal-alignment: center; vertical-alignment: center; wrap: word-wrap;
                    }
                }
                for ser[i] in root.series: Rectangle {
                    vertical-stretch: ser.visible ? 1 : 0;
                    max-height: ser.visible ? 100000px : 0px;
                    clip: true;
                    background: Theme.panel;
                    HorizontalLayout {
                        plot := Rectangle {
                            clip: true;
                            border-width: ser.highlight ? 2px : 1px;
                            border-color: ser.highlight ? ser.clr : Theme.border;
                            background: ser.highlight ? Theme.accent-soft : Theme.panel;
                            for gy in [0.5]: Rectangle {
                                width: 100%; height: 1px; y: parent.height * gy; background: Theme.border;
                            }
                            Path {
                                width: 100%; height: 100%;
                                viewbox-width: 100 * root.chart-aspect;
                                viewbox-height: 100;
                                stroke: ser.clr;
                                stroke-width: ser.highlight ? 3px : 1.5px;
                                commands: ser.commands;
                            }
                            if root.chart-cursor: Rectangle {
                                width: 1px; height: 100%; x: parent.width * root.cursor-frac; background: Theme.bad;
                            }
                            if root.chart-cursor && ser.cursor-valid: Rectangle {
                                width: 7px; height: 7px;
                                x: parent.width * root.cursor-frac - 3px;
                                y: parent.height * ser.cursor-y / 100 - 3px;
                                border-radius: 4px;
                                background: ser.clr;
                                border-width: 1px;
                                border-color: white;
                            }
                            if root.chart-cursor && ser.cursor-valid: Rectangle {
                                width: 112px; height: 22px;
                                x: root.cursor-frac > 0.72 ? parent.width * root.cursor-frac - 118px : parent.width * root.cursor-frac + 8px;
                                y: ser.cursor-y > 78 ? parent.height * ser.cursor-y / 100 - 26px : parent.height * ser.cursor-y / 100 + 6px;
                                background: Theme.panel;
                                border-width: 1px;
                                border-color: ser.clr;
                                border-radius: 3px;
                                Text {
                                    text: ser.cursor-value;
                                    x: 4px;
                                    width: parent.width - 8px;
                                    color: ser.clr;
                                    font-size: 11px;
                                    font-family: Theme.mono;
                                    vertical-alignment: center;
                                    overflow: elide;
                                }
                            }
                            // 第二游标（双游标模式，蓝色；点击放置）
                            if root.chart-cursor && root.chart-dual: Rectangle {
                                width: 1px; height: 100%; x: parent.width * root.cursor-frac2; background: Theme.accent;
                            }
                            if root.chart-cursor && root.chart-dual && ser.cursor2-valid: Rectangle {
                                width: 7px; height: 7px;
                                x: parent.width * root.cursor-frac2 - 3px;
                                y: parent.height * ser.cursor2-y / 100 - 3px;
                                border-radius: 4px;
                                background: Theme.accent;
                                border-width: 1px;
                                border-color: white;
                            }
                            // 第二游标的值框（蓝色边，与游标1一样显示实时值）
                            if root.chart-cursor && root.chart-dual && ser.cursor2-valid: Rectangle {
                                width: 112px; height: 22px;
                                x: root.cursor-frac2 > 0.72 ? parent.width * root.cursor-frac2 - 118px : parent.width * root.cursor-frac2 + 8px;
                                y: ser.cursor2-y > 78 ? parent.height * ser.cursor2-y / 100 - 26px : parent.height * ser.cursor2-y / 100 + 6px;
                                background: Theme.panel;
                                border-width: 1px;
                                border-color: Theme.accent;
                                border-radius: 3px;
                                Text {
                                    text: ser.cursor2-value;
                                    x: 4px;
                                    width: parent.width - 8px;
                                    color: ser.clr;
                                    font-size: 11px;
                                    font-family: Theme.mono;
                                    vertical-alignment: center;
                                    overflow: elide;
                                }
                            }
                            cta := TouchArea {
                                changed mouse-x => {
                                    // 单游标：悬停跟随
                                    if root.chart-cursor && !root.chart-dual {
                                        root.cursor-frac = self.mouse-x / self.width;
                                        root.chart-cursor-move();
                                    }
                                }
                                pointer-event(e) => {
                                    // 双游标：按下时抓住离鼠标最近的那条游标
                                    if root.chart-cursor && root.chart-dual && e.kind == PointerEventKind.down {
                                        root.drag-target =
                                            Math.abs(self.mouse-x / self.width - root.cursor-frac)
                                            <= Math.abs(self.mouse-x / self.width - root.cursor-frac2)
                                            ? 1 : 2;
                                        if root.drag-target == 2 {
                                            root.cursor-frac2 = self.mouse-x / self.width;
                                        } else {
                                            root.cursor-frac = self.mouse-x / self.width;
                                        }
                                        root.chart-cursor-move();
                                    }
                                }
                                moved => {
                                    // 双游标：拖动当前抓住的游标
                                    if root.chart-cursor && root.chart-dual && self.pressed {
                                        if root.drag-target == 2 {
                                            root.cursor-frac2 = self.mouse-x / self.width;
                                        } else {
                                            root.cursor-frac = self.mouse-x / self.width;
                                        }
                                        root.chart-cursor-move();
                                    }
                                }
                                scroll-event(e) => {
                                    root.chart-zoom(e.delta-y / 1px, self.mouse-x / self.width);
                                    accept
                                }
                            }
                            // 左上角信号名
                            Rectangle {
                                x: 4px; y: 3px;
                                width: nametxt.preferred-width + 8px; height: 16px;
                                background: Theme.panel.with-alpha(0.82); // 跟随主题(原硬编码白在深色下突兀)
                                border-radius: 3px;
                                nametxt := Text {
                                    text: ser.name; x: 4px;
                                    color: ser.clr; font-size: Theme.fs-sm; font-weight: 700;
                                    vertical-alignment: center;
                                }
                            }
                        }
                        Rectangle {
                            width: 86px;
                            background: Theme.zebra;
                            Rectangle { x: 0px; width: 1px; height: 100%; background: Theme.border; }
                            Rectangle { x: 5px; width: 2px; height: parent.height - 16px; y: 8px; background: ser.clr; }
                            Text { text: ser.axis-max; x: 12px; y: 6px; width: 50px; font-size: 10px; font-family: Theme.mono; color: ser.clr; overflow: elide; }
                            Text { text: ser.axis-mid; x: 12px; y: parent.height / 2 - 6px; width: 50px; font-size: 10px; font-family: Theme.mono; color: Theme.text-dim; overflow: elide; }
                            Text { text: ser.axis-min; x: 12px; y: parent.height - 18px; width: 50px; font-size: 10px; font-family: Theme.mono; color: ser.clr; overflow: elide; }
                            Text { text: ser.name; x: 58px; y: 8px; width: 24px; height: parent.height - 16px; transform-rotation: 90deg; font-size: 10px; color: ser.clr; overflow: elide; }
                        }
                    }
                }
            }

            Rectangle {
                height: 22px; background: xta.has-hover ? Theme.accent-soft : Theme.panel;
                Rectangle { width: 100%; height: 1px; y: 0; background: Theme.border; }
                xta := TouchArea {
                    mouse-cursor: ew-resize;
                    scroll-event(e) => {
                        root.chart-zoom(e.delta-y / 1px, self.mouse-x / self.width);
                        accept
                    }
                }
                // 5 个均匀时间刻度（绘图区从 0 到 width-86，最右 86px 是 Y 轴列）
                for lbl[idx] in root.chart-xlabels: Text {
                    text: lbl;
                    x: Math.max(0px, Math.min((parent.width - 86px) - 76px,
                        (parent.width - 86px) * (idx / 4.0) - 38px));
                    width: 76px; height: 100%;
                    vertical-alignment: center; horizontal-alignment: center;
                    font-size: 10px; font-family: Theme.mono; color: Theme.text-dim;
                }
                // 刻度竖线
                for t[idx] in root.chart-xlabels: Rectangle {
                    width: 1px; height: 4px; y: 0;
                    x: (parent.width - 86px) * (idx / 4.0);
                    background: Theme.border;
                }
            }
            Rectangle {
                height: 22px; background: Theme.panel2;
                Text { text: root.chart-cursor ? root.chart-cursor-readout : "";
                       x: 6px; vertical-alignment: center; font-size: 11px; font-family: Theme.mono; color: Theme.text; }
            }
        }
    }
}

export component TxWindow inherits Window {
    title: root.tx-page == 0 ? (I18n.en ? "Normal Send" : "普通发送") : (root.tx-page == 1 ? (I18n.en ? "DBC Send" : "DBC发送") : (root.tx-page == 2 ? (I18n.en ? "DBC Send (vary)" : "DBC发送(信号变化)") : (I18n.en ? "File Send" : "文件发送")));
    icon: @image-url("logo.svg");
    preferred-width: 1320px;
    preferred-height: 760px;
    // ensure the window opens wide/tall enough to show the whole form + list (no clipped controls)
    min-width: 1200px;
    min-height: 680px;
    background: Theme.bg;

    in property <[TxRow]> txs;
    in-out property <int> tx-page: 0;
    in-out property <string> tx-form-ch: "CAN1";
    in-out property <string> tx-form-id: "100";
    in-out property <string> tx-form-kind: "Std";
    in-out property <string> tx-form-fd: "No";    // No=CAN, Yes=CAN FD
    in-out property <string> tx-form-brs: "No";
    in-out property <string> tx-form-remote: "No"; // No=data frame, Yes=remote(RTR), classic CAN only
    in-out property <string> tx-form-dlc: "8";
    in-out property <string> tx-form-data: "00 11 22 33 44 55 66 77";
    in-out property <string> tx-form-period: "0";
    in-out property <string> tx-form-count: "1";    // 每次帧数(burst)
    in-out property <string> tx-form-repeat: "1";   // 发送次数
    in-out property <bool> tx-form-id-inc: false;   // ID 递增
    in-out property <bool> tx-form-data-inc: false; // 数据递增
    in-out property <string> tx-form-name: "";

    callback tx-add();
    callback tx-remove(int);
    callback tx-send-once(int);
    callback tx-toggle-periodic(int);
    callback tx-all(bool);
    callback tx-clear();
    callback tx-apply-all(int, string); // 把第 i 行的 "repeat"/"period" 套用到所有任务
    callback tx-speed-set(string);      // 设置发送速度倍率（字符串便于解析 0.5/1/2/5）
    in-out property <string> tx-speed: "1";
    callback tx-save-list();
    callback tx-load-list();
    callback tx-toggle-check(int);   // toggle a row's checkbox
    callback tx-select-all();        // check every row
    callback tx-invert();            // invert checks
    callback tx-move-up();           // move checked rows up
    callback tx-move-down();         // move checked rows down
    callback tx-remove-checked();    // delete checked rows
    // 文件发送
    in-out property <string> tx-file-path: "";
    in-out property <string> tx-file-id: "0";
    in-out property <string> tx-file-len: "8";
    in-out property <string> tx-file-interval: "0";
    in-out property <string> tx-file-repeat: "1";
    in property <string> tx-file-status: "请选择要发送的文件!";
    in property <float> tx-file-progress: 0.0;
    callback tx-file-pick();
    callback tx-file-send();
    callback tx-file-stop();
    callback tx-update(int, string, string);
    callback tx-form-add(string, string, string, string, string, string, string, string, string);
    callback tx-form-send(string, string, string, string, string, string, string, string, string);
    callback tx-form-dlc-edited(string);    // DLC typing -> grow data (never drop bytes mid-edit)
    callback tx-form-dlc-committed(string); // DLC committed (Enter) -> full pad/truncate to match
    callback tx-form-data-edited(string);   // data changed -> recompute DLC byte count
    in property <[string]> channel-names;
    in-out property <string> tx-dbc-ch: "CAN1";
    in property <[string]> tx-dbc-msgs;
    in property <[TxSigRow]> tx-dbc-sigs;
    in property <string> tx-sel-title: "未选择 DBC 发送任务";
    in-out property <int> tx-sel: -1;
    callback tx-dbc-add(int);
    callback tx-row-sel(int);
    callback tx-sig-edit(int, string);
    // 信号变化页：选中信号 + 信号信息 + 实际值变化配置
    in-out property <int> tx-sig-sel: -1;          // 选中的信号行(索引到 tx-dbc-sigs)
    in property <string> tx-sel-sig-name: "";
    in-out property <string> tx-sel-sig-phys: "0"; // 可编辑实际值
    in-out property <string> tx-sel-sig-raw: "0";  // 可编辑原始值
    in property <string> tx-sel-sig-unit: "";
    in property <string> tx-sel-sig-factor: "1";
    in property <string> tx-sel-sig-offset: "0";
    in property <string> tx-sel-sig-startbit: "0";
    in property <string> tx-sel-sig-length: "0";
    in property <string> tx-sel-sig-comment: "";
    in-out property <int> tx-vary-mode: 0;         // 0无变化 1等差 2等比 3正弦 4三角 5矩形 6随机 7序列
    in-out property <string> tx-vp1: "";
    in-out property <string> tx-vp2: "";
    in-out property <string> tx-vp3: "";
    in-out property <string> tx-vp4: "";
    in-out property <string> tx-vp5: "";
    in-out property <string> tx-vp6: "";
    in-out property <string> tx-vseq: "";          // 自定义序列文本
    callback tx-sig-row-sel(int);                  // 选中信号行
    callback tx-sig-edit-phys(string);             // 编辑选中信号实际值
    callback tx-sig-edit-raw(string);              // 编辑选中信号原始值
    callback tx-vary-apply(int, string, string, string, string, string, string, string); // mode,p1..p6,seq

    VerticalLayout {
        Rectangle {
            height: 38px; background: Theme.panel2;
            Rectangle { width: 100%; height: 1px; y: parent.height - 1px; background: Theme.border; }
            HorizontalLayout {
                padding-left: 6px; padding-top: 6px; spacing: 4px; alignment: start;
                TBtn { text: "+"; clicked => { root.tx-add(); } }
                TBtn { text: I18n.en ? "Normal" : "普通发送"; active: root.tx-page == 0; clicked => { root.tx-page = 0; } }
                TBtn { text: I18n.en ? "DBC Send" : "DBC发送"; active: root.tx-page == 1; clicked => { root.tx-page = 1; } }
                TBtn { text: I18n.en ? "Signal Vary" : "信号变化"; active: root.tx-page == 2; clicked => { root.tx-page = 2; } }
                TBtn { text: I18n.en ? "File Send" : "文件发送"; active: root.tx-page == 3; clicked => { root.tx-page = 3; } }
            }
        }

        if root.tx-page == 0: VerticalLayout {
            Rectangle {
                height: 250px;
                background: Theme.panel;
                border-width: 1px; border-color: Theme.border;
                Rectangle { x: 0; y: 0; width: 100%; height: 26px; background: Theme.header;
                    Rectangle { width: 100%; height: 1px; y: parent.height - 1px; background: Theme.border; }
                    Text { text: I18n.en ? "Frame Send" : "帧发送"; x: 8px; vertical-alignment: center; font-weight: 700; font-size: Theme.fs; color: Theme.text; }
                }
                GridLayout {
                    x: 12px; y: 34px; width: parent.width - 24px; height: 180px;
                    spacing: 6px;
                    Row {
                        Text { text: I18n.en ? "Channel:" : "通道:"; width: 90px; horizontal-alignment: left; font-weight: 700; font-size: Theme.fs; vertical-alignment: center; color: Theme.text; }
                        ComboBox { width: 150px; height: Theme.ctrl-h; model: root.channel-names; current-value <=> root.tx-form-ch; }
                        Text { text: I18n.en ? "Frame type:" : "帧类型:"; width: 90px; horizontal-alignment: left; font-weight: 700; font-size: Theme.fs; vertical-alignment: center; color: Theme.text; }
                        TBtn { boxed: true; text: root.tx-form-kind == "Ext" ? (I18n.en ? "Extended" : "扩展帧") : (I18n.en ? "Standard" : "标准帧"); active: root.tx-form-kind == "Ext"; clicked => { root.tx-form-kind = root.tx-form-kind == "Ext" ? "Std" : "Ext"; } }
                        Text { text: I18n.en ? "Protocol:" : "类型:"; width: 90px; horizontal-alignment: left; font-weight: 700; font-size: Theme.fs; vertical-alignment: center; color: Theme.text; }
                        TBtn { boxed: true; text: root.tx-form-fd == "Yes" ? "CAN FD" : "CAN"; active: root.tx-form-fd == "Yes"; clicked => {
                            root.tx-form-fd = root.tx-form-fd == "Yes" ? "No" : "Yes";
                            if (root.tx-form-fd == "Yes") { root.tx-form-remote = "No"; } else { root.tx-form-brs = "No"; }
                        } }
                        Text { text: I18n.en ? "Frame fmt:" : "帧格式:"; width: 90px; horizontal-alignment: left; font-weight: 700; font-size: Theme.fs; vertical-alignment: center; color: Theme.text; }
                        TBtn { boxed: true; btn-enabled: root.tx-form-fd != "Yes"; text: root.tx-form-remote == "Yes" ? (I18n.en ? "Remote" : "远程帧") : (I18n.en ? "Data" : "数据帧"); active: root.tx-form-remote == "Yes"; clicked => { root.tx-form-remote = root.tx-form-remote == "Yes" ? "No" : "Yes"; } }
                        TBtn { boxed: true; btn-enabled: root.tx-form-fd == "Yes"; text: root.tx-form-brs == "Yes" ? "BRS" : "No BRS"; active: root.tx-form-brs == "Yes"; clicked => { root.tx-form-brs = root.tx-form-brs == "Yes" ? "No" : "Yes"; } }
                    }
                    Row {
                        Text { text: I18n.en ? "ID:0x" : "帧ID:0x"; width: 90px; horizontal-alignment: left; font-weight: 700; font-size: Theme.fs; vertical-alignment: center; color: Theme.text; }
                        LineEdit { text: root.tx-form-id; width: 110px; height: Theme.ctrl-h; accepted(v) => { root.tx-form-id = v; } }
                        Text { text: I18n.en ? "Data len:" : "数据长度:"; width: 90px; horizontal-alignment: left; font-weight: 700; font-size: Theme.fs; vertical-alignment: center; color: Theme.text; }
                        LineEdit { text: root.tx-form-dlc; width: 64px; height: Theme.ctrl-h; edited(v) => { root.tx-form-dlc-edited(v); } accepted(v) => { root.tx-form-dlc-committed(v); } }
                        Text { text: I18n.en ? "Data:0x" : "数据:0x"; width: 90px; horizontal-alignment: left; font-weight: 700; font-size: Theme.fs; vertical-alignment: center; color: Theme.text; }
                        LineEdit { text: root.tx-form-data; width: 240px; height: Theme.ctrl-h; edited(v) => { root.tx-form-data-edited(v); } accepted(v) => { root.tx-form-data-edited(v); } }
                    }
                    Row {
                        Text { text: I18n.en ? "Frames/burst:" : "每次帧数:"; width: 90px; horizontal-alignment: left; font-weight: 700; font-size: Theme.fs; vertical-alignment: center; color: Theme.text; }
                        LineEdit { text: root.tx-form-count; width: 110px; height: Theme.ctrl-h; accepted(v) => { root.tx-form-count = v; } edited(v) => { root.tx-form-count = v; } }
                        Text { text: I18n.en ? "Repeat:" : "发送次数:"; width: 90px; horizontal-alignment: left; font-weight: 700; font-size: Theme.fs; vertical-alignment: center; color: Theme.text; }
                        LineEdit { text: root.tx-form-repeat; width: 64px; height: Theme.ctrl-h; accepted(v) => { root.tx-form-repeat = v; } edited(v) => { root.tx-form-repeat = v; } }
                        Text { text: I18n.en ? "Interval(ms):" : "间隔(ms):"; width: 90px; horizontal-alignment: left; font-weight: 700; font-size: Theme.fs; vertical-alignment: center; color: Theme.text; }
                        LineEdit { text: root.tx-form-period; width: 90px; height: Theme.ctrl-h; accepted(v) => { root.tx-form-period = v; } }
                    }
                    Row {
                        Text { text: I18n.en ? "Name(opt):" : "名称(可选):"; width: 90px; horizontal-alignment: left; font-weight: 700; font-size: Theme.fs; vertical-alignment: center; color: Theme.text; }
                        LineEdit { text: root.tx-form-name; width: 180px; height: Theme.ctrl-h; accepted(v) => { root.tx-form-name = v; } }
                        CheckBox { text: I18n.en ? "ID++" : "ID递增"; checked: root.tx-form-id-inc; toggled => { root.tx-form-id-inc = self.checked; } }
                        CheckBox { text: I18n.en ? "Data++" : "数据递增"; checked: root.tx-form-data-inc; toggled => { root.tx-form-data-inc = self.checked; } }
                        Rectangle { horizontal-stretch: 1; }
                        TBtn { boxed: true; text: I18n.en ? "Add to list" : "添加到列表"; clicked => { root.tx-form-add(root.tx-form-ch, root.tx-form-id, root.tx-form-kind, root.tx-form-fd, root.tx-form-brs, root.tx-form-dlc, root.tx-form-data, root.tx-form-period, root.tx-form-name); } }
                        TBtn { primary: true; text: I18n.en ? "Send Now" : "立即发送"; clicked => { root.tx-form-send(root.tx-form-ch, root.tx-form-id, root.tx-form-kind, root.tx-form-fd, root.tx-form-brs, root.tx-form-dlc, root.tx-form-data, root.tx-form-period, root.tx-form-name); } }
                    }
                }
            }

            Rectangle {
                vertical-stretch: 1;
                background: Theme.panel;
                border-width: 1px; border-color: Theme.border;
                Rectangle { x: 0; y: 0; width: 100%; height: 26px; background: Theme.header;
                    Rectangle { width: 100%; height: 1px; y: parent.height - 1px; background: Theme.border; }
                    Text { text: I18n.en ? "List Send" : "列表发送"; x: 8px; vertical-alignment: center; font-weight: 700; font-size: Theme.fs; color: Theme.text; }
                }
                ScrollView {
                    x: 12px; y: 34px; width: parent.width - 24px; height: parent.height - 88px;
                    viewport-width: 1152px;
                    VerticalLayout {
                        width: 1152px;
                        Rectangle {
                            height: 28px; background: Theme.header;
                            HorizontalLayout {
                                HCell { text: I18n.en ? "Sel" : "选"; w: 32px; }
                                HCell { text: I18n.en ? "No." : "序号"; w: 46px; }
                                HCell { text: I18n.en ? "Status" : "状态"; w: 58px; }
                                HCell { text: "ID(0x)"; w: 86px; }
                                HCell { text: I18n.en ? "Proto" : "协议"; w: 64px; }
                                HCell { text: I18n.en ? "Len" : "长度"; w: 56px; }
                                HCell { text: I18n.en ? "Name" : "名称"; w: 120px; }
                                HCell { text: I18n.en ? "Data" : "数据"; w: 250px; }
                                HCell { text: I18n.en ? "Type" : "帧类型"; w: 76px; }
                                HCell { text: I18n.en ? "Tx Count" : "发送次数"; w: 80px; }
                                HCell { text: I18n.en ? "Interval(ms)" : "间隔(ms)"; w: 86px; }
                                HCell { text: I18n.en ? "Sent" : "已发"; w: 58px; }
                                HCell { text: I18n.en ? "Action" : "操作"; w: 140px; }
                            }
                        }
                        ListView {
                            for t[i] in root.txs: Rectangle {
                                height: 32px;
                                background: Math.mod(i, 2) == 0 ? Theme.panel : Theme.zebra; // 原 white 深色下突兀
                                HorizontalLayout {
                                    padding-top: 3px; padding-bottom: 3px;
                                    Rectangle { width: 32px; CheckBox { checked: t.checked; toggled => { root.tx-toggle-check(i); } } }
                                    Cell { text: i + 1; w: 46px; mono: true; align: right; }
                                    Cell { text: t.status; w: 58px; txt-clr: t.running ? Theme.ok : Theme.text-dim; }
                                    LineEdit { text: t.id; width: 86px; height: 26px; accepted(v) => { root.tx-update(i, "id", v); } }
                                    TBtn { h: 26px; boxed: true; text: t.fd == "Yes" ? "CAN FD" : "CAN"; active: t.fd == "Yes"; clicked => { root.tx-update(i, "fd", t.fd == "Yes" ? "No" : "Yes"); } }
                                    LineEdit { text: t.dlc; width: 56px; height: 26px; accepted(v) => { root.tx-update(i, "dlc", v); } }
                                    LineEdit { text: t.name; width: 120px; height: 26px; accepted(v) => { root.tx-update(i, "name", v); } }
                                    LineEdit { text: t.data; width: 250px; height: 26px; accepted(v) => { root.tx-update(i, "data", v); } }
                                    TBtn { h: 26px; boxed: true; text: t.kind == "Ext" ? (I18n.en ? "Extended" : "扩展帧") : (I18n.en ? "Standard" : "标准帧"); active: t.kind == "Ext"; clicked => { root.tx-update(i, "type", t.kind == "Ext" ? "Std" : "Ext"); } }
                                    Cell { text: "1"; w: 80px; mono: true; align: right; }
                                    LineEdit { text: t.period; width: 86px; height: 26px; accepted(v) => { root.tx-update(i, "period", v); } }
                                    Cell { text: t.sent; w: 58px; mono: true; align: right; }
                                    Rectangle {
                                        width: 140px;
                                        HorizontalLayout {
                                            spacing: 2px; padding: 2px;
                                            TBtn { h: 26px; boxed: true; text: I18n.en ? "Send" : "发"; clicked => { root.tx-send-once(i); } }
                                            TBtn { h: 26px; boxed: true; text: t.running ? (I18n.en ? "Stop" : "停") : (I18n.en ? "Cyclic" : "周期"); active: t.running; clicked => { root.tx-toggle-periodic(i); } }
                                            TBtn { h: 26px; boxed: true; text: I18n.en ? "Del" : "删"; clicked => { root.tx-remove(i); } }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
                Rectangle {
                    height: 42px; y: parent.height - self.height;
                    background: Theme.panel2;
                    HorizontalLayout {
                        padding: 5px; spacing: 5px;
                        TBtn { boxed: true; text: I18n.en ? "Select All" : "全选"; clicked => { root.tx-select-all(); } }
                        TBtn { boxed: true; text: I18n.en ? "Invert" : "反选"; clicked => { root.tx-invert(); } }
                        TBtn { boxed: true; text: I18n.en ? "Up" : "上移"; clicked => { root.tx-move-up(); } }
                        TBtn { boxed: true; text: I18n.en ? "Down" : "下移"; clicked => { root.tx-move-down(); } }
                        TBtn { boxed: true; text: I18n.en ? "Delete" : "删除"; clicked => { root.tx-remove-checked(); } }
                        TBtn { boxed: true; text: I18n.en ? "Clear" : "清空"; clicked => { root.tx-clear(); } }
                        Rectangle { width: 1px; background: Theme.border; }
                        TBtn { boxed: true; text: I18n.en ? "Save List" : "保存列表"; clicked => { root.tx-save-list(); } }
                        TBtn { boxed: true; text: I18n.en ? "Load List" : "加载列表"; clicked => { root.tx-load-list(); } }
                        Rectangle { horizontal-stretch: 1; }
                        TBtn { boxed: true; text: I18n.en ? "Start All" : "启动全部"; clicked => { root.tx-all(true); } }
                        TBtn { boxed: true; text: I18n.en ? "Stop All" : "停止全部"; clicked => { root.tx-all(false); } }
                    }
                }
            }
        }

        if root.tx-page == 1: Rectangle { width: 100%; HorizontalLayout { width: 100%; height: 100%;
            // 左：DBC 报文选择（双击添加）
            Rectangle {
                width: 300px; background: Theme.panel; border-width: 1px; border-color: Theme.border;
                VerticalLayout {
                    Rectangle { height: 38px; background: Theme.panel2;
                        HorizontalLayout { padding: 4px; spacing: 6px;
                            Text { text: I18n.en ? "Target Ch" : "目标通道"; vertical-alignment: center; font-size: Theme.fs; }
                            ComboBox { width: 120px; model: root.channel-names; current-value <=> root.tx-dbc-ch; }
                        }
                    }
                    ListView {
                        for m[i] in root.tx-dbc-msgs: Rectangle {
                            height: Theme.big ? 28px : 24px;
                            background: mta.has-hover ? Theme.accent-soft : (Math.mod(i, 2) == 0 ? Theme.panel : Theme.zebra);
                            mta := TouchArea { clicked => { root.tx-dbc-add(i); } }
                            HorizontalLayout {
                                padding-left: 8px; spacing: 5px;
                                Rectangle { width: 16px; Icon { name: "send"; clr: Theme.accent; width: 13px; height: 13px; x: (parent.width - self.width)/2; y: (parent.height - self.height)/2; } }
                                Text { text: m; color: Theme.text; vertical-alignment: center; font-size: Theme.fs; overflow: elide; }
                            }
                        }
                    }
                    Rectangle { height: 24px; background: Theme.panel2;
                        Text { text: I18n.en ? "Tip: empty when no DBC loaded" : "提示：未加载 DBC 时此处为空"; x: 8px; vertical-alignment: center; font-size: Theme.fs-sm; color: Theme.text-dim; }
                    }
                }
            }
            // 右：发送列表 + 信号编辑
            VerticalLayout {
                horizontal-stretch: 1;
                padding: 6px;
                spacing: 6px;
                Rectangle { height: 26px; background: Theme.header; border-radius: 4px;
                    Text { text: root.tx-sel-title; x: 8px; vertical-alignment: center; font-weight: 700; font-size: Theme.fs; color: Theme.text; }
                }
                // 发送任务列表（单击选中以编辑信号）
                Rectangle { height: 24px; background: Theme.panel2;
                    HorizontalLayout {
                        HCell { text: I18n.en ? "Name" : "名称"; w: 130px; } HCell { text: "ID"; w: 80px; } HCell { text: "DLC"; w: 46px; }
                        HCell { text: I18n.en ? "Data" : "数据"; w: 230px; } HCell { text: I18n.en ? "Count" : "次数"; w: 58px; } HCell { text: I18n.en ? "Interval" : "间隔ms"; w: 70px; } HCell { text: I18n.en ? "Status" : "状态"; w: 56px; } HCell { text: I18n.en ? "Action" : "操作"; w: 150px; }
                        Rectangle { horizontal-stretch: 1; background: Theme.panel2; }
                    }
                }
                Rectangle { height: 200px; background: Theme.panel; border-width: 1px; border-color: Theme.border;
                    ListView {
                        for t[i] in root.txs: Rectangle {
                            height: Theme.big ? 30px : 26px;
                            background: i == root.tx-sel ? Theme.sel : (tta.has-hover ? Theme.accent-soft : (Math.mod(i, 2) == 0 ? Theme.panel : Theme.zebra));
                            HorizontalLayout {
                                // 行选中只包左侧只读单元格（按内容收缩，行尾弹性占位吸收余量，绝不覆盖右侧可编辑框/按钮）
                                tta := TouchArea { horizontal-stretch: 0; clicked => { root.tx-row-sel(i); }
                                    HorizontalLayout {
                                        Cell { text: t.name; w: 130px; }
                                        Cell { text: t.id; w: 80px; mono: true; }
                                        Cell { text: t.dlc; w: 46px; align: right; }
                                        Cell { text: t.data; w: 230px; mono: true; }
                                    }
                                }
                                Rectangle { width: 58px;
                                    LineEdit { text: t.count; width: 52px; height: Theme.ctrl-h - 6px; x: (parent.width - self.width)/2; y: (parent.height - self.height)/2; horizontal-alignment: right;
                                               accepted(v) => { root.tx-update(i, "repeat", v); } }
                                }
                                Rectangle { width: 70px;
                                    LineEdit { text: t.period; width: 62px; height: Theme.ctrl-h - 6px; x: (parent.width - self.width)/2; y: (parent.height - self.height)/2; horizontal-alignment: right;
                                               accepted(v) => { root.tx-update(i, "period", v); } }
                                }
                                Cell { text: t.status; w: 56px; txt-clr: t.running ? Theme.ok : Theme.text-dim; }
                                Rectangle { width: 150px;
                                    HorizontalLayout { spacing: 2px; padding: 2px; alignment: center;
                                        TBtn { text: I18n.en ? "Send" : "发"; h: parent.height - 4px; clicked => { root.tx-send-once(i); } }
                                        TBtn { text: t.running ? (I18n.en ? "Stop" : "停") : (I18n.en ? "Cyclic" : "周期"); h: parent.height - 4px; active: t.running; clicked => { root.tx-toggle-periodic(i); } }
                                        TBtn { text: I18n.en ? "Del" : "删"; h: parent.height - 4px; clicked => { root.tx-remove(i); } }
                                    }
                                }
                                Rectangle { horizontal-stretch: 1; }
                            }
                        }
                    }
                }
                // 信号编辑（改实际值自动编码 Data）
                Rectangle { height: 24px; background: Theme.panel2;
                    Text { text: I18n.en ? "Signal edit (edit Phys → auto Raw/Data)" : "信号编辑 (改 实际值 自动算 原始值/Data)"; x: 8px; vertical-alignment: center; font-size: Theme.fs-sm; color: Theme.text-dim; }
                }
                Rectangle { height: 24px; background: Theme.panel2;
                    HorizontalLayout {
                        HCell { text: I18n.en ? "Signal" : "信号"; w: 150px; } HCell { text: I18n.en ? "Phys" : "实际值"; w: 90px; } HCell { text: I18n.en ? "Raw" : "原始值"; w: 80px; }
                        HCell { text: I18n.en ? "Unit" : "单位"; w: 54px; } HCell { text: I18n.en ? "Factor" : "比例"; w: 60px; } HCell { text: I18n.en ? "Offset" : "偏移"; w: 60px; }
                        HCell { text: I18n.en ? "StartBit" : "起始位"; w: 56px; } HCell { text: I18n.en ? "Bits" : "位宽"; w: 50px; }
                        Rectangle { horizontal-stretch: 1; background: Theme.panel2; }
                    }
                }
                ListView {
                    for s[i] in root.tx-dbc-sigs: sigrow := Rectangle {
                        height: Theme.big ? 30px : 26px;
                        background: Math.mod(i, 2) == 0 ? Theme.panel : Theme.zebra;
                        // 实时跟随输入框，用于即时换算原始值
                        property <float> pv: s.phys.to-float();
                        HorizontalLayout {
                            Cell { text: s.signal; w: 150px; }
                            Rectangle { width: 90px;
                                LineEdit { text: s.phys; width: 86px; height: Theme.ctrl-h - 6px; y: (parent.height - self.height)/2;
                                           edited(v) => { sigrow.pv = v.to-float(); }
                                           accepted(v) => { root.tx-sig-edit(i, v); } }
                            }
                            Cell { text: s.factor-num == 0 ? s.raw : round((sigrow.pv - s.offset-num) / s.factor-num); w: 80px; mono: true; align: right; }
                            Cell { text: s.unit; w: 54px; }
                            Cell { text: s.factor; w: 60px; mono: true; align: right; }
                            Cell { text: s.offset; w: 60px; mono: true; align: right; }
                            Cell { text: s.startbit; w: 56px; align: right; }
                            Cell { text: s.length; w: 50px; align: right; }
                        }
                    }
                }
                // 底部：列表发送/停止全部 + 应用到全部 + 速度倍率 + 清空
                Rectangle { height: 34px; vertical-stretch: 0;
                    HorizontalLayout { spacing: 6px; padding: 2px; alignment: start;
                        TBtn { boxed: true; primary: true; text: I18n.en ? "Send List" : "列表发送"; clicked => { root.tx-all(true); } }
                        TBtn { boxed: true; text: I18n.en ? "Stop List" : "列表停止"; clicked => { root.tx-all(false); } }
                        Rectangle { width: 10px; }
                        TBtn { boxed: true; text: I18n.en ? "Count→All" : "次数→全部"; clicked => { root.tx-apply-all(root.tx-sel, "repeat"); } }
                        TBtn { boxed: true; text: I18n.en ? "Interval→All" : "间隔→全部"; clicked => { root.tx-apply-all(root.tx-sel, "period"); } }
                        Rectangle { width: 10px; }
                        Text { text: I18n.en ? "Speed" : "速度"; vertical-alignment: center; font-size: Theme.fs; color: Theme.text; }
                        TBtn { boxed: true; text: "0.5×"; active: root.tx-speed == "0.5"; clicked => { root.tx-speed-set("0.5"); } }
                        TBtn { boxed: true; text: "1×"; active: root.tx-speed == "1"; clicked => { root.tx-speed-set("1"); } }
                        TBtn { boxed: true; text: "2×"; active: root.tx-speed == "2"; clicked => { root.tx-speed-set("2"); } }
                        TBtn { boxed: true; text: "5×"; active: root.tx-speed == "5"; clicked => { root.tx-speed-set("5"); } }
                        Rectangle { horizontal-stretch: 1; }
                        TBtn { boxed: true; text: I18n.en ? "Clear" : "清空"; clicked => { root.tx-clear(); } }
                    }
                }
            }
        } }

        if root.tx-page == 2: Rectangle { width: 100%; HorizontalLayout { width: 100%; height: 100%;
            // 左：DBC 报文选择
            Rectangle {
                width: 300px; background: Theme.panel; border-width: 1px; border-color: Theme.border;
                VerticalLayout {
                    Rectangle { height: 38px; background: Theme.panel2;
                        HorizontalLayout { padding: 4px; spacing: 6px;
                            Text { text: I18n.en ? "Target Ch" : "目标通道"; vertical-alignment: center; font-size: Theme.fs; }
                            ComboBox { width: 110px; model: root.channel-names; current-value <=> root.tx-dbc-ch; }
                        }
                    }
                    ListView {
                        for m[i] in root.tx-dbc-msgs: Rectangle {
                            height: Theme.big ? 28px : 24px;
                            background: cmta.has-hover ? Theme.accent-soft : (Math.mod(i, 2) == 0 ? Theme.panel : Theme.zebra);
                            cmta := TouchArea { clicked => { root.tx-dbc-add(i); } }
                            Text { text: m; x: 8px; vertical-alignment: center; font-size: Theme.fs; color: Theme.text; overflow: elide; }
                        }
                    }
                }
            }
            VerticalLayout {
                horizontal-stretch: 1;
                padding: 6px;
                spacing: 6px;
                Rectangle { height: 26px; background: Theme.header; border-radius: 4px;
                    Text { text: (root.tx-sel-title == "" ? (I18n.en ? "DBC send tasks (double-click a message on the left to add)" : "DBC 发送任务（双击左侧报文添加）") : root.tx-sel-title); x: 8px; vertical-alignment: center; font-weight: 700; font-size: Theme.fs; color: Theme.text; overflow: elide; } }
                // 任务列表
                Rectangle { height: 24px; background: Theme.panel2;
                    HorizontalLayout {
                        HCell { text: I18n.en ? "Name" : "名称"; w: 130px; } HCell { text: "ID"; w: 80px; } HCell { text: I18n.en ? "Data" : "数据"; w: 230px; }
                        HCell { text: I18n.en ? "Sent" : "已发"; w: 60px; } HCell { text: I18n.en ? "Status" : "状态"; w: 60px; } HCell { text: I18n.en ? "Action" : "操作"; w: 150px; }
                        Rectangle { horizontal-stretch: 1; background: Theme.panel2; }
                    } }
                Rectangle { vertical-stretch: 1; min-height: 0px; preferred-height: 0px; background: Theme.panel; border-width: 1px; border-color: Theme.border;
                    ListView {
                        for t[i] in root.txs: Rectangle {
                            height: 30px;
                            background: i == root.tx-sel ? Theme.sel : (ctta.has-hover ? Theme.accent-soft : (Math.mod(i, 2) == 0 ? Theme.panel : Theme.zebra));
                            ctta := TouchArea { clicked => { root.tx-row-sel(i); } }
                            HorizontalLayout {
                                padding-top: 3px; padding-bottom: 3px;
                                Cell { text: t.name; w: 130px; }
                                Cell { text: t.id; w: 80px; mono: true; }
                                Cell { text: t.data; w: 230px; mono: true; }
                                Cell { text: t.sent; w: 60px; mono: true; align: right; }
                                Cell { text: t.status; w: 60px; txt-clr: t.running ? Theme.ok : Theme.text-dim; }
                                Rectangle { width: 150px;
                                    HorizontalLayout { spacing: 2px; padding: 2px;
                                        TBtn { h: 24px; boxed: true; text: I18n.en ? "Send" : "发"; clicked => { root.tx-send-once(i); } }
                                        TBtn { h: 24px; boxed: true; text: t.running ? (I18n.en ? "Stop" : "停止") : (I18n.en ? "Start vary" : "开始变化"); active: t.running; clicked => { root.tx-toggle-periodic(i); } }
                                        TBtn { h: 24px; boxed: true; text: I18n.en ? "Del" : "删"; clicked => { root.tx-remove(i); } }
                                    }
                                }
                            }
                        }
                    }
                }
                // 信号表（点选一行 → 下方编辑实际值/原始值与变化方式）
                Rectangle { height: 24px; background: Theme.panel2;
                    HorizontalLayout {
                        HCell { text: I18n.en ? "Signal" : "信号"; w: 200px; }
                        HCell { text: I18n.en ? "Actual" : "实际值"; w: 100px; }
                        HCell { text: I18n.en ? "Raw" : "原始值"; w: 90px; }
                        HCell { text: I18n.en ? "Unit" : "单位"; w: 60px; }
                        HCell { text: I18n.en ? "Start" : "起始位"; w: 64px; }
                        HCell { text: I18n.en ? "Len" : "位宽"; w: 56px; }
                        Rectangle { horizontal-stretch: 1; background: Theme.panel2; }
                    } }
                sigtbl := Rectangle { vertical-stretch: 1; min-height: 0px; preferred-height: 0px; background: Theme.panel; border-width: 1px; border-color: Theme.border;
                    ListView {
                        for s[i] in root.tx-dbc-sigs: Rectangle {
                            height: 24px;
                            background: i == root.tx-sig-sel ? Theme.sel : (sgta.has-hover ? Theme.accent-soft : (Math.mod(i, 2) == 0 ? Theme.panel : Theme.zebra));
                            sgta := TouchArea { clicked => { root.tx-sig-row-sel(i); } }
                            HorizontalLayout {
                                Cell { text: s.signal; w: 200px; }
                                Cell { text: s.phys; w: 100px; mono: true; align: right; }
                                Cell { text: s.raw; w: 90px; mono: true; align: right; }
                                Cell { text: s.unit; w: 60px; }
                                Cell { text: s.startbit; w: 64px; mono: true; align: right; }
                                Cell { text: s.length; w: 56px; mono: true; align: right; }
                            }
                        }
                    }
                }
                // 下方：信号信息 + 信号实际值变化
                // preferred/min 高度钉为 0，使本区与上方两个列表区一样不上抛内容高度，
                // 三个 vertical-stretch 区才能被严格三等分（否则面板内表单会把本区撑高）。
                Rectangle { vertical-stretch: 1; min-height: 0px; preferred-height: 0px;
                    HorizontalLayout { spacing: 8px;
                        // 信号信息（horizontal-stretch：两块等分填满右侧区，右缘与上方列表对齐；
                        // 不引用 root.width，故无绑定环——避免对话框 relayout 时撞环卡死）。
                        Rectangle { horizontal-stretch: 1; background: Theme.panel; border-width: 1px; border-color: Theme.border;
                            VerticalLayout { padding: 8px; spacing: 6px; alignment: start;
                                Text { text: I18n.en ? "Signal Info" : "信号信息"; font-weight: 700; font-size: Theme.fs; color: Theme.text; }
                                HorizontalLayout { spacing: 6px;
                                    Text { text: I18n.en ? "Signal" : "信号名"; width: 64px; vertical-alignment: center; font-size: Theme.fs; }
                                    Text { text: root.tx-sel-sig-name == "" ? "—" : root.tx-sel-sig-name; vertical-alignment: center; font-size: Theme.fs; color: Theme.accent; overflow: elide; horizontal-stretch: 1; }
                                }
                                HorizontalLayout { spacing: 6px;
                                    Text { text: I18n.en ? "Actual" : "实际值"; width: 64px; vertical-alignment: center; font-size: Theme.fs; }
                                    LineEdit { width: 120px; height: Theme.ctrl-h; text: root.tx-sel-sig-phys; edited(v) => { root.tx-sig-edit-phys(v); } }
                                    Text { text: I18n.en ? "Raw" : "原始值"; width: 56px; vertical-alignment: center; font-size: Theme.fs; }
                                    LineEdit { width: 120px; height: Theme.ctrl-h; text: root.tx-sel-sig-raw; edited(v) => { root.tx-sig-edit-raw(v); } }
                                }
                                HorizontalLayout { spacing: 6px;
                                    Text { text: I18n.en ? "Unit" : "单位"; width: 64px; vertical-alignment: center; font-size: Theme.fs; }
                                    Text { text: root.tx-sel-sig-unit; vertical-alignment: center; font-size: Theme.fs; color: Theme.text-dim; width: 120px; }
                                    Text { text: I18n.en ? "Scale" : "比例"; width: 56px; vertical-alignment: center; font-size: Theme.fs; }
                                    Text { text: root.tx-sel-sig-factor; vertical-alignment: center; font-size: Theme.fs; color: Theme.text-dim; }
                                }
                                HorizontalLayout { spacing: 6px;
                                    Text { text: I18n.en ? "Offset" : "偏移"; width: 64px; vertical-alignment: center; font-size: Theme.fs; }
                                    Text { text: root.tx-sel-sig-offset; vertical-alignment: center; font-size: Theme.fs; color: Theme.text-dim; width: 120px; }
                                    Text { text: I18n.en ? "Start/Len" : "起始/位宽"; width: 56px; vertical-alignment: center; font-size: Theme.fs; }
                                    Text { text: root.tx-sel-sig-startbit + " / " + root.tx-sel-sig-length; vertical-alignment: center; font-size: Theme.fs; color: Theme.text-dim; }
                                }
                                Text { text: root.tx-sel-sig-comment; font-size: Theme.fs-sm; color: Theme.text-dim; wrap: word-wrap; }
                            }
                        }
                        // 信号实际值变化
                        varybox := Rectangle { horizontal-stretch: 1; background: Theme.panel; border-width: 1px; border-color: Theme.border;
                            property <int> vpc: root.tx-vary-mode == 1 ? 3 : root.tx-vary-mode == 2 ? 4 : root.tx-vary-mode == 3 ? 6 : root.tx-vary-mode == 4 ? 6 : root.tx-vary-mode == 5 ? 4 : root.tx-vary-mode == 6 ? 2 : 0;
                            VerticalLayout { padding: 8px; spacing: 6px; alignment: start;
                                Text { text: I18n.en ? "Signal value variation" : "信号实际值变化"; font-weight: 700; font-size: Theme.fs; color: Theme.text; }
                                HorizontalLayout { spacing: 6px;
                                    Text { text: I18n.en ? "Mode" : "变化方式"; width: 64px; vertical-alignment: center; font-size: Theme.fs; }
                                    ComboBox { horizontal-stretch: 1; current-index <=> root.tx-vary-mode;
                                        model: I18n.en
                                            ? ["None", "Arithmetic", "Geometric", "Sine", "Triangle", "Rect", "Random", "Sequence"]
                                            : ["无变化", "等差循环", "等比循环", "正弦", "三角波", "矩形波", "随机", "自定义序列"]; }
                                }
                                // 参数说明（按变化方式给出参数顺序）
                                Text { font-size: Theme.fs-sm; color: Theme.text-dim; wrap: word-wrap;
                                    text: root.tx-vary-mode == 1 ? (I18n.en ? "Params: diff, lo, hi (step from lo up to hi then loop; clamp to bit width)" : "参数: 差值, 下限, 上限（由下限递增至上限循环，超范围按位宽截断）")
                                        : root.tx-vary-mode == 2 ? (I18n.en ? "Params: init, ratio, lo, hi (geometric loop; clamp to bit width)" : "参数: 初值, 比值, 下限, 上限（等比循环，超范围按位宽截断）")
                                        : root.tx-vary-mode == 3 ? (I18n.en ? "Params: amp, omega, phase, offset, lo, hi (offset+amp·sin(ω·n+φ), saturated)" : "参数: 振幅, 角速度, 初相, 偏移, 下限, 上限（offset+amp·sin(ω·n+φ)，饱和到上下限）")
                                        : root.tx-vary-mode == 4 ? (I18n.en ? "Params: period, amp, h-offset, v-offset, lo, hi (triangle, saturated)" : "参数: 周期, 幅值, 横偏, 纵偏, 下限, 上限（三角波，饱和到上下限）")
                                        : root.tx-vary-mode == 5 ? (I18n.en ? "Params: period, duty(0~1), high, low (rectangle wave)" : "参数: 周期, 占空比(0~1), 高值, 低值（矩形波）")
                                        : root.tx-vary-mode == 6 ? (I18n.en ? "Params: min, max (random in range)" : "参数: 最小, 最大（范围内随机）")
                                        : root.tx-vary-mode == 7 ? (I18n.en ? "Enter a comma-separated value sequence below; sent in a loop" : "在下方输入用逗号分隔的数值序列，循环发送")
                                        : (I18n.en ? "No variation: send the actual value edited above" : "无变化：发送上方编辑的实际值"); }
                                if root.tx-vary-mode != 0 && root.tx-vary-mode != 7: HorizontalLayout { spacing: 6px;
                                    if varybox.vpc >= 1: LineEdit { width: 80px; height: Theme.ctrl-h; placeholder-text: "1"; text: root.tx-vp1; edited(v) => { root.tx-vp1 = v; } }
                                    if varybox.vpc >= 2: LineEdit { width: 80px; height: Theme.ctrl-h; placeholder-text: "2"; text: root.tx-vp2; edited(v) => { root.tx-vp2 = v; } }
                                    if varybox.vpc >= 3: LineEdit { width: 80px; height: Theme.ctrl-h; placeholder-text: "3"; text: root.tx-vp3; edited(v) => { root.tx-vp3 = v; } }
                                }
                                if root.tx-vary-mode != 0 && root.tx-vary-mode != 7 && varybox.vpc >= 4: HorizontalLayout { spacing: 6px;
                                    LineEdit { width: 80px; height: Theme.ctrl-h; placeholder-text: "4"; text: root.tx-vp4; edited(v) => { root.tx-vp4 = v; } }
                                    if varybox.vpc >= 5: LineEdit { width: 80px; height: Theme.ctrl-h; placeholder-text: "5"; text: root.tx-vp5; edited(v) => { root.tx-vp5 = v; } }
                                    if varybox.vpc >= 6: LineEdit { width: 80px; height: Theme.ctrl-h; placeholder-text: "6"; text: root.tx-vp6; edited(v) => { root.tx-vp6 = v; } }
                                }
                                if root.tx-vary-mode == 7: LineEdit { height: Theme.ctrl-h; placeholder-text: I18n.en ? "1, 2, 3.5, ..." : "如 1, 2, 3.5, ..."; text: root.tx-vseq; edited(v) => { root.tx-vseq = v; } }
                                TBtn { primary: true; text: I18n.en ? "Apply variation" : "应用变化"; clicked => { root.tx-vary-apply(root.tx-vary-mode, root.tx-vp1, root.tx-vp2, root.tx-vp3, root.tx-vp4, root.tx-vp5, root.tx-vp6, root.tx-vseq); } }
                            }
                        }
                    }
                }
            }
        } }

        if root.tx-page == 3: Rectangle { width: 100%; HorizontalLayout { width: 100%; height: 100%;
            VerticalLayout {
                width: 560px;
                padding: 6px;
                spacing: 6px;
                Rectangle { background: Theme.panel; border-width: 1px; border-color: Theme.border; vertical-stretch: 0;
                    VerticalLayout {
                        Rectangle { height: 26px; background: Theme.header;
                            Rectangle { width: 100%; height: 1px; y: parent.height - 1px; background: Theme.border; }
                            Text { text: I18n.en ? "Send params" : "发送参数"; x: 8px; vertical-alignment: center; font-weight: 700; font-size: Theme.fs; color: Theme.text; }
                        }
                        GridLayout {
                            padding: 12px; spacing: 6px;
                            Row {
                                Text { text: I18n.en ? "File type:" : "文件类型:"; width: 90px; horizontal-alignment: left; font-weight: 700; font-size: Theme.fs; vertical-alignment: center; color: Theme.text; }
                                Text { text: I18n.en ? "Normal file" : "普通文件"; width: 140px; font-size: Theme.fs; vertical-alignment: center; color: Theme.text; }
                                Text { text: I18n.en ? "Send mode:" : "发送模式:"; width: 90px; horizontal-alignment: left; font-weight: 700; font-size: Theme.fs; vertical-alignment: center; color: Theme.text; }
                                Text { text: I18n.en ? "Normal send" : "正常发送"; width: 140px; font-size: Theme.fs; vertical-alignment: center; color: Theme.text; }
                            }
                            Row {
                                Text { text: I18n.en ? "ID:0x" : "帧ID:0x"; width: 90px; horizontal-alignment: left; font-weight: 700; font-size: Theme.fs; vertical-alignment: center; color: Theme.text; }
                                LineEdit { text: root.tx-file-id; width: 140px; height: Theme.ctrl-h; edited(v) => { root.tx-file-id = v; } }
                                Text { text: I18n.en ? "Frame len:" : "帧长度:"; width: 90px; horizontal-alignment: left; font-weight: 700; font-size: Theme.fs; vertical-alignment: center; color: Theme.text; }
                                LineEdit { text: root.tx-file-len; width: 140px; height: Theme.ctrl-h; edited(v) => { root.tx-file-len = v; } }
                            }
                            Row {
                                Text { text: I18n.en ? "Interval(ms):" : "间隔(ms):"; width: 90px; horizontal-alignment: left; font-weight: 700; font-size: Theme.fs; vertical-alignment: center; color: Theme.text; }
                                LineEdit { text: root.tx-file-interval; width: 140px; height: Theme.ctrl-h; edited(v) => { root.tx-file-interval = v; } }
                                Text { text: I18n.en ? "Repeat:" : "发送次数:"; width: 90px; horizontal-alignment: left; font-weight: 700; font-size: Theme.fs; vertical-alignment: center; color: Theme.text; }
                                LineEdit { text: root.tx-file-repeat; width: 140px; height: Theme.ctrl-h; edited(v) => { root.tx-file-repeat = v; } }
                            }
                            Row {
                                Text { text: I18n.en ? "File fmt:" : "文件格式:"; width: 90px; horizontal-alignment: left; font-weight: 700; font-size: Theme.fs; vertical-alignment: center; color: Theme.text; }
                                Text { text: I18n.en ? "Text: one frame per line as hex (e.g. 01 02 03)" : "文本:每行一帧的十六进制数据(如 01 02 03)"; font-size: Theme.fs-sm; vertical-alignment: center; color: Theme.text-dim; }
                                Rectangle { }
                                Rectangle { }
                            }
                        }
                    }
                }
                Rectangle { height: 8px; }
                Rectangle { background: Theme.panel; border-width: 1px; border-color: Theme.border; vertical-stretch: 0;
                    VerticalLayout {
                        padding: 12px; spacing: 10px;
                        Text { text: I18n.en ? "File" : "文件"; font-weight: 700; color: Theme.text; font-size: Theme.fs; }
                        HorizontalLayout {
                            spacing: 6px;
                            Text { text: I18n.en ? "File:" : "文件:"; width: 90px; horizontal-alignment: left; font-weight: 700; font-size: Theme.fs; vertical-alignment: center; color: Theme.text; }
                            LineEdit { text: root.tx-file-path; height: Theme.ctrl-h; horizontal-stretch: 1; read-only: true; }
                            TBtn { text: "..."; clicked => { root.tx-file-pick(); } }
                        }
                        Text { text: root.tx-file-status; font-size: Theme.fs; color: Theme.text; }
                        HorizontalLayout {
                            spacing: 6px;
                            Rectangle { height: 28px; horizontal-stretch: 1; background: Theme.panel2; border-width: 1px; border-color: Theme.border;
                                Rectangle { x: 0; y: 0; height: 100%; width: parent.width * root.tx-file-progress; background: Theme.accent; }
                            }
                            Text { text: Math.round(root.tx-file-progress * 100) + "%"; width: 48px; horizontal-alignment: right; vertical-alignment: center; font-size: Theme.fs; color: Theme.text; }
                        }
                        HorizontalLayout {
                            spacing: 8px; alignment: end;
                            TBtn { text: I18n.en ? "Send" : "发送"; clicked => { root.tx-file-send(); } }
                            TBtn { text: I18n.en ? "Stop" : "停止"; clicked => { root.tx-file-stop(); } }
                        }
                    }
                }
                Rectangle { vertical-stretch: 1; }
            }
            Rectangle {
                horizontal-stretch: 1; background: Theme.panel; border-width: 1px; border-color: Theme.border;
                Text { text: I18n.en ? "Custom interval list" : "自定义发送间隔列表"; x: 10px; y: 10px; font-size: Theme.fs; font-weight: 700; color: Theme.text; }
                Rectangle { x: 8px; y: 48px; width: parent.width - 16px; height: 34px; background: Theme.header;
                    Text { text: I18n.en ? "Frame idx        Delay(ms)        Multi-frame delay" : "帧索引        延时(ms)        倍数帧延时"; x: 42px; vertical-alignment: center; font-size: Theme.fs; color: Theme.text; }
                }
                Text { text: I18n.en ? "Delay is applied after the frame at the given index is sent.\nCustom delays override the per-send interval.\nFrame index starts from 1." : "帧索引对应的帧发送之后进行延时操作\n自定义延时会覆盖每次发送间隔\n帧索引从1开始"; x: 10px; y: parent.height - 100px; color: Theme.text; font-size: 14px; }
            }
        } }
    }
}

export component ChannelConfigWindow inherits Window {
    title: I18n.en ? "CAN Channel Config" : "CAN 通道配置";
    icon: @image-url("logo.svg");
    preferred-width: 760px;
    preferred-height: 460px;
    background: Theme.bg;

    in property <[string]> channels;
    in-out property <int> chan-sel: 0;
    in-out property <bool> is-fd: false;
    in-out property <string> device-type: "Virtual";
    in-out property <string> device-index: "0";
    in-out property <string> channel-index: "0";
    in-out property <string> baud: "500K";
    in-out property <string> data-baud: "2M";
    in-out property <bool> termination: false;
    in-out property <bool> net-server: true;
    in-out property <string> ip: "192.168.0.178";
    in-out property <string> port: "8000";
    property <bool> is-net: device-type == "CANFDNET" || device-type == "CANFDWIFI";
    in-out property <length> list-w: 220px; // 通道列表宽度（可拖动分隔条调整）

    callback chan-add();
    callback chan-clone();
    callback chan-remove(int);
    callback chan-select(int);
    callback chan-edit(string, string);
    callback save-all();
    callback connect-all();
    callback cancel();

    VerticalLayout {
        padding: 12px;
        spacing: 10px;
        Rectangle {
            height: 38px; background: Theme.panel; border-width: 1px; border-color: Theme.border;
            Text {
                text: I18n.en ? "Software CAN1/CAN2… each map to a device hardware channel (HW from CAN0). Click CAN+ to add a channel; Clone copies the config." : "软件 CAN1/CAN2… 各映射到设备的硬件通道（硬件从 CAN0 起）。点 CAN+ 添加通道，克隆可复制配置。";
                x: 10px; width: parent.width - 20px; color: Theme.text; font-size: 13px;
                vertical-alignment: center; overflow: elide;
            }
        }
        HorizontalLayout {
            spacing: 10px;
            // 通道列表
            Rectangle {
                width: root.list-w; background: Theme.panel; border-width: 1px; border-color: Theme.border;
                VerticalLayout {
                    Rectangle { height: 28px; background: Theme.header;
                        Text { text: I18n.en ? "Channel list" : "通道列表"; x: 8px; vertical-alignment: center; font-weight: 700; font-size: 13px; color: Theme.text; } }
                    ListView {
                        for c[i] in root.channels: Rectangle {
                            height: 32px;
                            background: i == root.chan-sel ? Theme.sel : (cta.has-hover ? Theme.accent-soft : (Math.mod(i, 2) == 0 ? Theme.panel : Theme.zebra));
                            cta := TouchArea { clicked => { root.chan-select(i); } }
                            Text { text: c; x: 10px; vertical-alignment: center; font-size: 13px; color: Theme.text; overflow: elide; }
                        }
                    }
                    Rectangle { height: 40px; background: Theme.panel2;
                        HorizontalLayout { padding: 5px; spacing: 5px;
                            TBtn { text: "CAN+"; clicked => { root.chan-add(); } }
                            TBtn { text: I18n.en ? "Clone" : "克隆"; clicked => { root.chan-clone(); } }
                            TBtn { text: I18n.en ? "Delete" : "删除"; clicked => { root.chan-remove(root.chan-sel); } }
                        }
                    }
                }
            }
            // -------- 可拖拽分隔条：调整通道列表宽度 --------
            Rectangle {
                width: 6px;
                background: clsp.has-hover || clsp.pressed ? Theme.accent : Theme.border;
                property <length> press-x;
                property <length> press-w;
                clsp := TouchArea {
                    mouse-cursor: col-resize;
                    pointer-event(e) => {
                        if (e.kind == PointerEventKind.down) {
                            press-x = self.absolute-position.x + self.mouse-x;
                            press-w = root.list-w;
                        }
                    }
                    moved => {
                        if (self.pressed) {
                            root.list-w = Math.max(140px, Math.min(480px,
                                press-w + (self.absolute-position.x + self.mouse-x - press-x)));
                        }
                    }
                }
            }
            // 编辑表单
            Rectangle {
                horizontal-stretch: 1; background: Theme.panel; border-width: 1px; border-color: Theme.border;
                VerticalLayout {
                    padding: 12px; spacing: 8px;
                    GridLayout {
                        spacing: 8px;
                        Row {
                            Text { text: I18n.en ? "Device type" : "设备类型"; font-size: 14px; vertical-alignment: center; }
                            ComboBox {
                                width: 240px;
                                model: ["Virtual", "PCAN", "USBCANFD-200U", "USBCANFD-100U", "USBCANFD-MINI", "USBCAN2", "USBCAN-E-U", "USBCAN-2E-U", "GCAN", "ZHCX", "CANFDNET", "CANFDWIFI"];
                                current-value <=> root.device-type;
                                selected(v) => { root.chan-edit("device_type", v); }
                            }
                        }
                        Row {
                            Text { text: I18n.en ? "Device index" : "设备索引"; font-size: 14px; vertical-alignment: center; }
                            LineEdit { text: root.device-index; width: 120px; edited(v) => { root.device-index = v; root.chan-edit("device_index", v); } }
                        }
                        Row {
                            Text { text: I18n.en ? "HW channel index" : "硬件通道索引"; font-size: 14px; vertical-alignment: center; }
                            LineEdit { text: root.channel-index; width: 120px; edited(v) => { root.channel-index = v; root.chan-edit("channel_index", v); } }
                        }
                        Row {
                            Text { text: I18n.en ? "Proto" : "协议"; font-size: 14px; vertical-alignment: center; }
                            ComboBox { width: 160px; model: ["CAN", "CAN FD"];
                                current-value: root.is-fd ? "CAN FD" : "CAN";
                                selected(v) => { root.is-fd = v == "CAN FD"; root.chan-edit("is_fd", v == "CAN FD" ? "1" : "0"); } }
                        }
                        Row {
                            Text { text: I18n.en ? "Arb baud" : "仲裁域波特率"; font-size: 14px; vertical-alignment: center; }
                            ComboBox { width: 160px; model: ["1M", "800K", "500K", "250K", "125K", "100K", "50K", "20K"];
                                current-value <=> root.baud; selected(v) => { root.chan-edit("baud", v); } }
                        }
                        Row {
                            Text { text: I18n.en ? "Data baud" : "数据域波特率"; font-size: 14px; vertical-alignment: center; color: root.is-fd ? Theme.text : Theme.text-dim; }
                            ComboBox { width: 160px; enabled: root.is-fd; model: ["5M", "4M", "2M", "1M", "800K", "500K", "250K", "125K", "100K"];
                                current-value <=> root.data-baud; selected(v) => { root.chan-edit("data_baud", v); } }
                        }
                        Row {
                            Text { text: I18n.en ? "Termination" : "终端电阻"; font-size: 14px; vertical-alignment: center; }
                            CheckBox { checked: root.termination; text: I18n.en ? "Enable" : "启用"; toggled => { root.termination = self.checked; root.chan-edit("termination", self.checked ? "1" : "0"); } }
                        }
                    }
                    // 网络设备参数（仅 CANFDNET/WIFI 显示）
                    if root.is-net: GridLayout {
                        spacing: 8px;
                        Row {
                            Text { text: I18n.en ? "Work mode" : "工作模式"; font-size: 14px; vertical-alignment: center; }
                            ComboBox { width: 160px; model: I18n.en ? ["Server", "Client"] : ["服务器", "客户端"];
                                current-value: root.net-server ? (I18n.en ? "Server" : "服务器") : (I18n.en ? "Client" : "客户端");
                                selected(v) => { root.net-server = (v == "服务器" || v == "Server"); root.chan-edit("net_server", (v == "服务器" || v == "Server") ? "1" : "0"); } }
                        }
                        Row {
                            Text { text: I18n.en ? "IP address" : "IP 地址"; font-size: 14px; vertical-alignment: center; }
                            LineEdit { text: root.ip; width: 200px; edited(v) => { root.ip = v; root.chan-edit("ip", v); } }
                        }
                        Row {
                            Text { text: I18n.en ? "Port" : "端口"; font-size: 14px; vertical-alignment: center; }
                            LineEdit { text: root.port; width: 120px; edited(v) => { root.port = v; root.chan-edit("port", v); } }
                        }
                    }
                    Rectangle { vertical-stretch: 1;
                        Text {
                            text: I18n.en ? "PCAN needs PEAK driver; Virtual needs no hardware; USBCAN/USBCANFD need zlgcan.dll; GCAN needs ECanVci64.dll; ZHCX/USBCAN2 need ControlCAN.dll; CANFDNET/WIFI are network devices (IP/port). Data-phase baud is for CAN FD only." : "PCAN需PEAK驱动；Virtual免硬件；USBCAN/USBCANFD需zlgcan.dll；GCAN需ECanVci64.dll；ZHCX/USBCAN2需ControlCAN.dll；CANFDNET/WIFI为网络设备(IP/端口)。数据域波特率仅CAN FD用。";
                            x: 2px; y: 4px; width: parent.width - 4px; color: Theme.text-dim; font-size: 12px; wrap: word-wrap;
                        }
                    }
                }
            }
        }
        Rectangle {
            height: 38px;
            HorizontalLayout {
                spacing: 8px;
                Rectangle { horizontal-stretch: 1; }
                Button { text: I18n.en ? "Save" : "保存"; clicked => { root.save-all(); } }
                Button { text: I18n.en ? "Save & Connect" : "保存并连接"; clicked => { root.connect-all(); } }
                Button { text: I18n.en ? "Cancel" : "取消"; clicked => { root.cancel(); } }
            }
        }
    }
}

// ======================= Main Window =======================

export component AppWindow inherits Window {
    title: I18n.en ? "PcanWork - CAN/CAN FD Analyzer" : "PcanWork - CAN/CAN FD 分析工具";
    icon: @image-url("logo.svg");
    preferred-width: 1320px;
    preferred-height: 820px;
    min-width: 900px;   // 防止 ribbon/筛选条/状态栏被挤压
    min-height: 560px;
    background: Theme.bg;

    in property <[TreeRow]> tree;
    in property <[MsgRow]> msgs;
    in property <[SigRow]> sigs;
    in property <[TxRow]> txs;
    in property <[ChanStat]> chan-stats;
    in property <[IdStat]> id-stats;
    in property <[ChartSeries]> series;
    in property <[string]> dbc-signals;
    in property <[string]> logs;
    // CAN 报文日志 (printf-over-CAN 控制台)
    in property <[string]> console-lines;
    in-out property <bool> console-enabled: false;
    in-out property <string> console-id;     // 捕获的 ID, 空=全部
    in-out property <int> console-ch: 0;      // 0=全部, 1=CAN1...
    in-out property <bool> console-autoscroll: true;

    in property <bool> connected: false;
    in property <bool> running: false;
    in property <bool> recording: false;
    in property <bool> trigger-armed: false;
    in property <bool> mode-trace: true;
    in-out property <int> time-mode: 0;
    in property <bool> paused: false;
    in property <bool> auto-scroll: true;
    in property <string> fps: "0";
    in property <string> bus-load: "0%";
    in property <string> chan-load: ""; // 多卡时各通道负载明细, 如 "CAN1 84%  CAN2 83%"; 单通道为空
    in property <bool> load-high: false;
    in-out property <int> ribbon: 1;
    in-out property <int> left-tab: 0;
    in-out property <int> bottom-tab: 0; // 0=运行日志 1=报文统计
    in-out property <length> bottom-h: 192px;
    in-out property <length> left-w: 232px;
    in property <string> rx-count: "0";
    in property <string> tx-count: "0";
    in property <string> err-count: "0";
    in property <string> total-count: "0";
    in property <string> shown-count: "0";
    in property <string> baud: "500K";
    in property <string> sig-title: "未选择报文";
    in property <int> selected: -1;
    in property <string> sel-id: "无";
    in property <int> sort-col: -1;
    in property <bool> sort-desc: false;

    // chart
    in property <string> chart-ymax-label;
    in property <string> chart-ymid-label;
    in property <string> chart-ymin-label;
    in property <string> chart-xstart-label;
    in property <string> chart-xend-label;
    in property <string> chart-cursor-readout;
    in property <bool> chart-paused: false;
    in property <bool> chart-normalize: false;
    in property <bool> chart-cursor: false;
    in-out property <float> cursor-frac;

    in-out property <string> f-id;
    in-out property <string> f-name;
    in-out property <string> f-data;
    in-out property <int> dir-filter: 0; // 0=全部 1=Rx 2=Tx

    callback connect();
    callback start-demo();
    callback disconnect();
    callback start-rx();
    callback stop-rx();
    callback load-dbc();
    callback reload-dbc();
    callback clear-dbc();
    callback clear-msgs();
    callback set-mode(bool);
    callback set-time-mode(int);
    callback toggle-col(string);
    callback toggle-pause();
    callback toggle-record();
    callback toggle-autoscroll();
    // CAN 报文日志
    callback console-set-enabled(bool);
    callback console-set-id(string);
    callback console-set-ch(int);
    callback console-clear();
    callback console-export();
    callback console-help();
    callback select-row(int);
    callback view-signals(int);
    callback toggle-expand(int);
    callback msg-sig-to-chart(int);
    callback add-sig-to-chart(int);
    callback apply-filter();
    callback set-dir-filter(int);
    callback clear-filter();
    callback tx-add();
    callback tx-remove(int);
    callback tx-send-once(int);
    callback tx-toggle-periodic(int);
    callback tree-clicked(int);
    callback tree-dblclick(int);
    callback clear-chart();
    callback tx-all(bool);
    callback open-chart-window();
    callback open-tx-window();
    callback open-channel-config();
    callback open-playback-window();
    callback open-convert-window();
    callback open-cache-config();
    callback open-trigger-window();
    callback open-sim-panel-window();
    callback open-serial-tool();
    callback open-modbus-tool();
    callback open-script-runner();
    callback new-project();
    callback open-project();
    callback save-project();
    callback toggle-dark();
    callback toggle-big();
    callback toggle-lang();
    callback tx-update(int, string, string);
    callback quit-app();
    callback menu-info(string);
    callback sort-by(int);
    callback ctx-only-id(int);
    callback ctx-hide-id(int);
    callback ctx-to-tx(int);
    callback ctx-send-now(int);
    callback ctx-add-all-signals(int);
    callback sel-only-id();
    callback sel-hide-id();
    callback sel-to-tx();
    callback sel-send-now();
    callback sel-add-all-signals();
    callback chart-toggle-pause();
    callback chart-autoscale();
    callback chart-normalize-toggle();
    callback chart-cursor-toggle();
    callback chart-export-csv();
    callback chart-add-dbc-signal(int);
    callback chart-toggle-series(int);
    callback chart-remove-series(int);

    VerticalLayout {
        // ===================== Ribbon 功能区 =====================
        Rectangle {
            height: Theme.big ? 126px : 110px;
            background: Theme.panel;
            Rectangle { width: 100%; height: 1px; y: parent.height - 1px; background: Theme.border; }
            VerticalLayout {
                // ribbon tabs
                Rectangle {
                    height: 28px; background: Theme.header;
                    Rectangle { width: 100%; height: 1px; y: parent.height - 1px; background: Theme.border; }
                    HorizontalLayout {
                        padding-left: 6px; spacing: 2px; alignment: start;
                        // 软件 LOGO
                        Image { source: @image-url("logo.svg"); width: 22px; height: 22px; y: (parent.height - 22px) / 2; }
                        Text { text: "PcanWork"; vertical-alignment: center; font-weight: 700; font-size: Theme.fs; color: Theme.accent; }
                        Rectangle { width: 8px; }
                        RibbonTab { text: I18n.en ? "File" : "文件"; active: root.ribbon == 0; clicked => { root.ribbon = 0; } }
                        RibbonTab { text: I18n.en ? "Home" : "主页"; active: root.ribbon == 1; clicked => { root.ribbon = 1; } }
                        RibbonTab { text: I18n.en ? "View" : "视图"; active: root.ribbon == 2; clicked => { root.ribbon = 2; } }
                    }
                }
                // ribbon band
                Rectangle {
                    vertical-stretch: 1;
                    if root.ribbon == 0: ScrollView { HorizontalLayout {
                        padding: 4px; spacing: 0px; alignment: start;
                        RibbonGroup {
                            caption: I18n.en ? "Project" : "工程";
                            RibbonBtn { icon: "file"; label: I18n.en ? "New" : "新建"; clicked => { root.new-project(); } }
                            RibbonBtn { icon: "folder"; label: I18n.en ? "Open" : "打开"; clicked => { root.open-project(); } }
                            RibbonBtn { icon: "save"; label: I18n.en ? "Save" : "保存"; clicked => { root.save-project(); } }
                        }
                        RibbonGroup {
                            caption: I18n.en ? "App" : "程序";
                            RibbonBtn { icon: "clear"; label: I18n.en ? "Exit" : "退出"; icon-clr: Theme.bad; clicked => { root.quit-app(); } }
                        }
                    } }
                    if root.ribbon == 1: ScrollView { HorizontalLayout {
                        padding: 4px; spacing: 0px; alignment: start;
                        RibbonGroup {
                            caption: I18n.en ? "Manage" : "管理";
                            RibbonBtn { icon: "channel"; label: I18n.en ? "Device" : "设备"; clicked => { root.open-channel-config(); } }
                            RibbonBtn { icon: "database"; label: I18n.en ? "Load DBC" : "加载DBC"; clicked => { root.load-dbc(); } }
                            RibbonBtn { icon: "database"; label: I18n.en ? "Reload DBC" : "重载DBC"; clicked => { root.reload-dbc(); } }
                            RibbonBtn { icon: "clear"; label: I18n.en ? "Clear DBC" : "清除DBC"; clicked => { root.clear-dbc(); } }
                        }
                        RibbonGroup {
                            caption: I18n.en ? "Measure" : "测量";
                            RibbonBtn { icon: "start"; label: I18n.en ? "Start" : "启动"; icon-clr: Theme.ok; active: root.running; clicked => { root.start-rx(); } }
                            RibbonBtn { icon: "stop"; label: I18n.en ? "Stop" : "停止"; icon-clr: Theme.bad; clicked => { root.stop-rx(); } }
                            RibbonBtn { icon: "disconnect"; label: I18n.en ? "Disconnect" : "断开"; clicked => { root.disconnect(); } }
                            RibbonBtn { icon: "demo"; label: I18n.en ? "Simulate" : "模拟"; clicked => { root.start-demo(); } }
                        }
                        RibbonGroup {
                            caption: I18n.en ? "Analysis" : "数据分析";
                            RibbonBtn { icon: "send"; label: I18n.en ? "Send" : "发送"; clicked => { root.open-tx-window(); } }
                            RibbonBtn { icon: "curve"; label: I18n.en ? "Chart" : "曲线"; clicked => { root.open-chart-window(); } }
                        }
                        RibbonGroup {
                            caption: I18n.en ? "Record/Play" : "记录与回放";
                            RibbonBtn { icon: "record"; label: root.recording ? (I18n.en ? "Stop Rec" : "停止保存") : (I18n.en ? "Record" : "保存报文"); icon-clr: Theme.bad; active: root.recording; clicked => { root.toggle-record(); } }
                            RibbonBtn { icon: "playback"; label: I18n.en ? "Playback" : "数据回放"; clicked => { root.open-playback-window(); } }
                            RibbonBtn { icon: "record"; label: I18n.en ? "Convert" : "记录转换"; clicked => { root.open-convert-window(); } }
                        }
                        RibbonGroup {
                            caption: I18n.en ? "Display" : "显示";
                            RibbonBtn { icon: "clear"; label: I18n.en ? "Clear" : "清空"; clicked => { root.clear-msgs(); } }
                            RibbonBtn { icon: "pause"; label: root.paused ? (I18n.en ? "Resume" : "继续") : (I18n.en ? "Pause" : "暂停"); active: root.paused; clicked => { root.toggle-pause(); } }
                        }
                    } }
                    if root.ribbon == 2: ScrollView { HorizontalLayout {
                        padding: 4px; spacing: 0px; alignment: start;
                        RibbonGroup {
                            caption: I18n.en ? "Theme" : "主题";
                            RibbonBtn { icon: "theme"; label: Theme.dark ? (I18n.en ? "Light" : "浅色") : (I18n.en ? "Dark" : "深色"); clicked => { root.toggle-dark(); } }
                            RibbonBtn { icon: "layout"; label: Theme.big ? (I18n.en ? "Compact" : "紧凑") : (I18n.en ? "Large" : "大号"); clicked => { root.toggle-big(); } }
                            RibbonBtn { icon: "language"; label: I18n.en ? "中文" : "EN"; clicked => { root.toggle-lang(); } }
                        }
                        RibbonGroup {
                            caption: I18n.en ? "Cache" : "缓存";
                            RibbonBtn { icon: "database"; label: I18n.en ? "Cache" : "缓存设置"; clicked => { root.open-cache-config(); } }
                        }
                        RibbonGroup {
                            caption: I18n.en ? "Windows" : "窗口";
                            RibbonBtn { icon: "curve"; label: I18n.en ? "Chart" : "曲线窗"; clicked => { root.open-chart-window(); } }
                            RibbonBtn { icon: "send"; label: I18n.en ? "Send" : "发送窗"; clicked => { root.open-tx-window(); } }
                            RibbonBtn { icon: "playback"; label: I18n.en ? "Playback" : "回放窗"; clicked => { root.open-playback-window(); } }
                            RibbonBtn { icon: "record"; label: I18n.en ? "Trigger" : "触发器"; icon-clr: Theme.bad; active: root.trigger-armed; clicked => { root.open-trigger-window(); } }
                            RibbonBtn { icon: "layout"; label: I18n.en ? "Sim Panel" : "仿真面板"; clicked => { root.open-sim-panel-window(); } }
                            RibbonBtn { icon: "channel"; label: I18n.en ? "Serial" : "串口工具"; clicked => { root.open-serial-tool(); } }
                            RibbonBtn { icon: "modbus"; label: "Modbus"; clicked => { root.open-modbus-tool(); } }
                            RibbonBtn { icon: "start"; label: I18n.en ? "Py Test" : "Py测试"; clicked => { root.open-script-runner(); } }
                        }
                    } }
                }
            }
        }

        // ribbon 与主体之间的间隔条，避免 ribbon 分组名贴住下一行
        Rectangle { height: 8px; background: Theme.bg; }

        // ===================== Body =====================
        HorizontalLayout {
            // -------- left project tree --------
            Rectangle {
                width: root.left-w;
                background: Theme.panel;
                Rectangle { width: 1px; height: 100%; x: parent.width - 1px; background: Theme.border; }
                VerticalLayout {
                    // 浏览器 / 信号 双 Tab
                    Rectangle {
                        height: 28px; background: Theme.header;
                        Rectangle { width: 100%; height: 1px; y: parent.height - 1px; background: Theme.border; }
                        HorizontalLayout {
                            padding-left: 4px; spacing: 2px; alignment: start;
                            RibbonTab { text: I18n.en ? "Browser" : "浏览器"; active: root.left-tab == 0; clicked => { root.left-tab = 0; } }
                            RibbonTab { text: I18n.en ? "Signal" : "信号"; active: root.left-tab == 1; clicked => { root.left-tab = 1; } }
                        }
                    }
                    if root.left-tab == 0: ListView {
                        for row[i] in root.tree: Rectangle {
                            height: Theme.big ? 28px : 24px;
                            background: ta-tree.has-hover ? Theme.accent-soft : transparent;
                            ta-tree := TouchArea {
                                clicked => { root.tree-clicked(i); }
                                double-clicked => { root.tree-dblclick(i); }
                            }
                            HorizontalLayout {
                                padding-left: 6px + row.level * 14px;
                                spacing: 4px;
                                Text {
                                    text: row.expandable ? (row.expanded ? "v" : ">") : "";
                                    width: 12px;
                                    color: Theme.text-dim;
                                    vertical-alignment: center;
                                    horizontal-alignment: center;
                                    font-family: Theme.mono;
                                    font-size: Theme.fs-sm;
                                }
                                Rectangle {
                                    width: 18px;
                                    Icon {
                                        name: row.kind == "channel" || row.kind == "device" ? "channel"
                                            : row.kind == "dbc" ? "database"
                                            : row.kind == "msg" ? "send"
                                            : row.kind == "signal" ? "curve"
                                            : row.kind == "tx" ? "send"
                                            : row.kind == "curve" ? "curve"
                                            : row.kind == "record" ? "record"
                                            : row.kind == "project" ? "folder" : "file";
                                        clr: row.accent ? Theme.accent : Theme.text-dim;
                                        width: 15px; height: 15px;
                                        x: (parent.width - self.width) / 2; y: (parent.height - self.height) / 2;
                                    }
                                }
                                Text {
                                    text: row.label;
                                    color: row.accent ? Theme.accent : Theme.text;
                                    font-weight: row.level == 0 ? 700 : 400;
                                    vertical-alignment: center; font-size: Theme.fs; overflow: elide;
                                }
                            }
                        }
                    }
                    if root.left-tab == 1: VerticalLayout {
                        Rectangle {
                            height: 22px; background: Theme.panel2;
                            Text { text: I18n.en ? "DBC signals (click to add to chart)" : "DBC 信号（单击加入曲线）"; x: 8px; vertical-alignment: center; font-size: Theme.fs-sm; color: Theme.text-dim; }
                        }
                        ListView {
                            for s[i] in root.dbc-signals: Rectangle {
                                height: Theme.big ? 26px : 22px;
                                background: sta.has-hover ? Theme.accent-soft : (Math.mod(i, 2) == 0 ? Theme.panel : Theme.zebra);
                                sta := TouchArea { clicked => { root.chart-add-dbc-signal(i); } }
                                HorizontalLayout {
                                    padding-left: 8px; spacing: 5px;
                                    Rectangle {
                                        width: 16px;
                                        Icon { name: "curve"; clr: Theme.accent; width: 14px; height: 14px;
                                               x: (parent.width - self.width) / 2; y: (parent.height - self.height) / 2; }
                                    }
                                    Text { text: s; color: Theme.text; vertical-alignment: center; font-size: Theme.fs; overflow: elide; }
                                }
                            }
                        }
                    }
                }
            }

            // -------- 左右可拖拽分隔条 --------
            Rectangle {
                width: 6px;
                background: spv.has-hover || spv.pressed ? Theme.accent : Theme.border;
                property <length> press-x;
                property <length> press-w;
                spv := TouchArea {
                    mouse-cursor: col-resize;
                    pointer-event(e) => {
                        if (e.kind == PointerEventKind.down) {
                            press-x = self.absolute-position.x + self.mouse-x;
                            press-w = root.left-w;
                        }
                    }
                    moved => {
                        if (self.pressed) {
                            root.left-w = Math.max(150px, Math.min(560px,
                                press-w + (self.absolute-position.x + self.mouse-x - press-x)));
                        }
                    }
                }
            }

            // -------- center + bottom --------
            VerticalLayout {
                // message window toolbar
                Rectangle {
                    height: Theme.ctrl-h + 10px; background: Theme.panel2;
                    Rectangle { width: 100%; height: 1px; y: parent.height - 1px; background: Theme.border; }
                    ScrollView { HorizontalLayout {
                        padding: 4px; spacing: 3px; alignment: start;
                        TBtn { text: "Trace"; active: root.mode-trace; clicked => { root.set-mode(true); } }
                        TBtn { text: I18n.en ? "Group" : "分组"; active: !root.mode-trace; clicked => { root.set-mode(false); } }
                        Rectangle { width: 1px; background: Theme.border; }
                        TBtn { text: root.paused ? (I18n.en ? "Resume" : "继续") : (I18n.en ? "Pause" : "暂停"); active: root.paused; clicked => { root.toggle-pause(); } }
                        TBtn { text: I18n.en ? "Auto-scroll" : "自动滚动"; active: root.auto-scroll; clicked => { root.toggle-autoscroll(); } }
                        Rectangle { width: 1px; background: Theme.border; }
                        Text { text: "ID:"; vertical-alignment: center; font-size: Theme.fs; }
                        LineEdit { width: 90px; height: Theme.ctrl-h; placeholder-text: I18n.en ? "0x180/range" : "0x180/范围"; text <=> root.f-id; }
                        Text { text: "Name:"; vertical-alignment: center; font-size: Theme.fs; }
                        LineEdit { width: 90px; height: Theme.ctrl-h; placeholder-text: "BMS"; text <=> root.f-name; }
                        Text { text: "Data:"; vertical-alignment: center; font-size: Theme.fs; }
                        LineEdit { width: 90px; height: Theme.ctrl-h; placeholder-text: "01 02"; text <=> root.f-data; }
                        Text { text: I18n.en ? "Dir:" : "方向:"; vertical-alignment: center; font-size: Theme.fs; }
                        ComboBox {
                            width: 80px; height: Theme.ctrl-h;
                            model: I18n.en ? ["All", "Rx", "Tx"] : ["全部", "Rx", "Tx"];
                            current-index <=> root.dir-filter;
                            selected => { root.set-dir-filter(self.current-index); }
                        }
                        Text { text: I18n.en ? "Time:" : "时间:"; vertical-alignment: center; font-size: Theme.fs; }
                        ComboBox {
                            width: 90px; height: Theme.ctrl-h;
                            model: I18n.en ? ["Relative", "Absolute", "System"] : ["相对", "绝对", "系统"];
                            current-index <=> root.time-mode;
                            selected => { root.set-time-mode(self.current-index); }
                        }
                        TBtn { text: I18n.en ? "Apply" : "应用"; clicked => { root.apply-filter(); } }
                        TBtn { text: I18n.en ? "Clear" : "清除"; clicked => { root.clear-filter(); } }
                        Rectangle {
                            width: 44px; height: Theme.ctrl-h;
                            colbtn := TBtn { boxed: true; text: I18n.en ? "Columns" : "列设置"; clicked => { colpop.show(); } }
                            colpop := PopupWindow {
                                x: 0; y: parent.height + 2px;
                                Rectangle {
                                    width: 132px;
                                    background: Theme.panel;
                                    border-width: 1px; border-color: Theme.border; border-radius: 4px;
                                    drop-shadow-blur: 8px; drop-shadow-color: #00000040;
                                    VerticalLayout {
                                        padding: 6px; spacing: 1px;
                                        Text { text: I18n.en ? "Columns" : "显示列"; font-weight: 700; font-size: Theme.fs-sm; color: Theme.text-dim; }
                                        CheckBox { text: I18n.en ? "No." : "序号"; checked: ColW.no > 0px; toggled => { root.toggle-col("no"); } }
                                        CheckBox { text: I18n.en ? "Time" : "时间"; checked: ColW.time > 0px; toggled => { root.toggle-col("time"); } }
                                        CheckBox { text: I18n.en ? "Delta" : "间隔"; checked: ColW.delta > 0px; toggled => { root.toggle-col("delta"); } }
                                        CheckBox { text: I18n.en ? "Ch" : "通道"; checked: ColW.ch > 0px; toggled => { root.toggle-col("ch"); } }
                                        CheckBox { text: I18n.en ? "Dir" : "方向"; checked: ColW.dir > 0px; toggled => { root.toggle-col("dir"); } }
                                        CheckBox { text: "ID"; checked: ColW.id > 0px; toggled => { root.toggle-col("id"); } }
                                        CheckBox { text: I18n.en ? "Name" : "名称"; checked: ColW.name > 0px; toggled => { root.toggle-col("name"); } }
                                        CheckBox { text: I18n.en ? "Type" : "类型"; checked: ColW.kind > 0px; toggled => { root.toggle-col("kind"); } }
                                        CheckBox { text: "FD"; checked: ColW.fd > 0px; toggled => { root.toggle-col("fd"); } }
                                        CheckBox { text: "BRS"; checked: ColW.brs > 0px; toggled => { root.toggle-col("brs"); } }
                                        CheckBox { text: "DLC"; checked: ColW.dlc > 0px; toggled => { root.toggle-col("dlc"); } }
                                        CheckBox { text: I18n.en ? "Len" : "长度"; checked: ColW.len > 0px; toggled => { root.toggle-col("len"); } }
                                        CheckBox { text: I18n.en ? "Data" : "数据"; checked: ColW.data > 0px; toggled => { root.toggle-col("data"); } }
                                        CheckBox { text: I18n.en ? "Cycle" : "周期"; checked: ColW.cycle > 0px; toggled => { root.toggle-col("cycle"); } }
                                        CheckBox { text: I18n.en ? "Count" : "计数"; checked: ColW.count > 0px; toggled => { root.toggle-col("count"); } }
                                        CheckBox { text: I18n.en ? "Comment" : "备注"; checked: ColW.comment > 0px; toggled => { root.toggle-col("comment"); } }
                                    }
                                }
                            }
                        }
                    } }
                }

                // selected-row action bar
                Rectangle {
                    height: Theme.ctrl-h + 10px; background: Theme.panel;
                    Rectangle { width: 100%; height: 1px; y: parent.height - 1px; background: Theme.border; }
                    ScrollView { HorizontalLayout {
                        padding: 4px; spacing: 3px; alignment: start;
                        Text { text: (I18n.en ? "Selected: " : "选中行: ") + root.sel-id; vertical-alignment: center; font-size: Theme.fs; color: Theme.text; }
                        Rectangle { width: 8px; }
                        TBtn { text: I18n.en ? "Only this ID" : "只显示该ID"; clicked => { root.sel-only-id(); } }
                        TBtn { text: I18n.en ? "Hide this ID" : "隐藏该ID"; clicked => { root.sel-hide-id(); } }
                        TBtn { text: I18n.en ? "Clear filter" : "清除过滤"; clicked => { root.clear-filter(); } }
                        Rectangle { width: 1px; background: Theme.border; }
                        TBtn { text: I18n.en ? "Add to TX" : "加到发送"; clicked => { root.sel-to-tx(); } }
                        TBtn { text: I18n.en ? "Send once" : "发一次"; clicked => { root.sel-send-now(); } }
                        Rectangle { width: 1px; background: Theme.border; }
                        TBtn { text: I18n.en ? "All sigs→chart" : "所有信号→曲线"; clicked => { root.sel-add-all-signals(); } }
                        Rectangle { width: 1px; background: Theme.border; }
                        TBtn { text: I18n.en ? "Clear data" : "清除数据"; clicked => { root.clear-msgs(); } }
                        Rectangle { width: 16px; }
                        Text { text: I18n.en ? "Tip: click=select row (see Signals tab below) · dbl-click=add all signals to chart" : "提示: 单击选中行(底部'信号解析'看解码) · 双击行=加全部信号到曲线"; vertical-alignment: center; font-size: Theme.fs-sm; color: Theme.text-dim; }
                    } }
                }

                // message table
                Rectangle {
                    vertical-stretch: 1;
                    background: Theme.panel;
                    ScrollView {
                        viewport-width: ColW.total;
                        VerticalLayout {
                            width: ColW.total;
                            Rectangle {
                                height: 26px;
                                HorizontalLayout {
                                    SortHeader { text: "No."; w: ColW.no; cidx: 0; sort-col: root.sort-col; sort-desc: root.sort-desc; clicked(c) => { root.sort-by(c); } }
                                    SortHeader { text: "Time"; w: ColW.time; cidx: 1; sort-col: root.sort-col; sort-desc: root.sort-desc; clicked(c) => { root.sort-by(c); } }
                                    SortHeader { text: "Delta"; w: ColW.delta; cidx: 2; sort-col: root.sort-col; sort-desc: root.sort-desc; clicked(c) => { root.sort-by(c); } }
                                    SortHeader { text: "Ch"; w: ColW.ch; cidx: 3; sort-col: root.sort-col; sort-desc: root.sort-desc; clicked(c) => { root.sort-by(c); } }
                                    SortHeader { text: "Dir"; w: ColW.dir; cidx: 4; sort-col: root.sort-col; sort-desc: root.sort-desc; clicked(c) => { root.sort-by(c); } }
                                    SortHeader { text: "ID"; w: ColW.id; cidx: 5; sort-col: root.sort-col; sort-desc: root.sort-desc; clicked(c) => { root.sort-by(c); } }
                                    SortHeader { text: "Name"; w: ColW.name; cidx: 6; sort-col: root.sort-col; sort-desc: root.sort-desc; clicked(c) => { root.sort-by(c); } }
                                    SortHeader { text: "Type"; w: ColW.kind; cidx: 7; sort-col: root.sort-col; sort-desc: root.sort-desc; clicked(c) => { root.sort-by(c); } }
                                    HCell { text: "FD"; w: ColW.fd; }
                                    HCell { text: "BRS"; w: ColW.brs; }
                                    SortHeader { text: "DLC"; w: ColW.dlc; cidx: 10; sort-col: root.sort-col; sort-desc: root.sort-desc; clicked(c) => { root.sort-by(c); } }
                                    SortHeader { text: "Len"; w: ColW.len; cidx: 11; sort-col: root.sort-col; sort-desc: root.sort-desc; clicked(c) => { root.sort-by(c); } }
                                    HCell { text: "Data"; w: ColW.data; }
                                    HCell { text: "Cycle"; w: ColW.cycle; }
                                    SortHeader { text: "Count"; w: ColW.count; cidx: 14; sort-col: root.sort-col; sort-desc: root.sort-desc; clicked(c) => { root.sort-by(c); } }
                                    HCell { text: "Comment"; w: ColW.comment; }
                                }
                            }
                            msglist := ListView {
                                // 自动滚动：内容增长时若开启则把视口拉到底
                                changed viewport-height => {
                                    if (root.auto-scroll) {
                                        self.viewport-y = min(0px, self.visible-height - self.viewport-height);
                                    }
                                }
                                property <bool> as-trigger: root.auto-scroll;
                                changed as-trigger => {
                                    if (self.as-trigger) {
                                        self.viewport-y = min(0px, self.visible-height - self.viewport-height);
                                    }
                                }
                                for row[i] in root.msgs: Rectangle {
                                    // CAN FD: grow the row so long data wraps into lines of 16 bytes
                                    height: row.data-bytes.length <= 16 ? Theme.rowh
                                        : row.data-bytes.length <= 32 ? 48px
                                        : row.data-bytes.length <= 48 ? 68px : 88px;
                                    background:
                                        i == root.selected ? Theme.sel :
                                        rowta.has-hover ? Theme.accent-soft :
                                        row.is-signal ? Theme.sigrow :
                                        row.is-error ? Theme.err-bg :
                                        row.timeout ? Theme.timeout-bg :
                                        row.is-new ? Theme.new-bg :
                                        row.is-tx ? Theme.tx-bg :
                                        (Math.mod(i, 2) == 0 ? Theme.panel : Theme.zebra);
                                    Rectangle { width: 100%; height: 1px; y: parent.height - 1px; background: Theme.border; }
                                    msg-ctx := ContextMenuArea {
                                        enabled: !row.is-signal;
                                        width: 100%; height: 100%;
                                        Menu {
                                            MenuItem { title: I18n.en ? "View signals" : "查看信号解析"; activated => { root.view-signals(i); } }
                                            MenuItem { title: I18n.en ? "Only this ID" : "只显示该 ID"; activated => { root.ctx-only-id(i); } }
                                            MenuItem { title: I18n.en ? "Hide this ID" : "隐藏该 ID"; activated => { root.ctx-hide-id(i); } }
                                            MenuItem { title: I18n.en ? "Clear filter" : "清除过滤"; activated => { root.clear-filter(); } }
                                            MenuItem { title: I18n.en ? "Add to TX window" : "添加到发送窗口"; activated => { root.ctx-to-tx(i); } }
                                            MenuItem { title: I18n.en ? "Send once now" : "立即发送一次"; activated => { root.ctx-send-now(i); } }
                                            MenuItem { title: I18n.en ? "Add all signals to chart" : "添加所有信号到曲线"; activated => { root.ctx-add-all-signals(i); } }
                                        }
                                    }
                                    sig-ctx := ContextMenuArea {
                                        enabled: row.is-signal;
                                        width: 100%; height: 100%;
                                        Menu {
                                            MenuItem { title: I18n.en ? "View signals" : "查看信号解析"; activated => { root.view-signals(i); } }
                                            MenuItem { title: I18n.en ? "Add this signal to chart" : "添加该信号到曲线"; activated => { root.msg-sig-to-chart(i); } }
                                        }
                                    }
                                    Rectangle {
                                        width: 100%; height: 100%;
                                        rowta := TouchArea {
                                            clicked => { root.select-row(i); }
                                            double-clicked => {
                                                root.select-row(i);
                                                if (row.is-signal) {
                                                    root.msg-sig-to-chart(i);
                                                } else {
                                                    root.sel-add-all-signals();
                                                }
                                            }
                                            pointer-event(event) => {
                                                if (event.button == PointerEventButton.right && event.kind == PointerEventKind.down) {
                                                    root.select-row(i);
                                                    if (row.is-signal) {
                                                        sig-ctx.show({ x: self.mouse-x, y: self.mouse-y });
                                                    } else {
                                                        msg-ctx.show({ x: self.mouse-x, y: self.mouse-y });
                                                    }
                                                }
                                            }
                                        }
                                        Rectangle {
                                            width: 100%; height: 100%;
                                            HorizontalLayout {
                                        Rectangle {
                                            width: ColW.no;
                                            clip: true;
                                            background: row.can-expand && no-ta.has-hover ? Theme.panel2 : transparent;
                                            no-ta := TouchArea {
                                                clicked => {
                                                    if (row.can-expand) {
                                                        root.toggle-expand(i);
                                                    } else {
                                                        root.select-row(i);
                                                    }
                                                }
                                            }
                                            Text {
                                                text: row.no;
                                                color: row.can-expand ? Theme.accent : Theme.text;
                                                font-family: Theme.mono;
                                                font-size: 12px;
                                                vertical-alignment: center;
                                                horizontal-alignment: right;
                                                x: 3px;
                                                width: parent.width - 8px;
                                            }
                                        }
                                        Cell { text: row.time; w: ColW.time; mono: true; align: right; }
                                        Cell { text: row.delta; w: ColW.delta; mono: true; align: right; txt-clr: Theme.text-dim; }
                                        Cell { text: row.ch; w: ColW.ch; }
                                        Cell { text: row.dir; w: ColW.dir; txt-clr: row.is-tx ? Theme.accent : Theme.text; }
                                        Cell { text: row.id; w: ColW.id; mono: true; txt-clr: row.fd == "Yes" ? Theme.accent : Theme.text; }
                                        Cell { text: row.name; w: ColW.name; txt-clr: row.is-signal ? Theme.accent : (row.name == "" ? Theme.text-dim : Theme.text); }
                                        Cell { text: row.kind; w: ColW.kind; }
                                        Cell { text: row.fd; w: ColW.fd; }
                                        Cell { text: row.brs; w: ColW.brs; }
                                        Cell { text: row.dlc; w: ColW.dlc; align: right; }
                                        Cell { text: row.len; w: ColW.len; align: right; }
                                        Rectangle {
                                            width: ColW.data;
                                            clip: true;
                                            // short frames (<=16 bytes): per-byte cells with changed-byte highlight
                                            if (row.data-bytes.length <= 16): HorizontalLayout {
                                                padding-left: 5px; spacing: 3px; alignment: start;
                                                for bc in row.data-bytes: Rectangle {
                                                    background: bc.hot ? Theme.changed-bg : transparent;
                                                    border-radius: 2px;
                                                    Text {
                                                        text: bc.hex;
                                                        font-family: Theme.mono; font-size: 12px;
                                                        color: bc.hot ? Theme.bad : Theme.text;
                                                        vertical-alignment: center;
                                                    }
                                                }
                                            }
                                            // long CAN FD payloads: wrapped multi-line hex (16 bytes per line)
                                            if (row.data-bytes.length > 16): Text {
                                                x: 5px;
                                                text: row.data-text;
                                                font-family: Theme.mono;
                                                font-size: 12px;
                                                color: Theme.text;
                                                vertical-alignment: center;
                                            }
                                        }
                                        Cell { text: row.cycle; w: ColW.cycle; mono: true; align: right; }
                                        Cell { text: row.count; w: ColW.count; mono: true; align: right; }
                                        Cell { text: row.comment; w: ColW.comment; txt-clr: row.signal-out-of-range || row.is-error ? Theme.bad : Theme.text-dim; }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }

                // ===================== 可拖拽分隔条 =====================
                Rectangle {
                    height: 6px;
                    background: sph.has-hover || sph.pressed ? Theme.accent : Theme.border;
                    property <length> press-y;
                    property <length> press-h;
                    sph := TouchArea {
                        mouse-cursor: row-resize;
                        pointer-event(e) => {
                            if (e.kind == PointerEventKind.down) {
                                press-y = self.absolute-position.y + self.mouse-y;
                                press-h = root.bottom-h;
                            }
                        }
                        moved => {
                            if (self.pressed) {
                                root.bottom-h = Math.max(90px, Math.min(560px,
                                    press-h - (self.absolute-position.y + self.mouse-y - press-y)));
                            }
                        }
                    }
                }

                // ===================== 底部面板：运行日志 / 报文统计 =====================
                Rectangle {
                    height: root.bottom-h;
                    background: Theme.panel;
                    VerticalLayout {
                        // 标签切换
                        Rectangle { height: 26px; background: Theme.header;
                            Rectangle { width: 100%; height: 1px; y: parent.height - 1px; background: Theme.border; }
                            HorizontalLayout {
                                padding-left: 6px; spacing: 2px; alignment: start;
                                RibbonTab { text: I18n.en ? "Log" : "运行日志"; active: root.bottom-tab == 0; clicked => { root.bottom-tab = 0; } }
                                RibbonTab { text: I18n.en ? "Stats" : "报文统计"; active: root.bottom-tab == 1; clicked => { root.bottom-tab = 1; } }
                                RibbonTab { text: I18n.en ? "Signals" : "信号解析"; active: root.bottom-tab == 2; clicked => { root.bottom-tab = 2; } }
                                RibbonTab { text: I18n.en ? "CAN Console" : "报文日志"; active: root.bottom-tab == 3; clicked => { root.bottom-tab = 3; } }
                            }
                        }
                        if root.bottom-tab == 0: ListView {
                            for line[i] in root.logs: Rectangle {
                                height: 20px; background: Math.mod(i, 2) == 0 ? Theme.panel : Theme.zebra;
                                Text { text: line; x: 6px; vertical-alignment: center; font-family: Theme.mono; font-size: 11px; color: Theme.text; }
                            }
                        }
                        if root.bottom-tab == 1: VerticalLayout {
                            // 表头
                            Rectangle { height: 22px; background: Theme.panel2;
                                HorizontalLayout {
                                    HCell { text: I18n.en ? "Ch" : "通道"; w: 50px; } HCell { text: "ID"; w: 90px; } HCell { text: I18n.en ? "Name" : "名称"; w: 150px; }
                                    HCell { text: I18n.en ? "Count" : "数量"; w: 70px; } HCell { text: I18n.en ? "Cycle" : "周期"; w: 70px; } HCell { text: I18n.en ? "Min" : "最小"; w: 70px; }
                                    HCell { text: I18n.en ? "Max" : "最大"; w: 70px; } HCell { text: I18n.en ? "Last time" : "最后时间"; w: 90px; } HCell { text: I18n.en ? "Timeout" : "超时"; w: 50px; }
                                }
                            }
                            ListView {
                                for s[i] in root.id-stats: Rectangle {
                                    height: Theme.big ? 24px : 20px;
                                    background: s.timeout == "是" ? Theme.timeout-bg : (Math.mod(i, 2) == 0 ? Theme.panel : Theme.zebra);
                                    HorizontalLayout {
                                        Cell { text: s.ch; w: 50px; }
                                        Cell { text: s.id; w: 90px; mono: true; }
                                        Cell { text: s.name; w: 150px; }
                                        Cell { text: s.count; w: 70px; mono: true; align: right; }
                                        Cell { text: s.avg-cycle; w: 70px; mono: true; align: right; }
                                        Cell { text: s.min; w: 70px; mono: true; align: right; }
                                        Cell { text: s.max; w: 70px; mono: true; align: right; }
                                        Cell { text: s.last-time; w: 90px; mono: true; align: right; }
                                        Cell { text: s.timeout; w: 50px; }
                                    }
                                }
                            }
                        }
                        // 信号解析：渲染当前选中报文按 DBC 解码出的信号（单击报文行选中）
                        if root.bottom-tab == 2: VerticalLayout {
                            Rectangle { height: 22px; background: Theme.panel2;
                                Text { text: root.sig-title; x: 6px; vertical-alignment: center; font-size: Theme.fs; font-weight: 700; color: Theme.text; }
                            }
                            Rectangle { height: 22px; background: Theme.panel2;
                                HorizontalLayout {
                                    HCell { text: I18n.en ? "Signal" : "信号"; w: 170px; } HCell { text: I18n.en ? "Raw" : "原始"; w: 80px; } HCell { text: I18n.en ? "Physical" : "物理值"; w: 90px; }
                                    HCell { text: I18n.en ? "Unit" : "单位"; w: 60px; } HCell { text: I18n.en ? "Min" : "最小"; w: 70px; } HCell { text: I18n.en ? "Max" : "最大"; w: 70px; }
                                    HCell { text: I18n.en ? "Bits" : "起始:长"; w: 70px; } HCell { text: I18n.en ? "Order" : "字节序"; w: 80px; } HCell { text: I18n.en ? "Status" : "状态"; w: 90px; }
                                }
                            }
                            ListView {
                                for s[i] in root.sigs: Rectangle {
                                    height: Theme.big ? 24px : 20px;
                                    background: s.out-of-range ? Theme.timeout-bg : (Math.mod(i, 2) == 0 ? Theme.panel : Theme.zebra);
                                    HorizontalLayout {
                                        Cell { text: s.signal; w: 170px; }
                                        Cell { text: s.raw; w: 80px; mono: true; align: right; }
                                        Cell { text: s.physical; w: 90px; mono: true; align: right; txt-clr: s.out-of-range ? Theme.bad : Theme.text; }
                                        Cell { text: s.unit; w: 60px; }
                                        Cell { text: s.min; w: 70px; mono: true; align: right; }
                                        Cell { text: s.max; w: 70px; mono: true; align: right; }
                                        Cell { text: s.startbit + ":" + s.length; w: 70px; mono: true; }
                                        Cell { text: s.byteorder; w: 80px; }
                                        Cell { text: s.status; w: 90px; txt-clr: s.out-of-range ? Theme.bad : Theme.text-dim; }
                                    }
                                }
                            }
                        }
                        // 报文日志: printf-over-CAN 控制台
                        if root.bottom-tab == 3: VerticalLayout {
                            Rectangle { height: 30px; background: Theme.panel2;
                                Rectangle { width: 100%; height: 1px; y: parent.height - 1px; background: Theme.border; }
                                HorizontalLayout {
                                    padding-left: 6px; padding-right: 6px; spacing: 8px; alignment: start;
                                    CheckBox { checked <=> root.console-enabled; text: I18n.en ? "Capture" : "启用"; toggled => { root.console-set-enabled(self.checked); } }
                                    Text { text: "ID:"; vertical-alignment: center; font-size: Theme.fs-sm; color: Theme.text-dim; }
                                    LineEdit { width: 90px; height: Theme.ctrl-h - 6px; placeholder-text: I18n.en ? "all" : "全部"; text <=> root.console-id; edited(v) => { root.console-set-id(v); } accepted(v) => { root.console-set-id(v); } }
                                    Text { text: I18n.en ? "Ch:" : "通道:"; vertical-alignment: center; font-size: Theme.fs-sm; color: Theme.text-dim; }
                                    ComboBox { width: 92px; height: Theme.ctrl-h - 6px; model: [I18n.en ? "All" : "全部", "CAN1", "CAN2", "CAN3", "CAN4", "CAN5", "CAN6", "CAN7", "CAN8"]; current-index <=> root.console-ch; selected(v) => { root.console-set-ch(self.current-index); } }
                                    Rectangle { horizontal-stretch: 1; }
                                    CheckBox { checked <=> root.console-autoscroll; text: I18n.en ? "Auto-scroll" : "自动滚动"; }
                                    TBtn { text: I18n.en ? "Clear" : "清空"; clicked => { root.console-clear(); } }
                                    TBtn { text: I18n.en ? "Export" : "导出"; clicked => { root.console-export(); } }
                                    TBtn { text: I18n.en ? "MCU code" : "帮助"; clicked => { root.console-help(); } }
                                }
                            }
                            ListView {
                                changed viewport-height => { if (root.console-autoscroll) { self.viewport-y = min(0px, self.visible-height - self.viewport-height); } }
                                property <bool> as2: root.console-autoscroll;
                                changed as2 => { if (self.as2) { self.viewport-y = min(0px, self.visible-height - self.viewport-height); } }
                                for line[i] in root.console-lines: Rectangle {
                                    height: 18px; background: Math.mod(i, 2) == 0 ? Theme.panel : Theme.zebra;
                                    Text { text: line; x: 6px; vertical-alignment: center; font-family: Theme.mono; font-size: 11px; color: Theme.text; overflow: elide; }
                                }
                            }
                        }
                    }
                }
            }
        }

        // ===================== 底部状态栏 =====================
        Rectangle {
            height: 24px;
            background: Theme.panel;
            Rectangle { width: 100%; height: 1px; y: 0; background: Theme.border; }
            HorizontalLayout {
                padding-left: 10px; padding-right: 10px; spacing: 16px; alignment: start;
                Text { text: root.connected ? (I18n.en ? "● Connected" : "● 已连接") : (I18n.en ? "○ Disconnected" : "○ 未连接"); color: root.connected ? Theme.ok : Theme.text-dim; font-size: Theme.fs-sm; vertical-alignment: center; }
                Text { text: root.running ? (I18n.en ? "Measuring" : "测量中") : (I18n.en ? "Stopped" : "已停止"); color: root.running ? Theme.ok : Theme.text-dim; font-size: Theme.fs-sm; vertical-alignment: center; }
                Text { text: (I18n.en ? "Mode: " : "模式: ") + (root.mode-trace ? "Trace" : (I18n.en ? "Group" : "分组")); font-size: Theme.fs-sm; color: Theme.text-dim; vertical-alignment: center; }
                Text { text: (I18n.en ? "Shown " : "显示 ") + root.shown-count + (I18n.en ? " / total " : " / 总 ") + root.total-count; font-size: Theme.fs-sm; color: Theme.text-dim; vertical-alignment: center; }
                Text { text: (I18n.en ? "Sel: " : "选中: ") + root.sel-id; font-size: Theme.fs-sm; color: Theme.text-dim; vertical-alignment: center; }
                Rectangle { horizontal-stretch: 1; }
                Text { text: "Rx " + root.rx-count + "  Tx " + root.tx-count + "  Err " + root.err-count; font-size: Theme.fs-sm; color: Theme.text-dim; vertical-alignment: center; }
                Text { text: "FPS " + root.fps + (I18n.en ? "  Load " : "  负载 ") + root.bus-load; font-size: Theme.fs-sm; color: Theme.accent; vertical-alignment: center; }
                if root.chan-load != "": Text { text: root.chan-load; max-width: 300px; overflow: elide; font-size: Theme.fs-sm; color: Theme.text-dim; vertical-alignment: center; }
            }
        }
    }
}

// ======================= 数据回放窗口（独立窗口） =======================

export component PlaybackWindow inherits Window {
    title: I18n.en ? "PcanWork - Playback" : "PcanWork - 数据回放";
    icon: @image-url("logo.svg");
    preferred-width: 760px;
    preferred-height: 360px;
    min-width: 560px;
    background: Theme.bg;

    in property <string> file-name: "(未选择文件)";
    in property <string> pos: "0";
    in property <string> total: "0";
    in property <bool> playing: false;
    in property <string> status: "就绪";
    in property <string> src-channels: "-";
    in-out property <string> channel-map: "";

    in-out property <bool> online: false;
    in-out property <bool> speed-fast: false;
    in-out property <bool> loop-play: false;
    in-out property <string> rate: "1";
    in-out property <string> id-lo: "";
    in-out property <string> id-hi: "";
    in-out property <string> seg-start: "";
    in-out property <string> seg-end: "";

    in-out property <bool> merge-concat: false;   // 多文件合并：false=按时间戳交错，true=顺序拼接
    in property <[PbFileRow]> pb-files: [];        // 已载入文件列表（名称+帧数）
    in-out property <bool> files-expanded: false;  // 文件列表是否展开
    callback open-file();
    callback add-file();
    callback remerge();
    callback clear-files();
    callback remove-file(int);
    callback move-file-up(int);
    callback move-file-down(int);
    callback apply-settings();
    callback play();
    callback step();
    callback pause();
    callback cancel();
    callback seek(float);

    VerticalLayout {
        padding: 12px;
        spacing: 10px;

        // file row
        Rectangle {
            height: 40px; background: Theme.panel; border-width: 1px; border-color: Theme.border;
            HorizontalLayout {
                padding: 6px; spacing: 8px;
                Button { text: I18n.en ? "Open (multi)" : "打开文件(可多选)"; clicked => { root.open-file(); } }
                Button { text: I18n.en ? "Add" : "添加"; clicked => { root.add-file(); } }
                Button { text: I18n.en ? "Clear" : "清空已载入"; clicked => { root.clear-files(); } }
                Button { text: (root.files-expanded ? (I18n.en ? "Hide list" : "收起列表") : (I18n.en ? "File list" : "文件列表")) + " (" + root.pb-files.length + ")"; clicked => { root.files-expanded = !root.files-expanded; } }
                Text { text: root.file-name; vertical-alignment: center; font-size: 13px; color: Theme.text; overflow: elide; horizontal-stretch: 1; }
            }
        }

        // expandable file list (reorder for concat / remove single)
        if root.files-expanded: Rectangle {
            height: 132px; background: Theme.panel; border-width: 1px; border-color: Theme.border;
            ListView {
                for f[i] in root.pb-files: Rectangle {
                    height: 28px;
                    background: Math.mod(i, 2) == 0 ? Theme.panel : Theme.zebra;
                    HorizontalLayout {
                        padding-left: 8px; padding-right: 6px; spacing: 6px;
                        Text { text: (i + 1) + ". " + f.name; vertical-alignment: center; font-size: 13px; color: Theme.text; overflow: elide; horizontal-stretch: 1; }
                        Text { text: f.count; width: 70px; vertical-alignment: center; horizontal-alignment: right; font-size: 12px; color: Theme.text-dim; }
                        TBtn { boxed: true; h: 22px; text: I18n.en ? "Up" : "上移"; clicked => { root.move-file-up(i); } }
                        TBtn { boxed: true; h: 22px; text: I18n.en ? "Dn" : "下移"; clicked => { root.move-file-down(i); } }
                        TBtn { boxed: true; h: 22px; text: I18n.en ? "Del" : "移除"; clicked => { root.remove-file(i); } }
                    }
                }
            }
        }

        // mode + speed
        Rectangle {
            height: 36px;
            HorizontalLayout {
                spacing: 16px;
                CheckBox { text: I18n.en ? "Online playback (send to bus, else offline only)" : "在线回放（发送到总线，否则仅离线显示）"; checked: root.online; toggled => { root.online = self.checked; } }
                CheckBox { text: I18n.en ? "As fast as possible" : "尽可能快"; checked: root.speed-fast; toggled => { root.speed-fast = self.checked; } }
                Text { text: I18n.en ? "Speed" : "倍率"; vertical-alignment: center; font-size: 13px; }
                LineEdit { width: 70px; text: root.rate; enabled: !root.speed-fast; edited(v) => { root.rate = v; } }
                CheckBox { text: I18n.en ? "Concat (else interleave by time)" : "多文件:顺序拼接（默认按时间戳交错）"; checked: root.merge-concat; toggled => { root.merge-concat = self.checked; root.remerge(); } }
            }
        }

        // channel mapping
        Rectangle {
            height: 40px; background: Theme.panel; border-width: 1px; border-color: Theme.border;
            HorizontalLayout {
                padding: 6px; spacing: 8px;
                Text { text: (I18n.en ? "File channels: " : "文件通道: ") + root.src-channels; vertical-alignment: center; font-size: 13px; color: Theme.text; }
                Rectangle { width: 10px; }
                Text { text: I18n.en ? "Channel map" : "通道映射"; vertical-alignment: center; font-size: 13px; }
                LineEdit { width: 200px; placeholder-text: I18n.en ? "e.g. 1:2,2:1  (:0 drops)" : "如 1:2,2:1（:0 丢弃）"; text: root.channel-map; edited(v) => { root.channel-map = v; } }
                Text { text: I18n.en ? "empty=keep original" : "留空=保持原通道"; vertical-alignment: center; font-size: 12px; color: Theme.text-dim; }
            }
        }

        // filter + segment
        Rectangle {
            height: 40px; background: Theme.panel; border-width: 1px; border-color: Theme.border;
            HorizontalLayout {
                padding: 6px; spacing: 8px;
                Text { text: I18n.en ? "ID filter(hex)" : "ID过滤(hex)"; vertical-alignment: center; font-size: 13px; }
                LineEdit { width: 90px; placeholder-text: I18n.en ? "from 0" : "起 0"; text: root.id-lo; edited(v) => { root.id-lo = v; } }
                Text { text: "-"; vertical-alignment: center; }
                LineEdit { width: 90px; placeholder-text: I18n.en ? "to 7FF" : "止 7FF"; text: root.id-hi; edited(v) => { root.id-hi = v; } }
                Rectangle { width: 10px; }
                Text { text: I18n.en ? "Time range(s)" : "时间段(s)"; vertical-alignment: center; font-size: 13px; }
                LineEdit { width: 70px; placeholder-text: I18n.en ? "from" : "起"; text: root.seg-start; edited(v) => { root.seg-start = v; } }
                Text { text: "-"; vertical-alignment: center; }
                LineEdit { width: 70px; placeholder-text: I18n.en ? "to" : "止"; text: root.seg-end; edited(v) => { root.seg-end = v; } }
                Button { text: I18n.en ? "Apply/Reload" : "应用/重载"; clicked => { root.apply-settings(); } }
            }
        }

        // controls
        Rectangle {
            height: 40px;
            HorizontalLayout {
                spacing: 8px;
                Button { text: root.playing ? (I18n.en ? "Playing..." : "回放中...") : (I18n.en ? "Play" : "正常回放"); enabled: !root.playing; clicked => { root.play(); } }
                Button { text: I18n.en ? "Step" : "步进"; clicked => { root.step(); } }
                Button { text: I18n.en ? "Pause" : "暂停"; clicked => { root.pause(); } }
                Button { text: I18n.en ? "Cancel" : "取消"; clicked => { root.cancel(); } }
                CheckBox { text: I18n.en ? "Loop" : "循环回放"; checked: root.loop-play; toggled => { root.loop-play = self.checked; } }
            }
        }

        // progress bar（可点击跳转）
        Rectangle {
            height: 22px; background: Theme.panel2; border-radius: 4px;
            Rectangle {
                x: 0; height: 100%; border-radius: 4px;
                width: parent.width * (root.total == "0" ? 0 : (root.pos.to-float() / max(1, root.total.to-float())));
                background: Theme.accent;
            }
            Text {
                text: root.pos + " / " + root.total;
                x: 8px; vertical-alignment: center; font-size: 12px; font-family: Theme.mono; color: Theme.text;
            }
            TouchArea {
                mouse-cursor: pointer;
                clicked => { root.seek(self.mouse-x / self.width); }
            }
        }

        // status
        Rectangle {
            vertical-stretch: 1;
            Text {
                text: (I18n.en ? "Status: " : "状态: ") + root.status + (root.playing ? (I18n.en ? " (playing)" : "（回放中）") : "");
                x: 4px; y: 6px; color: Theme.text-dim; font-size: 12px;
            }
        }
    }
}

// ======================= Record file conversion window =======================

// Small tab-selector button used by ConvertWindow.
component ConvTab inherits Rectangle {
    in property <string> label;
    in property <bool> active;
    callback clicked();
    height: 32px;
    width: 110px;
    border-radius: 4px;
    border-width: 1px;
    border-color: Theme.border;
    background: active ? Theme.accent : Theme.panel2;
    Text {
        text: label;
        vertical-alignment: center;
        horizontal-alignment: center;
        font-size: 13px;
        color: active ? #ffffff : Theme.text;
    }
    TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
}

// 报文日志帮助：展示下位机 printf-over-CAN 的 C 实现(只读 TextEdit, 可全选复制)
export component ConsoleHelpWindow inherits Window {
    title: I18n.en ? "PcanWork - printf-over-CAN (MCU firmware)" : "PcanWork - 下位机 printf-over-CAN 实现";
    icon: @image-url("logo.svg");
    preferred-width: 780px;
    preferred-height: 620px;
    background: Theme.bg;

    in property <string> help-text;

    VerticalLayout {
        padding: 10px;
        spacing: 8px;
        Text {
            text: I18n.en
                ? "Copy the C below into your MCU firmware. CAN_LOG_ID must match the ID box in the CAN Console panel."
                : "把下面的 C 代码抄进下位机固件。CAN_LOG_ID 要和「报文日志」面板里填的 ID 一致。";
            wrap: word-wrap; color: Theme.text; font-size: Theme.fs;
        }
        Rectangle {
            vertical-stretch: 1;
            background: Theme.panel; border-width: 1px; border-color: Theme.border;
            TextEdit {
                width: 100%; height: 100%;
                text: root.help-text;
                read-only: true;
                font-size: 12px;
            }
        }
        Text {
            text: I18n.en ? "Tip: click in the text, then Ctrl+A and Ctrl+C to copy all."
                         : "提示：在文本里点一下，Ctrl+A 全选，Ctrl+C 复制。";
            color: Theme.text-dim; font-size: Theme.fs-sm;
        }
    }
}

export component ConvertWindow inherits Window {
    title: I18n.en ? "PcanWork - Record File Conversion" : "PcanWork - 记录文件转换";
    icon: @image-url("logo.svg");
    preferred-width: 660px;
    preferred-height: 420px;
    background: Theme.bg;

    in-out property <int> tab: 0; // 0=single format, 1=batch, 2=signal merge

    // single-file conversion (full paths held directly in these props)
    in-out property <string> src-file: "";
    in-out property <int> fmt1: 1; // 0=CSV 1=ASC 2=BLF
    in property <string> status1: "";

    // batch conversion
    in-out property <string> src-dir: "";
    in-out property <string> out-dir: "";
    in-out property <int> fmt2: 1;
    in property <string> status2: "";

    callback pick-src-file();
    callback do-convert();
    callback pick-src-dir();
    callback pick-out-dir();
    callback do-batch();

    VerticalLayout {
        padding: 12px;
        spacing: 10px;

        // tabs
        HorizontalLayout {
            spacing: 6px;
            ConvTab { label: I18n.en ? "Format" : "格式转换"; active: root.tab == 0; clicked => { root.tab = 0; } }
            ConvTab { label: I18n.en ? "Batch" : "批量转换"; active: root.tab == 1; clicked => { root.tab = 1; } }
            ConvTab { label: I18n.en ? "Signal merge" : "信号合并"; active: root.tab == 2; clicked => { root.tab = 2; } }
            Rectangle { horizontal-stretch: 1; }
        }

        // ---- tab 0: single-file format conversion ----
        if root.tab == 0: VerticalLayout {
            spacing: 10px;
            Rectangle {
                height: 40px; background: Theme.panel; border-width: 1px; border-color: Theme.border;
                HorizontalLayout {
                    padding: 6px; spacing: 8px;
                    Button { text: I18n.en ? "Source file" : "源文件"; clicked => { root.pick-src-file(); } }
                    Text {
                        text: root.src-file == "" ? (I18n.en ? "(no file selected)" : "(未选择文件)") : root.src-file;
                        vertical-alignment: center; font-size: 13px; color: Theme.text; overflow: elide; horizontal-stretch: 1;
                    }
                }
            }
            HorizontalLayout {
                spacing: 8px;
                Text { text: I18n.en ? "Target format" : "目标格式"; vertical-alignment: center; font-size: 13px; }
                ComboBox { width: 120px; model: ["CSV", "ASC", "BLF"]; current-index <=> root.fmt1; }
                Button { text: I18n.en ? "Convert" : "格式转换"; clicked => { root.do-convert(); } }
            }
            Text {
                text: I18n.en ? "Supported: CSV / Vector ASC / BLF interconversion." : "支持范围：CSV / Vector ASC / BLF 互相转换。";
                font-size: 12px; color: Theme.text-dim;
            }
            Rectangle {
                vertical-stretch: 1; background: Theme.panel2; border-radius: 4px;
                Text { x: 8px; y: 8px; text: root.status1; color: Theme.text; font-size: 12px; wrap: word-wrap; width: parent.width - 16px; }
            }
        }

        // ---- tab 1: batch folder conversion ----
        if root.tab == 1: VerticalLayout {
            spacing: 10px;
            Rectangle {
                height: 40px; background: Theme.panel; border-width: 1px; border-color: Theme.border;
                HorizontalLayout {
                    padding: 6px; spacing: 8px;
                    Button { text: I18n.en ? "Source folder" : "源目录"; clicked => { root.pick-src-dir(); } }
                    Text {
                        text: root.src-dir == "" ? (I18n.en ? "(no folder selected)" : "(未选择目录)") : root.src-dir;
                        vertical-alignment: center; font-size: 13px; color: Theme.text; overflow: elide; horizontal-stretch: 1;
                    }
                }
            }
            Rectangle {
                height: 40px; background: Theme.panel; border-width: 1px; border-color: Theme.border;
                HorizontalLayout {
                    padding: 6px; spacing: 8px;
                    Button { text: I18n.en ? "Target folder" : "目标目录"; clicked => { root.pick-out-dir(); } }
                    Text {
                        text: root.out-dir == "" ? (I18n.en ? "(no folder selected)" : "(未选择目录)") : root.out-dir;
                        vertical-alignment: center; font-size: 13px; color: Theme.text; overflow: elide; horizontal-stretch: 1;
                    }
                }
            }
            HorizontalLayout {
                spacing: 8px;
                Text { text: I18n.en ? "Target format" : "目标格式"; vertical-alignment: center; font-size: 13px; }
                ComboBox { width: 120px; model: ["CSV", "ASC", "BLF"]; current-index <=> root.fmt2; }
                Button { text: I18n.en ? "Start" : "启动转换"; clicked => { root.do-batch(); } }
            }
            ScrollView {
                vertical-stretch: 1;
                Text { x: 8px; y: 8px; text: root.status2; color: Theme.text; font-size: 12px; font-family: Theme.mono; wrap: word-wrap; width: parent.width - 16px; }
            }
        }

        // ---- tab 2: signal merge (not supported in this build) ----
        if root.tab == 2: VerticalLayout {
            spacing: 10px;
            Rectangle {
                vertical-stretch: 1; background: Theme.panel2; border-radius: 4px;
                Text {
                    x: 12px; y: 12px; width: parent.width - 24px; wrap: word-wrap;
                    color: Theme.text-dim; font-size: 13px;
                    text: I18n.en
                        ? "Signal merge requires MAT / Signal MF4 read-write support, which is not available in this build. Only CSV / ASC / BLF format and batch conversion are supported."
                        : "信号合并需要 MAT / Signal MF4 读写支持，本版本暂未实现。当前仅支持 CSV / ASC / BLF 的格式转换与批量转换。";
                }
            }
        }
    }
}

// ======================= 缓存设置窗口 =======================

export component CacheConfigWindow inherits Window {
    title: I18n.en ? "Cache Settings" : "缓存设置";
    icon: @image-url("logo.svg");
    preferred-width: 480px;
    preferred-height: 280px;
    background: Theme.bg;

    in-out property <string> trace-cap: "100000";
    in-out property <string> chart-cap: "10000";
    callback apply-cache(string, string);
    callback cancel();

    VerticalLayout {
        padding: 16px; spacing: 12px;
        Text { text: I18n.en ? "Adjust cache limits — balance history depth vs memory/smoothness" : "调整缓存上限，平衡历史深度与内存/流畅度"; font-size: Theme.fs; font-weight: 700; color: Theme.text; }
        GridLayout {
            spacing: 10px;
            Row {
                Text { text: I18n.en ? "Raw frame cache (frames)" : "报文原始缓存(帧)"; font-size: 14px; vertical-alignment: center; }
                LineEdit { text: root.trace-cap; width: 180px; edited(v) => { root.trace-cap = v; } }
            }
            Row {
                Text { text: I18n.en ? "Chart points / signal" : "曲线点数 / 信号"; font-size: 14px; vertical-alignment: center; }
                LineEdit { text: root.chart-cap; width: 180px; edited(v) => { root.chart-cap = v; } }
            }
        }
        Rectangle { vertical-stretch: 1;
            Text {
                text: I18n.en ? "100k frames ≈ 15–25MB RAM. Smaller = less memory & smoother; larger = longer history. Chart keeps 10k points per signal by default." : "10 万帧约占 15–25MB 内存。调小更省内存、更流畅；调大可保留更长历史。曲线每信号默认 1 万点。";
                x: 2px; y: 4px; width: parent.width - 4px; color: Theme.text-dim; font-size: 12px; wrap: word-wrap;
            }
        }
        Rectangle {
            height: 36px;
            HorizontalLayout {
                spacing: 8px;
                Rectangle { horizontal-stretch: 1; }
                Button { text: I18n.en ? "Apply" : "应用"; clicked => { root.apply-cache(root.trace-cap, root.chart-cap); } }
                Button { text: I18n.en ? "Cancel" : "取消"; clicked => { root.cancel(); } }
            }
        }
    }
}

// ======================= 触发器窗口 =======================

export component TriggerWindow inherits Window {
    title: I18n.en ? "Trigger" : "触发器";
    icon: @image-url("logo.svg");
    preferred-width: 680px;
    preferred-height: 300px;
    min-width: 520px;
    background: Theme.bg;

    in property <bool> armed: false;
    in-out property <int> trig-cond: 0;   // 0=ID等于 1=数据字节等于 2=错误帧
    in-out property <string> trig-id: "100";
    in-out property <string> trig-off: "0";
    in-out property <string> trig-val: "00";
    in-out property <int> trig-action: 0; // 0=报警 1=开始记录 2=停止记录 3=发送报文
    in-out property <string> send-id: "200";
    in-out property <string> send-data: "00 11 22 33";
    in-out property <bool> send-ext: false;
    in-out property <bool> send-fd: false;
    callback trig-apply();
    callback trig-disarm();

    VerticalLayout {
        padding: 16px; spacing: 12px;
        Text { text: I18n.en ? "Trigger: auto-run an action when the condition matches (Alarm / Start rec / Stop rec / Send frame)" : "触发器：满足条件时自动执行动作（报警 / 开始记录 / 停止记录 / 发送报文）"; font-weight: 700; font-size: Theme.fs; color: Theme.text; }
        GridLayout {
            spacing: 8px;
            Row {
                Text { text: I18n.en ? "Condition:" : "条件类型:"; width: 90px; font-weight: 700; font-size: Theme.fs; vertical-alignment: center; color: Theme.text; }
                ComboBox { width: 200px; height: Theme.ctrl-h; model: ["ID 等于", "数据字节等于", "错误帧"]; current-index <=> root.trig-cond; }
                Rectangle { }
            }
            Row {
                Text { text: "ID:0x"; width: 90px; font-weight: 700; font-size: Theme.fs; vertical-alignment: center; color: Theme.text; }
                LineEdit { text: root.trig-id; width: 120px; height: Theme.ctrl-h; edited(v) => { root.trig-id = v; } }
                Text { text: I18n.en ? "Byte off:" : "字节偏移:"; width: 90px; font-weight: 700; font-size: Theme.fs; vertical-alignment: center; color: Theme.text; }
                LineEdit { text: root.trig-off; width: 80px; height: Theme.ctrl-h; edited(v) => { root.trig-off = v; } }
                Text { text: I18n.en ? "Byte val:0x" : "字节值:0x"; width: 90px; font-weight: 700; font-size: Theme.fs; vertical-alignment: center; color: Theme.text; }
                LineEdit { text: root.trig-val; width: 80px; height: Theme.ctrl-h; edited(v) => { root.trig-val = v; } }
            }
            Row {
                Text { text: I18n.en ? "Action:" : "动作:"; width: 90px; font-weight: 700; font-size: Theme.fs; vertical-alignment: center; color: Theme.text; }
                ComboBox { width: 200px; height: Theme.ctrl-h; model: I18n.en ? ["Alarm(log)", "Start rec(CSV)", "Stop rec", "Send frame"] : ["报警(日志)", "开始记录(CSV)", "停止记录", "发送报文"]; current-index <=> root.trig-action; }
                Rectangle { }
            }
            Row {
                Text { text: I18n.en ? "Send ID:0x" : "发送ID:0x"; width: 90px; font-weight: 700; font-size: Theme.fs; vertical-alignment: center; color: Theme.text; }
                LineEdit { text: root.send-id; width: 120px; height: Theme.ctrl-h; enabled: root.trig-action == 3; edited(v) => { root.send-id = v; } }
                Text { text: I18n.en ? "Send data:" : "发送数据:"; width: 90px; font-weight: 700; font-size: Theme.fs; vertical-alignment: center; color: Theme.text; }
                LineEdit { text: root.send-data; width: 200px; height: Theme.ctrl-h; enabled: root.trig-action == 3; placeholder-text: "00 11 22"; edited(v) => { root.send-data = v; } }
            }
            Row {
                Text { text: I18n.en ? "Send opts:" : "发送选项:"; width: 90px; font-weight: 700; font-size: Theme.fs; vertical-alignment: center; color: Theme.text; }
                CheckBox { text: I18n.en ? "Extended" : "扩展帧"; checked <=> root.send-ext; enabled: root.trig-action == 3; }
                CheckBox { text: "CAN FD"; checked <=> root.send-fd; enabled: root.trig-action == 3; }
                Rectangle { }
            }
        }
        Text {
            text: root.armed ? (I18n.en ? "● Armed: action fires when condition matches (300ms throttle)" : "● 已布防：条件满足时将执行动作（命中节流 300ms）") : (I18n.en ? "○ Disarmed" : "○ 未布防");
            font-size: Theme.fs; color: root.armed ? Theme.ok : Theme.text-dim;
        }
        Rectangle { vertical-stretch: 1;
            Text {
                text: I18n.en ? "Byte-equals: fires when the byte at the given offset equals the value. Error frame: fires on an error frame.\nStart-record writes to trigger_record.csv next to the exe. No hardware needed — verify with simulated data." : "数据字节等于：第「字节偏移」个字节等于「字节值」时触发。错误帧：收到错误帧时触发。\n开始记录写到 exe 目录 trigger_record.csv。无需硬件，模拟数据即可验证。";
                x: 2px; y: 2px; width: parent.width - 4px; color: Theme.text-dim; font-size: 12px; wrap: word-wrap;
            }
        }
        Rectangle {
            height: 36px;
            HorizontalLayout {
                spacing: 8px;
                Rectangle { horizontal-stretch: 1; }
                Button { text: I18n.en ? "Arm / Apply" : "布防 / 应用"; clicked => { root.trig-apply(); } }
                Button { text: I18n.en ? "Disarm" : "撤防"; clicked => { root.trig-disarm(); } }
            }
        }
    }
}

// ======================= 仿真面板窗口 =======================

// 画布上单个控件的图形渲染(按 kind 切换)
component SimGlyph inherits Rectangle {
    in property <SimRow> w;
    // 指示灯
    if w.kind == 0: Rectangle {
        Rectangle {
            width: min(parent.width, parent.height) - 34px; height: self.width; border-radius: self.width / 2;
            x: (parent.width - self.width) / 2; y: 6px;
            background: w.on ? Theme.ok : Theme.text-dim;
            border-width: 2px; border-color: w.on ? #ffffff80 : Theme.border;
            drop-shadow-blur: w.on ? 8px : 0px; drop-shadow-color: Theme.ok;
        }
        Text { text: w.name; y: parent.height - 18px; width: 100%; horizontal-alignment: center; font-size: 11px; color: Theme.text; }
    }
    // 仪表盘(圆盘 + 沿弧移动的指示珠 + 中心读数)
    if w.kind == 1: Rectangle {
        dial := Rectangle {
            width: min(parent.width, parent.height) - 28px; height: self.width; border-radius: self.width / 2;
            x: (parent.width - self.width) / 2; y: 4px;
            background: Theme.panel2; border-width: 2px; border-color: Theme.border;
            // 量程 0 弧端标记(左下)
            Rectangle { width: 6px; height: 6px; border-radius: 3px; background: Theme.text-dim;
                x: parent.width / 2 - 3px + (parent.width / 2 - 12px) * sin(-120deg);
                y: parent.height / 2 - 3px - (parent.height / 2 - 12px) * cos(-120deg);
            }
            // 量程 max 弧端标记(右下)
            Rectangle { width: 6px; height: 6px; border-radius: 3px; background: Theme.text-dim;
                x: parent.width / 2 - 3px + (parent.width / 2 - 12px) * sin(120deg);
                y: parent.height / 2 - 3px - (parent.height / 2 - 12px) * cos(120deg);
            }
            // 指示珠(沿 240° 弧移动)
            Rectangle { width: 13px; height: 13px; border-radius: 7px; background: Theme.accent; border-width: 2px; border-color: #ffffff80;
                x: parent.width / 2 - 7px + (parent.width / 2 - 14px) * sin(-120deg + 240deg * w.level);
                y: parent.height / 2 - 7px - (parent.height / 2 - 14px) * cos(-120deg + 240deg * w.level);
            }
            // 中心读数
            Text { text: w.status; width: 100%; height: 100%; horizontal-alignment: center; vertical-alignment: center; font-size: 14px; font-weight: 700; font-family: Theme.mono; color: Theme.accent; }
        }
        Text { text: w.name; y: parent.height - 16px; width: 100%; horizontal-alignment: center; font-size: 10px; color: Theme.text-dim; }
    }
    // 进度条
    if w.kind == 2: VerticalLayout {
        padding: 6px; spacing: 3px;
        Text { text: w.name; font-size: 11px; color: Theme.text-dim; }
        Rectangle {
            height: 16px; background: Theme.panel2; border-radius: 4px; border-width: 1px; border-color: Theme.border;
            Rectangle { x: 0; y: 0; height: parent.height; width: parent.width * w.level; background: Theme.accent; border-radius: 4px; }
        }
        Text { text: w.status; font-size: 11px; color: Theme.text; horizontal-alignment: right; }
    }
    // 数值
    if w.kind == 3: VerticalLayout {
        padding: 4px;
        Text { text: w.name; font-size: 11px; color: Theme.text-dim; horizontal-alignment: w.align == 0 ? TextHorizontalAlignment.left : w.align == 2 ? TextHorizontalAlignment.right : TextHorizontalAlignment.center; }
        Text { text: w.status; font-size: 22px; font-weight: 700; font-family: Theme.mono; color: Theme.accent; horizontal-alignment: w.align == 0 ? TextHorizontalAlignment.left : w.align == 2 ? TextHorizontalAlignment.right : TextHorizontalAlignment.center; vertical-alignment: center; }
    }
    // 标签
    if w.kind == 4: Text { text: w.name; width: 100%; height: 100%; horizontal-alignment: w.align == 0 ? TextHorizontalAlignment.left : w.align == 2 ? TextHorizontalAlignment.right : TextHorizontalAlignment.center; vertical-alignment: center; font-size: 14px; font-weight: 700; color: Theme.text; }
    // 按钮
    if w.kind == 5: Rectangle {
        background: Theme.accent; border-radius: 5px;
        Text { text: w.name; width: 100%; height: 100%; horizontal-alignment: center; vertical-alignment: center; font-size: 13px; font-weight: 700; color: white; }
    }
    // 滑块
    if w.kind == 6: VerticalLayout {
        padding: 6px; spacing: 3px;
        Text { text: w.name + ": " + w.status; font-size: 11px; color: Theme.text; }
        Rectangle {
            height: 18px;
            Rectangle { y: (parent.height - 4px) / 2; height: 4px; width: 100%; background: Theme.panel2; border-radius: 2px; }
            Rectangle {
                width: 14px; height: 14px; border-radius: 7px;
                x: (parent.width - self.width) * w.level; y: (parent.height - self.height) / 2;
                background: Theme.accent; border-width: 1px; border-color: #ffffff80;
            }
        }
    }
    // 信号发生器
    if w.kind == 7: VerticalLayout {
        padding: 6px; spacing: 2px;
        HorizontalLayout {
            spacing: 4px;
            Text { text: "∿"; font-size: 16px; color: Theme.accent; }
            Text { text: w.name; font-size: 12px; font-weight: 700; color: Theme.text; }
        }
        Text { text: w.info + " = " + w.status; font-size: 11px; color: Theme.text-dim; }
    }
}

export component SimPanelWindow inherits Window {
    title: I18n.en ? "Simulation Panel" : "仿真面板";
    icon: @image-url("logo.svg");
    preferred-width: 1000px;
    preferred-height: 660px;
    background: Theme.bg;

    in property <[SimRow]> sim-widgets;
    in property <bool> running: false;

    callback sim-add(int);
    callback sim-select(int, bool);           // (index, 是否 Ctrl 追加多选)
    callback sim-edit(int);                    // 双击 → 打开独立属性窗口
    callback sim-drag(int, length, length);
    // sim-resize 传绝对尺寸(指针相对控件左上角=目标宽高), 避免增量反馈半速
    callback sim-resize(int, float, float);
    callback sim-clear();
    callback sim-run-toggle();
    callback sim-button(int, bool);           // 运行模式按钮 按下(true)/释放(false)
    callback sim-slider(int, float);
    callback sim-select-all();                 // 全选
    callback sim-align(int);                   // 对齐: 0左 1右 2顶 3底 4水平居中 5垂直居中

    VerticalLayout {
        // 顶部工具栏
        Rectangle {
            height: 40px; background: Theme.panel;
            Rectangle { width: 100%; height: 1px; y: parent.height - 1px; background: Theme.border; }
            HorizontalLayout {
                padding-left: 8px; padding-right: 8px; spacing: 4px;
                Text { text: root.running ? (I18n.en ? "Running (locked)" : "运行中(已锁定)") : (I18n.en ? "Edit mode" : "编辑模式"); font-weight: 700; font-size: Theme.fs; color: root.running ? Theme.ok : Theme.text; vertical-alignment: center; }
                Rectangle { width: 8px; }
                // 控件调色板(编辑模式) — 横向滚动, Clear/Run 常驻右侧
                ScrollView { horizontal-stretch: 1; HorizontalLayout { spacing: 4px;
                Button { text: I18n.en ? "Indicator" : "指示灯"; enabled: !root.running; clicked => { root.sim-add(0); } }
                Button { text: I18n.en ? "Dial" : "仪表盘"; enabled: !root.running; clicked => { root.sim-add(1); } }
                Button { text: I18n.en ? "Bar" : "进度条"; enabled: !root.running; clicked => { root.sim-add(2); } }
                Button { text: I18n.en ? "Value" : "数值"; enabled: !root.running; clicked => { root.sim-add(3); } }
                Button { text: I18n.en ? "Label" : "标签"; enabled: !root.running; clicked => { root.sim-add(4); } }
                Button { text: I18n.en ? "Button" : "按钮"; enabled: !root.running; clicked => { root.sim-add(5); } }
                Button { text: I18n.en ? "Slider" : "滑块"; enabled: !root.running; clicked => { root.sim-add(6); } }
                Button { text: I18n.en ? "Generator" : "发生器"; enabled: !root.running; clicked => { root.sim-add(7); } }
                } }
                Button { text: I18n.en ? "Clear" : "清空"; enabled: !root.running; clicked => { root.sim-clear(); } }
                Button { text: root.running ? (I18n.en ? "Stop Sim" : "停止仿真") : (I18n.en ? "Run Sim" : "运行仿真"); clicked => { root.sim-run-toggle(); } }
            }
        }
        // 对齐工具栏(编辑模式): 全选 + 6 种对齐
        if !root.running: Rectangle {
            height: 36px; background: Theme.panel2;
            Rectangle { width: 100%; height: 1px; y: parent.height - 1px; background: Theme.border; }
            HorizontalLayout {
                padding-left: 8px; padding-right: 8px; spacing: 4px;
                Text { text: I18n.en ? "Align:" : "对齐:"; font-size: Theme.fs-sm; vertical-alignment: center; color: Theme.text-dim; }
                ScrollView { horizontal-stretch: 1; HorizontalLayout { spacing: 4px;
                Button { text: I18n.en ? "Select All" : "全选"; clicked => { root.sim-select-all(); } }
                Rectangle { width: 6px; }
                Button { text: I18n.en ? "Left" : "左对齐"; clicked => { root.sim-align(0); } }
                Button { text: I18n.en ? "Right" : "右对齐"; clicked => { root.sim-align(1); } }
                Button { text: I18n.en ? "Top" : "顶部对齐"; clicked => { root.sim-align(2); } }
                Button { text: I18n.en ? "Bottom" : "底部对齐"; clicked => { root.sim-align(3); } }
                Button { text: I18n.en ? "Center H" : "水平居中"; clicked => { root.sim-align(4); } }
                Button { text: I18n.en ? "Center V" : "垂直居中"; clicked => { root.sim-align(5); } }
                Rectangle { width: 6px; }
                Button { text: I18n.en ? "Equal W" : "等宽"; clicked => { root.sim-align(6); } }
                Button { text: I18n.en ? "Equal H" : "等高"; clicked => { root.sim-align(7); } }
                } }
                Rectangle { width: 12px; }
                Text { text: I18n.en ? "Tip: click=select / Ctrl+click=multi / dbl-click=edit" : "提示: 单击选中 / Ctrl+单击多选 / 双击编辑属性"; font-size: Theme.fs-sm; vertical-alignment: center; color: Theme.text-dim; }
            }
        }
        // 画布(全宽)
        Rectangle {
            background: Theme.bg; clip: true;
            // 空提示
            if root.sim-widgets.length == 0: Text {
                text: I18n.en ? "Blank canvas: add controls from the toolbar, drag to place, double-click a control to edit & bind a DBC signal, then click \"Run Sim\" to lock & go live." : "空白画布：点上方控件按钮添加，拖动摆放，双击控件编辑属性绑定 DBC 信号，点「运行仿真」锁定并联动。";
                width: 100%; height: 100%; horizontal-alignment: center; vertical-alignment: center;
                color: Theme.text-dim; font-size: Theme.fs;
            }
            for w[i] in root.sim-widgets: Rectangle {
                x: w.x * 1px; y: w.y * 1px; width: w.w * 1px; height: w.h * 1px;
                background: w.kind == 4 ? transparent : Theme.panel;
                border-width: w.primary ? 3px : (w.selected ? 2px : (w.kind == 4 ? 0px : 1px));
                border-color: w.primary ? Theme.ok : (w.selected ? Theme.accent : Theme.border);
                border-radius: 5px;
                drop-shadow-blur: w.selected ? 6px : 2px; drop-shadow-color: #00000022;

                SimGlyph { width: 100%; height: 100%; w: w; }

                // 主控件(模板)角标：等高/等宽以它为基准
                if w.primary: Rectangle {
                    x: 0; y: 0; width: 44px; height: 16px;
                    background: Theme.ok; border-radius: 3px;
                    Text { text: I18n.en ? "Ref" : "模板"; width: 100%; height: 100%; horizontal-alignment: center; vertical-alignment: center; color: white; font-size: 11px; }
                }

                // 编辑模式：拖动/缩放 + 选中(右下角 20px 内按下=缩放, 其余=移动; 双击=编辑属性)
                if !root.running: TouchArea {
                    width: 100%; height: 100%;
                    property <bool> resizing: false;
                    pointer-event(ev) => {
                        if (ev.button == PointerEventButton.left && ev.kind == PointerEventKind.down) {
                            root.sim-select(i, ev.modifiers.control);
                            self.resizing = (self.mouse-x > parent.width - 20px) && (self.mouse-y > parent.height - 20px);
                        }
                    }
                    double-clicked => { root.sim-edit(i); }
                    moved => {
                        if (self.pressed) {
                            if (self.resizing) {
                                // 绝对尺寸: 指针相对控件左上角(左上角拖动期间不变)=目标宽高
                                root.sim-resize(i, self.mouse-x / 1px, self.mouse-y / 1px);
                            } else {
                                root.sim-drag(i, self.mouse-x - self.pressed-x, self.mouse-y - self.pressed-y);
                            }
                        }
                    }
                }
                // 编辑模式：右下角缩放视觉手柄(纯提示, 不拦截事件)
                if !root.running: Rectangle {
                    width: 16px; height: 16px; x: parent.width - 16px; y: parent.height - 16px;
                    background: w.selected ? Theme.accent : Theme.border; border-radius: 3px;
                }
                // 运行模式：按钮 按下发「按下值」、释放发「释放值」
                if root.running && w.kind == 5: TouchArea {
                    width: 100%; height: 100%;
                    pointer-event(ev) => {
                        if (ev.button == PointerEventButton.left) {
                            if (ev.kind == PointerEventKind.down) { root.sim-button(i, true); }
                            if (ev.kind == PointerEventKind.up) { root.sim-button(i, false); }
                        }
                    }
                }
                // 运行模式：滑块可拖动设值(frac 对齐手柄行程, 消除偏移)
                if root.running && w.kind == 6: TouchArea {
                    width: 100%; height: 100%;
                    moved => { if (self.pressed) { root.sim-slider(i, ((self.mouse-x - 7px) / (parent.width - 14px)).clamp(0, 1)); } }
                    clicked => { root.sim-slider(i, ((self.mouse-x - 7px) / (parent.width - 14px)).clamp(0, 1)); }
                }
            }
        }
    }
}

// ======================= 仿真控件属性窗口(独立, 双击控件弹出, 所有控件共用) =======================

export component SimPropWindow inherits Window {
    title: I18n.en ? "Control Properties" : "控件属性";
    icon: @image-url("logo.svg");
    preferred-width: 320px;
    preferred-height: 600px;
    background: Theme.bg;

    in property <[string]> dbc-signals;
    in property <bool> has-sel: false;
    in-out property <string> p-name: "";
    in-out property <string> p-frame: "100";
    in-out property <string> p-signal: "";
    in-out property <string> p-bind: "";
    in-out property <int> p-kind: 0;
    in-out property <string> p-min: "0";
    in-out property <string> p-max: "100";
    in-out property <string> p-threshold: "0";
    in-out property <int> p-genmode: 0;
    in-out property <string> p-step: "1";
    in-out property <string> p-period: "100";
    in-out property <string> p-x: "0";
    in-out property <string> p-y: "0";
    in-out property <string> p-w: "100";
    in-out property <string> p-h: "60";
    in-out property <int> p-align: 1;
    in-out property <string> p-chan: "1";
    in-out property <string> p-pressval: "1";
    in-out property <string> p-releaseval: "0";
    callback prop-apply();
    callback prop-signal(int);
    callback prop-remove();

    VerticalLayout {
        padding: 10px; spacing: 6px;
        Text { text: I18n.en ? "Control Properties" : "控件属性"; font-weight: 700; font-size: Theme.fs; color: Theme.text; }
        if !root.has-sel: Text { text: I18n.en ? "Double-click a control on the canvas to edit. All controls share this window." : "双击画布上的控件以编辑其属性。所有控件共用此窗口。"; color: Theme.text-dim; font-size: Theme.fs-sm; wrap: word-wrap; }
        if root.has-sel: ScrollView {
            VerticalLayout {
                spacing: 6px;
                HorizontalLayout { spacing: 6px; Text { text: I18n.en ? "Name" : "名称"; width: 56px; vertical-alignment: center; font-size: Theme.fs-sm; color: Theme.text-dim; } LineEdit { height: Theme.ctrl-h; text: root.p-name; edited(v) => { root.p-name = v; } } }
                HorizontalLayout { spacing: 6px; Text { text: I18n.en ? "Signal" : "信号"; width: 56px; vertical-alignment: center; font-size: Theme.fs-sm; color: Theme.text-dim; } ComboBox { height: Theme.ctrl-h; model: root.dbc-signals; selected(v) => { root.prop-signal(self.current-index); } } }
                Text { text: (I18n.en ? "Bound: " : "当前绑定: ") + root.p-bind; font-size: Theme.fs-sm; color: Theme.accent; wrap: word-wrap; }
                HorizontalLayout { spacing: 6px; Text { text: I18n.en ? "Channel" : "通道"; width: 56px; vertical-alignment: center; font-size: Theme.fs-sm; color: Theme.text-dim; } LineEdit { height: Theme.ctrl-h; placeholder-text: I18n.en ? "CAN ch (from 1)" : "CAN 通道(1起)"; text: root.p-chan; edited(v) => { root.p-chan = v; } } }
                HorizontalLayout { spacing: 6px; Text { text: I18n.en ? "ID:0x" : "帧ID:0x"; width: 56px; vertical-alignment: center; font-size: Theme.fs-sm; color: Theme.text-dim; } LineEdit { height: Theme.ctrl-h; text: root.p-frame; edited(v) => { root.p-frame = v; } } }
                HorizontalLayout { spacing: 6px; Text { text: I18n.en ? "Sig name" : "信号名"; width: 56px; vertical-alignment: center; font-size: Theme.fs-sm; color: Theme.text-dim; } LineEdit { height: Theme.ctrl-h; placeholder-text: I18n.en ? "empty=byte0" : "空=byte0"; text: root.p-signal; edited(v) => { root.p-signal = v; } } }
                HorizontalLayout { spacing: 6px; Text { text: I18n.en ? "Pos X/Y" : "位置 X/Y"; width: 56px; vertical-alignment: center; font-size: Theme.fs-sm; color: Theme.text-dim; } LineEdit { width: 92px; height: Theme.ctrl-h; text: root.p-x; edited(v) => { root.p-x = v; } } LineEdit { width: 92px; height: Theme.ctrl-h; text: root.p-y; edited(v) => { root.p-y = v; } } }
                HorizontalLayout { spacing: 6px; Text { text: I18n.en ? "Size W/H" : "大小 W/H"; width: 56px; vertical-alignment: center; font-size: Theme.fs-sm; color: Theme.text-dim; } LineEdit { width: 92px; height: Theme.ctrl-h; text: root.p-w; edited(v) => { root.p-w = v; } } LineEdit { width: 92px; height: Theme.ctrl-h; text: root.p-h; edited(v) => { root.p-h = v; } } }
                HorizontalLayout { spacing: 6px; Text { text: I18n.en ? "Min" : "最小值"; width: 56px; vertical-alignment: center; font-size: Theme.fs-sm; color: Theme.text-dim; } LineEdit { height: Theme.ctrl-h; text: root.p-min; edited(v) => { root.p-min = v; } } }
                HorizontalLayout { spacing: 6px; Text { text: I18n.en ? "Max" : "最大值"; width: 56px; vertical-alignment: center; font-size: Theme.fs-sm; color: Theme.text-dim; } LineEdit { height: Theme.ctrl-h; text: root.p-max; edited(v) => { root.p-max = v; } } }
                HorizontalLayout { spacing: 6px; Text { text: I18n.en ? "Thresh" : "阈值"; width: 56px; vertical-alignment: center; font-size: Theme.fs-sm; color: Theme.text-dim; } LineEdit { height: Theme.ctrl-h; text: root.p-threshold; edited(v) => { root.p-threshold = v; } } }
                HorizontalLayout { spacing: 6px; Text { text: I18n.en ? "Wave" : "波形"; width: 56px; vertical-alignment: center; font-size: Theme.fs-sm; color: Theme.text-dim; } ComboBox { height: Theme.ctrl-h; model: I18n.en ? ["Const", "Ramp", "Sine"] : ["恒定", "斜坡", "正弦"]; current-index <=> root.p-genmode; } }
                HorizontalLayout { spacing: 6px; Text { text: I18n.en ? "Step" : "步长"; width: 56px; vertical-alignment: center; font-size: Theme.fs-sm; color: Theme.text-dim; } LineEdit { height: Theme.ctrl-h; text: root.p-step; edited(v) => { root.p-step = v; } } }
                HorizontalLayout { spacing: 6px; Text { text: I18n.en ? "Period" : "周期ms"; width: 56px; vertical-alignment: center; font-size: Theme.fs-sm; color: Theme.text-dim; } LineEdit { height: Theme.ctrl-h; text: root.p-period; edited(v) => { root.p-period = v; } } }
                HorizontalLayout { spacing: 6px; Text { text: I18n.en ? "Press" : "按下值"; width: 56px; vertical-alignment: center; font-size: Theme.fs-sm; color: Theme.text-dim; } LineEdit { height: Theme.ctrl-h; text: root.p-pressval; edited(v) => { root.p-pressval = v; } } }
                HorizontalLayout { spacing: 6px; Text { text: I18n.en ? "Release" : "释放值"; width: 56px; vertical-alignment: center; font-size: Theme.fs-sm; color: Theme.text-dim; } LineEdit { height: Theme.ctrl-h; text: root.p-releaseval; edited(v) => { root.p-releaseval = v; } } }
                HorizontalLayout { spacing: 6px; Text { text: I18n.en ? "Align" : "对齐"; width: 56px; vertical-alignment: center; font-size: Theme.fs-sm; color: Theme.text-dim; } ComboBox { height: Theme.ctrl-h; model: I18n.en ? ["Left", "Center", "Right"] : ["左", "中", "右"]; current-index <=> root.p-align; } }
                HorizontalLayout { spacing: 6px; Button { text: I18n.en ? "Apply" : "应用"; clicked => { root.prop-apply(); } } Button { text: I18n.en ? "Delete" : "删除控件"; clicked => { root.prop-remove(); } } }
            }
        }
    }
}

// ======================= Python 脚本运行器（自动化测试） =======================
export component ScriptRunnerWindow inherits Window {
    title: I18n.en ? "Python Script Runner" : "Python 脚本运行器";
    icon: @image-url("logo.svg");
    preferred-width: 760px;
    preferred-height: 560px;
    background: Theme.bg;

    in-out property <string> interp-path: "";
    in property <[string]> python-list: [];
    in-out property <string> selected-python: "";
    in-out property <string> script-path: "";
    in property <string> output: "";
    in property <bool> running: false;
    in property <int> result: 0; // -1 失败, 0 空闲/运行中, 1 通过
    in property <string> status-text: "";

    callback detect-pythons();
    callback python-selected(string);
    callback browse-interp();
    callback browse-script();
    callback run-script();
    callback run-suite();
    callback stop-run();

    VerticalLayout {
        padding: 12px;
        spacing: 10px;

        // 解释器（在此切换 Python 版本）
        Rectangle { background: Theme.panel; border-width: 1px; border-color: Theme.border; border-radius: 4px;
            VerticalLayout { padding: 8px; spacing: 6px;
                Text { text: I18n.en ? "Python interpreter (switch version here)" : "Python 解释器（在此切换版本）"; font-weight: 700; font-size: Theme.fs; color: Theme.text; }
                HorizontalLayout { spacing: 6px;
                    LineEdit { horizontal-stretch: 1; height: Theme.ctrl-h; placeholder-text: "python.exe"; text <=> root.interp-path; }
                    Button { text: I18n.en ? "Browse" : "浏览"; clicked => { root.browse-interp(); } }
                }
                HorizontalLayout { spacing: 6px;
                    ComboBox { horizontal-stretch: 1; model: root.python-list; current-value <=> root.selected-python;
                        selected(v) => { root.python-selected(v); } }
                    Button { text: I18n.en ? "Detect installed" : "检测已装版本"; clicked => { root.detect-pythons(); } }
                }
            }
        }

        // 测试脚本
        Rectangle { background: Theme.panel; border-width: 1px; border-color: Theme.border; border-radius: 4px;
            VerticalLayout { padding: 8px; spacing: 6px;
                Text { text: I18n.en ? "Test script (.py)" : "测试脚本 (.py)"; font-weight: 700; font-size: Theme.fs; color: Theme.text; }
                HorizontalLayout { spacing: 6px;
                    LineEdit { horizontal-stretch: 1; height: Theme.ctrl-h; placeholder-text: I18n.en ? "your_test.py" : "测试脚本路径"; text <=> root.script-path; }
                    Button { text: I18n.en ? "Browse" : "浏览"; clicked => { root.browse-script(); } }
                }
            }
        }

        // 运行 / 停止 + 状态
        HorizontalLayout { spacing: 8px;
            Button { text: I18n.en ? "Run" : "运行"; enabled: !root.running; clicked => { root.run-script(); } }
            Button { text: I18n.en ? "Run folder" : "运行套件"; enabled: !root.running; clicked => { root.run-suite(); } }
            Button { text: I18n.en ? "Stop" : "停止"; enabled: root.running; clicked => { root.stop-run(); } }
            Rectangle { horizontal-stretch: 1; }
            Text { text: root.status-text; vertical-alignment: center; font-weight: 700; font-size: Theme.fs;
                color: root.result == 1 ? Theme.ok : (root.result == -1 ? Theme.bad : Theme.text-dim); }
        }

        // 输出（脚本 stdout/stderr）
        Rectangle { vertical-stretch: 1; background: Theme.panel; border-width: 1px; border-color: Theme.border; border-radius: 4px;
            ScrollView {
                Text { x: 8px; y: 8px; width: root.width - 44px; text: root.output; wrap: word-wrap;
                    font-family: Theme.mono; font-size: Theme.fs-sm; color: Theme.text; }
            }
        }
    }
}
