// One-window Slint page split from the original monolithic file.
import { Button, ComboBox, LineEdit, CheckBox, TabWidget, ListView, ScrollView, VerticalBox, HorizontalBox, TextEdit } from "std-widgets.slint";
import { ByteCell, SimRow, MsgRow, SigRow, TxSigRow, TxRow, PbFileRow, TreeRow, ChanStat, IdStat, ChartSeries, DbcSignalRow, SignalPickRow, I18n, Theme, ColW, Cell, HCell, SortHeader, TBtn, Icon, RibbonBtn, RibbonGroup, RibbonTab, ConvTab, SimGlyph } from "common.slint";

export component ConvertWindow inherits Window {
    title: I18n.en ? "PcanWork - Record File Conversion" : "PcanWork - 记录文件转换";
    icon: @image-url("logo.svg");
    preferred-width: 660px;
    preferred-height: 420px;
    background: Theme.bg;

    in-out property <int> tab: 0; // 0=single format, 1=batch, 2=signal merge

    // single-file conversion (full paths held directly in these props)
    in-out property <string> src-file: "";
    in-out property <int> fmt1: 1; // 0=CSV 1=ASC 2=BLF
    in property <string> status1: "";

    // batch conversion
    in-out property <string> src-dir: "";
    in-out property <string> out-dir: "";
    in-out property <int> fmt2: 1;
    in property <string> status2: "";

    callback pick-src-file();
    callback do-convert();
    callback pick-src-dir();
    callback pick-out-dir();
    callback do-batch();

    VerticalLayout {
        padding: 12px;
        spacing: 10px;

        // tabs
        HorizontalLayout {
            spacing: 6px;
            ConvTab { label: I18n.en ? "Format" : "格式转换"; active: root.tab == 0; clicked => { root.tab = 0; } }
            ConvTab { label: I18n.en ? "Batch" : "批量转换"; active: root.tab == 1; clicked => { root.tab = 1; } }
            ConvTab { label: I18n.en ? "Signal merge" : "信号合并"; active: root.tab == 2; clicked => { root.tab = 2; } }
            Rectangle { horizontal-stretch: 1; }
        }

        // ---- tab 0: single-file format conversion ----
        if root.tab == 0: VerticalLayout {
            spacing: 10px;
            Rectangle {
                height: 40px; background: Theme.panel; border-width: 1px; border-color: Theme.border;
                HorizontalLayout {
                    padding: 6px; spacing: 8px;
                    Button { text: I18n.en ? "Source file" : "源文件"; clicked => { root.pick-src-file(); } }
                    Text {
                        text: root.src-file == "" ? (I18n.en ? "(no file selected)" : "(未选择文件)") : root.src-file;
                        vertical-alignment: center; font-size: 13px; color: Theme.text; overflow: elide; horizontal-stretch: 1;
                    }
                }
            }
            HorizontalLayout {
                spacing: 8px;
                Text { text: I18n.en ? "Target format" : "目标格式"; vertical-alignment: center; font-size: 13px; }
                ComboBox { width: 120px; model: ["CSV", "ASC", "BLF"]; current-index <=> root.fmt1; }
                Button { text: I18n.en ? "Convert" : "格式转换"; clicked => { root.do-convert(); } }
            }
            Text {
                text: I18n.en ? "Supported: CSV / Vector ASC / BLF interconversion." : "支持范围：CSV / Vector ASC / BLF 互相转换。";
                font-size: 12px; color: Theme.text-dim;
            }
            Rectangle {
                vertical-stretch: 1; background: Theme.panel2; border-radius: 4px;
                Text { x: 8px; y: 8px; text: root.status1; color: Theme.text; font-size: 12px; wrap: word-wrap; width: parent.width - 16px; }
            }
        }

        // ---- tab 1: batch folder conversion ----
        if root.tab == 1: VerticalLayout {
            spacing: 10px;
            Rectangle {
                height: 40px; background: Theme.panel; border-width: 1px; border-color: Theme.border;
                HorizontalLayout {
                    padding: 6px; spacing: 8px;
                    Button { text: I18n.en ? "Source folder" : "源目录"; clicked => { root.pick-src-dir(); } }
                    Text {
                        text: root.src-dir == "" ? (I18n.en ? "(no folder selected)" : "(未选择目录)") : root.src-dir;
                        vertical-alignment: center; font-size: 13px; color: Theme.text; overflow: elide; horizontal-stretch: 1;
                    }
                }
            }
            Rectangle {
                height: 40px; background: Theme.panel; border-width: 1px; border-color: Theme.border;
                HorizontalLayout {
                    padding: 6px; spacing: 8px;
                    Button { text: I18n.en ? "Target folder" : "目标目录"; clicked => { root.pick-out-dir(); } }
                    Text {
                        text: root.out-dir == "" ? (I18n.en ? "(no folder selected)" : "(未选择目录)") : root.out-dir;
                        vertical-alignment: center; font-size: 13px; color: Theme.text; overflow: elide; horizontal-stretch: 1;
                    }
                }
            }
            HorizontalLayout {
                spacing: 8px;
                Text { text: I18n.en ? "Target format" : "目标格式"; vertical-alignment: center; font-size: 13px; }
                ComboBox { width: 120px; model: ["CSV", "ASC", "BLF"]; current-index <=> root.fmt2; }
                Button { text: I18n.en ? "Start" : "启动转换"; clicked => { root.do-batch(); } }
            }
            ScrollView {
                vertical-stretch: 1;
                Text { x: 8px; y: 8px; text: root.status2; color: Theme.text; font-size: 12px; font-family: Theme.mono; wrap: word-wrap; width: parent.width - 16px; }
            }
        }

        // ---- tab 2: signal merge (not supported in this build) ----
        if root.tab == 2: VerticalLayout {
            spacing: 10px;
            Rectangle {
                vertical-stretch: 1; background: Theme.panel2; border-radius: 4px;
                Text {
                    x: 12px; y: 12px; width: parent.width - 24px; wrap: word-wrap;
                    color: Theme.text-dim; font-size: 13px;
                    text: I18n.en
                        ? "Signal merge requires MAT / Signal MF4 read-write support, which is not available in this build. Only CSV / ASC / BLF format and batch conversion are supported."
                        : "信号合并需要 MAT / Signal MF4 读写支持，本版本暂未实现。当前仅支持 CSV / ASC / BLF 的格式转换与批量转换。";
                }
            }
        }
    }
}
