// One-window Slint page split from the original monolithic file.
import { Button, ComboBox, LineEdit, CheckBox, ListView } from "std-widgets.slint";
import { I18n, Theme, TBtn } from "common.slint";

component SlimCombo inherits Rectangle {
    in property <[string]> model;
    in-out property <string> value;
    in property <bool> combo-enabled: true;
    callback selected(string);

    height: 26px;
    border-radius: 5px;
    border-width: 1px;
    border-color: combo-enabled ? Theme.border : Theme.border.darker(0.05);
    background: combo-enabled ? Theme.panel : Theme.panel2;

    HorizontalLayout {
        padding-left: 8px;
        padding-right: 6px;
        spacing: 4px;
        Text {
            text: root.value;
            font-size: 11px;
            color: root.combo-enabled ? Theme.text : Theme.text-dim;
            vertical-alignment: center;
            overflow: elide;
        }
        Text {
            text: "v";
            font-size: 11px;
            color: Theme.text-dim;
            vertical-alignment: center;
            horizontal-alignment: center;
            width: 12px;
        }
    }

    TouchArea {
        enabled: root.combo-enabled;
        clicked => { popup.show(); }
    }

    popup := PopupWindow {
        width: root.width;
        height: Math.min(root.model.length * 28px, 96px);
        Rectangle {
            background: Theme.panel;
            border-width: 1px;
            border-color: Theme.border;
            border-radius: 4px;
            ListView {
                for option in root.model: Rectangle {
                    height: 28px;
                    background: option == root.value ? Theme.sel : (row_touch.has-hover ? Theme.accent-soft : Theme.panel);
                    Text {
                        text: option;
                        font-size: 12px;
                        color: Theme.text;
                        vertical-alignment: center;
                        x: 10px;
                    }
                    row_touch := TouchArea {
                        clicked => {
                            root.value = option;
                            root.selected(option);
                            popup.close();
                        }
                    }
                }
            }
        }
    }
}

export component ChannelConfigWindow inherits Window {
    title: I18n.en ? "CAN Channel Config" : "CAN 通道配置";
    icon: @image-url("logo.svg");
    preferred-width: 900px;
    preferred-height: 580px;
    background: Theme.bg;

    in property <[string]> pcan-hardware;
    in property <[string]> pcan-hardware-details;
    in property <[bool]> pcan-hardware-added;
    in property <[string]> channels;
    in property <[string]> channel-details;
    in-out property <int> chan-sel: 0;
    in-out property <bool> is-fd: false;
    in-out property <string> device-type: "Virtual";
    in-out property <string> hardware-label: "";
    in-out property <string> device-index: "0";
    in-out property <string> channel-index: "0";
    in-out property <string> baud: "500K";
    in-out property <string> data-baud: "2M";
    in-out property <bool> termination: false;
    in-out property <bool> net-server: true;
    in-out property <string> ip: "192.168.0.178";
    in-out property <string> port: "8000";
    property <bool> is-net: device-type == "CANFDNET" || device-type == "CANFDWIFI";
    property <string> active-channel-title: "CAN" + (chan-sel + 1);

    callback pcan-rescan();
    callback pcan-select(int);
    callback chan-add();
    callback chan-clone();
    callback chan-remove(int);
    callback chan-select(int);
    callback chan-edit(string, string);
    callback save-all();
    callback connect-all();
    callback cancel();

    VerticalLayout {
        padding: 8px;
        spacing: 4px;

        HorizontalLayout {
            spacing: 4px;

            Rectangle {
                width: 240px;
                background: Theme.panel;
                border-width: 1px;
                border-color: Theme.border;
                VerticalLayout {
                    Rectangle {
                        height: 46px;
                        background: Theme.header;
                        VerticalLayout {
                            padding-left: 8px;
                            padding-right: 6px;
                            padding-top: 5px;
                            spacing: 3px;
                            Text {
                                text: I18n.en ? "CAN hardware device pool" : "CAN 硬件设备池";
                                font-weight: 700;
                                font-size: 12px;
                                color: Theme.text;
                            }
                            HorizontalLayout {
                                spacing: 6px;
                                TBtn { text: I18n.en ? "Rescan" : "重新扫描"; h: 24px; fs: 11px; clicked => { root.pcan-rescan(); } }
                                TBtn { text: I18n.en ? "Add" : "手动添加"; h: 24px; fs: 11px; clicked => { root.chan-add(); } }
                            }
                        }
                    }
                    ListView {
                        for h[i] in root.pcan-hardware: Rectangle {
                            height: 70px;
                            background: root.pcan-hardware-added[i] ? Theme.sel : (scan_area.has-hover ? Theme.accent-soft : Theme.panel);
                            border-width: 1px;
                            border-color: root.pcan-hardware-added[i] ? Theme.accent : Theme.border;
                            scan_area := TouchArea { clicked => { root.pcan-select(i); } }
                            VerticalLayout {
                                padding-left: 10px;
                                padding-right: 8px;
                                padding-top: 6px;
                                spacing: 3px;
                                Text {
                                    text: h;
                                    font-size: 11px;
                                    font-weight: 700;
                                    color: Theme.text;
                                    overflow: elide;
                                }
                                Text {
                                    text: root.pcan-hardware-details[i];
                                    font-size: 9px;
                                    color: Theme.text-dim;
                                    overflow: elide;
                                }
                                HorizontalLayout {
                                    spacing: 4px;
                                    Rectangle { horizontal-stretch: 1; }
                                    TBtn {
                                        text: root.pcan-hardware-added[i] ? (I18n.en ? "Added" : "已添加") : (I18n.en ? "Bind" : "绑定为通道");
                                        h: 24px;
                                        fs: 11px;
                                        clicked => { root.pcan-select(i); }
                                    }
                                }
                            }
                        }
                    }
                }
            }

            Rectangle {
                width: 280px;
                background: Theme.panel;
                border-width: 1px;
                border-color: Theme.border;
                VerticalLayout {
                    Rectangle {
                        height: 46px;
                        background: Theme.header;
                        VerticalLayout {
                            padding-left: 8px;
                            padding-right: 6px;
                            padding-top: 5px;
                            spacing: 3px;
                            Text {
                                text: I18n.en ? "CAN channel mapping" : "CAN 通道映射";
                                font-weight: 700;
                                font-size: 12px;
                                color: Theme.text;
                            }
                        }
                    }
                    ListView {
                        for c[i] in root.channels: Rectangle {
                            height: 70px;
                            background: i == root.chan-sel ? Theme.sel : (chan_area.has-hover ? Theme.accent-soft : Theme.panel);
                            border-width: 1px;
                            border-color: i == root.chan-sel ? Theme.accent : Theme.border;
                            chan_area := TouchArea { clicked => { root.chan-sel = i; root.chan-select(i); } }
                            VerticalLayout {
                                padding-left: 10px;
                                padding-right: 8px;
                                padding-top: 6px;
                                spacing: 3px;
                                Text {
                                    text: c;
                                    font-size: 11px;
                                    font-weight: 700;
                                    color: Theme.text;
                                    overflow: elide;
                                }
                                Text {
                                    text: root.channel-details[i];
                                    font-size: 9px;
                                    color: Theme.text-dim;
                                    overflow: elide;
                                }
                                HorizontalLayout {
                                    spacing: 4px;
                                    Rectangle { horizontal-stretch: 1; }
                                    TBtn { text: I18n.en ? "Configure" : "配置"; h: 24px; fs: 11px; clicked => { root.chan-sel = i; root.chan-select(i); } }
                                    TBtn { text: I18n.en ? "Delete" : "删除"; h: 24px; fs: 11px; clicked => { root.chan-remove(i); } }
                                }
                            }
                        }
                    }
                }
            }

            Rectangle {
                width: 300px;
                background: Theme.panel;
                border-width: 1px;
                border-color: Theme.border;
                VerticalLayout {
                    Rectangle {
                        height: 46px;
                        background: Theme.header;
                        VerticalLayout {
                            padding-left: 8px;
                            padding-right: 6px;
                            padding-top: 6px;
                            spacing: 2px;
                            Text {
                                text: I18n.en ? "Dynamic operation area" : "动态操作区";
                                font-weight: 700;
                                font-size: 12px;
                                color: Theme.text;
                            }
                            Text {
                                text: (I18n.en ? "Current operation: " : "当前操作：") + root.active-channel-title + (I18n.en ? " parameter config" : " 参数配置");
                                font-size: 10px;
                                color: Theme.text-dim;
                                overflow: elide;
                            }
                        }
                    }

                    Rectangle {
                        vertical-stretch: 1;
                        background: Theme.panel2;
                        border-width: 1px;
                        border-color: Theme.border;
                        VerticalLayout {
                            padding: 6px;
                            spacing: 4px;

                            Text { height: 18px; text: I18n.en ? "Basic information" : "基本信息"; font-size: 11px; font-weight: 700; color: Theme.text; vertical-alignment: center; }
                            HorizontalLayout {
                                height: 26px;
                                spacing: 4px;
                                Text { width: 45px; text: I18n.en ? "Channel" : "通道"; font-size: 10px; vertical-alignment: center; color: Theme.text-dim; }
                                Text { width: 110px; text: root.active-channel-title; font-size: 11px; vertical-alignment: center; color: Theme.text; }
                                Rectangle { horizontal-stretch: 1; }
                            }
                            HorizontalLayout {
                                height: 26px;
                                spacing: 4px;
                                Text { width: 45px; text: I18n.en ? "Note" : "备注"; font-size: 10px; vertical-alignment: center; color: Theme.text-dim; }
                                LineEdit {
                                    text: root.hardware-label;
                                    height: 26px;
                                    width: 170px;
                                    font-size: 11px;
                                    placeholder-text: I18n.en ? "e.g. BMS CAN" : "例如 BMS CAN";
                                    edited(v) => { root.hardware-label = v; root.chan-edit("hardware_label", v); }
                                }
                                Rectangle { horizontal-stretch: 1; }
                            }

                            Text { height: 18px; text: I18n.en ? "Hardware binding" : "硬件绑定"; font-size: 11px; font-weight: 700; color: Theme.text; vertical-alignment: center; }
                            HorizontalLayout {
                                height: 26px;
                                spacing: 4px;
                                Text { width: 45px; text: I18n.en ? "Vendor" : "厂商"; font-size: 10px; vertical-alignment: center; color: Theme.text-dim; }
                                SlimCombo {
                                    width: 170px;
                                    model: ["Virtual", "PCAN", "USBCANFD-200U", "USBCANFD-100U", "USBCANFD-MINI", "USBCAN2", "USBCAN-E-U", "USBCAN-2E-U", "GCAN", "ZHCX", "CANFDNET", "CANFDWIFI"];
                                    value <=> root.device-type;
                                    selected(v) => { root.chan-edit("device_type", v); }
                                }
                                Rectangle { horizontal-stretch: 1; }
                            }
                            HorizontalLayout {
                                height: 26px;
                                spacing: 4px;
                                Text { width: 45px; text: I18n.en ? "Dev idx" : "设备索引"; font-size: 10px; vertical-alignment: center; color: Theme.text-dim; }
                                LineEdit {
                                    text: root.device-index;
                                    height: 26px;
                                    width: 65px;
                                    font-size: 11px;
                                    enabled: root.device-type != "PCAN";
                                    edited(v) => { root.device-index = v; root.chan-edit("device_index", v); }
                                }
                                Text { width: 48px; text: root.device-type == "PCAN" ? "PEAK" : (I18n.en ? "HW ch" : "硬件"); font-size: 10px; vertical-alignment: center; color: Theme.text-dim; }
                                LineEdit { text: root.channel-index; height: 26px; width: 65px; font-size: 11px; edited(v) => { root.channel-index = v; root.chan-edit("channel_index", v); } }
                                Rectangle { horizontal-stretch: 1; }
                            }

                            Text { height: 18px; text: I18n.en ? "Communication" : "通信参数"; font-size: 11px; font-weight: 700; color: Theme.text; vertical-alignment: center; }
                            HorizontalLayout {
                                height: 26px;
                                spacing: 4px;
                                Text { width: 45px; text: I18n.en ? "Protocol" : "协议"; font-size: 10px; vertical-alignment: center; color: Theme.text-dim; }
                                SlimCombo {
                                    width: 90px;
                                    model: ["CAN", "CAN FD"];
                                    value: root.is-fd ? "CAN FD" : "CAN";
                                    selected(v) => { root.is-fd = v == "CAN FD"; root.chan-edit("is_fd", v == "CAN FD" ? "1" : "0"); }
                                }
                                Text { width: 34px; text: I18n.en ? "Term" : "终端"; font-size: 10px; vertical-alignment: center; color: Theme.text-dim; }
                                CheckBox { checked: root.termination; text: I18n.en ? "120R" : "120Ω"; toggled => { root.termination = self.checked; root.chan-edit("termination", self.checked ? "1" : "0"); } }
                                Rectangle { horizontal-stretch: 1; }
                            }
                            HorizontalLayout {
                                height: 26px;
                                spacing: 4px;
                                Text { width: 45px; text: I18n.en ? "Arb" : "仲裁"; font-size: 10px; vertical-alignment: center; color: Theme.text-dim; }
                                SlimCombo {
                                    width: 90px;
                                    model: ["1M", "800K", "500K", "250K", "125K"];
                                    value <=> root.baud;
                                    selected(v) => { root.chan-edit("baud", v); }
                                }
                                Text { width: 34px; text: I18n.en ? "Data" : "数据"; font-size: 10px; vertical-alignment: center; color: Theme.text-dim; }
                                SlimCombo {
                                    width: 90px;
                                    combo-enabled: root.is-fd;
                                    model: ["1M", "800K", "500K", "250K", "125K"];
                                    value <=> root.data-baud;
                                    selected(v) => { root.chan-edit("data_baud", v); }
                                }
                                Rectangle { horizontal-stretch: 1; }
                            }

                            if root.is-net: VerticalLayout {
                                spacing: 4px;
                                HorizontalLayout {
                                    height: 26px;
                                    spacing: 4px;
                                    Text { width: 45px; text: I18n.en ? "Mode" : "模式"; font-size: 10px; vertical-alignment: center; color: Theme.text-dim; }
                                    SlimCombo {
                                        width: 90px;
                                        model: I18n.en ? ["Server", "Client"] : ["服务器", "客户端"];
                                        value: root.net-server ? (I18n.en ? "Server" : "服务器") : (I18n.en ? "Client" : "客户端");
                                        selected(v) => { root.net-server = (v == "服务器" || v == "Server"); root.chan-edit("net_server", (v == "服务器" || v == "Server") ? "1" : "0"); }
                                    }
                                    Text { width: 34px; text: I18n.en ? "Port" : "端口"; font-size: 10px; vertical-alignment: center; color: Theme.text-dim; }
                                    LineEdit { text: root.port; height: 26px; width: 90px; font-size: 11px; edited(v) => { root.port = v; root.chan-edit("port", v); } }
                                    Rectangle { horizontal-stretch: 1; }
                                }
                                HorizontalLayout {
                                    height: 26px;
                                    spacing: 4px;
                                    Text { width: 45px; text: I18n.en ? "IP" : "IP"; font-size: 10px; vertical-alignment: center; color: Theme.text-dim; }
                                    LineEdit { text: root.ip; height: 26px; width: 170px; font-size: 11px; edited(v) => { root.ip = v; root.chan-edit("ip", v); } }
                                    Rectangle { horizontal-stretch: 1; }
                                }
                            }
                            Rectangle { vertical-stretch: 1; }
                        }
                    }
                }
            }
        }

        Rectangle {
            height: 42px;
            HorizontalLayout {
                spacing: 8px;
                Rectangle { horizontal-stretch: 1; }
                Button { text: I18n.en ? "Cancel" : "取消"; clicked => { root.cancel(); } }
                Button { text: I18n.en ? "Save config" : "保存配置"; clicked => { root.save-all(); } }
                Button { text: I18n.en ? "Save && Connect" : "保存并连接"; clicked => { root.connect-all(); } }
            }
        }
    }
}
